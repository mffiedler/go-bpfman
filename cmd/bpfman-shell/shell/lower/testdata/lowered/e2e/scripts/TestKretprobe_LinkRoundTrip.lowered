body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = 5
  BindName events = t1
  BuildArgs t2 = [kfunc acquire]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t3 argv=t2 primary=fn rc=_ guard=true fail=bb1
  BuildArgs t4 = [kfunc release $fn]
  RegisterDefer argv=t4 policy=def-then-exec-bind lane=builtin(kfunc)
  BuildArgs t5 = [bpfman program load file --path testdata/bpf/kprobe_counter.bpf.o --programs kretprobe:kprobe_counter]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t6 argv=t5 primary=loaded rc=_ guard=true fail=bb2
  Eval t7 = $loaded.programs[0]
  BindName prog = t7
  Eval t8 = $prog.record.program_id
  BindName pid = t8
  BuildArgs t9 = [expect_program_load $prog kretprobe kprobe kprobe_counter]
  DispatchCommand argv=t9 policy=def-then-exec-command lane=exec
  BuildArgs t10 = [bpfman link attach kprobe --fn-name $fn.name $prog]
  DispatchBind t11 = t10 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t11 argv=t10 primary=link rc=_ guard=true fail=bb3
  Eval t12 = $link.record.id
  BindName linkID = t12
  Assert $link.record.kind == kretprobe
  Assert $link.record.program_id == $pid
  Assert $link.record.details.fn_name == $fn.name
  Assert $link.record.details.offset == 0
  Assert $link.record.details.retprobe
  Assert $link.status.kernel_seen
  BuildArgs t13 = [bpfman link get $linkID]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t14 argv=t13 primary=gotLink rc=_ guard=true fail=bb4
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == kretprobe
  Assert $gotLink.record.program_id == $pid
  Assert $gotLink.record.details.fn_name == $fn.name
  Assert $gotLink.record.details.offset == 0
  Assert $gotLink.record.details.retprobe
  BuildArgs t15 = [bpfman link list -o json]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=listed rc=_ guard=true fail=bb5
  Eval t17 = $listed |> jq ".links[] | select(.id == ${linkID})"
  BindName ourLink = t17
  Require not null ourLink
  Assert $ourLink.id == $linkID
  Assert $ourLink.kind == kretprobe
  BuildArgs t18 = [kfunc fire $fn $events]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t19 argv=t18 primary=fired rc=_ guard=true fail=bb6
  Assert $fired.ok
  Eval t20 = $prog.status.maps[0].id
  BindName mapID = t20
  Eval t21 = "fromjson | [.[0].formatted.values[].value | tonumber] | add"
  BindName sumFilter = t21
  BuildArgs t22 = [bpftool map dump id $mapID -j]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=exec
  ApplyBind src=t23 argv=t22 primary=dump rc=_ guard=true fail=bb7
  Eval t24 = $dump.stdout |> jq $sumFilter
  BindName got = t24
  BuildArgs t25 = [print "kfunc=${fn.name} got=${got} want=${events}"]
  DispatchCommand argv=t25 policy=def-then-exec-command lane=builtin(print)
  Assert $got == $events
  BuildArgs t26 = [bpfman link detach $link]
  DispatchCommand argv=t26 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t27 = [bpfman link list -o json]
  DispatchBind t28 = t27 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t28 argv=t27 primary=listedAfter rc=_ guard=true fail=bb8
  BuildArgs t29 = [assert_link_absent $listedAfter $linkID]
  DispatchCommand argv=t29 policy=def-then-exec-command lane=exec
  BuildArgs t30 = [bpfman program unload $pid]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $prog
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError
