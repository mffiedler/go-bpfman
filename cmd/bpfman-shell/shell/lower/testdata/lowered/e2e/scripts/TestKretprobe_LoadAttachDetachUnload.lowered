body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  BuildArgs t1 = [bpfman program load file --path testdata/bpf/kprobe_counter.bpf.o --programs kretprobe:kprobe_counter]
  DispatchBind t2 = t1 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t2 argv=t1 primary=loaded rc=_ guard=true fail=bb1
  Eval t3 = $loaded.programs[0]
  BindName prog = t3
  Eval t4 = $prog.record.program_id
  BindName pid = t4
  BuildArgs t5 = [expect_program_load $prog kretprobe kprobe kprobe_counter]
  DispatchCommand argv=t5 policy=def-then-exec-command lane=exec
  BuildArgs t6 = [bpfman program get $pid]
  DispatchBind t7 = t6 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t7 argv=t6 primary=got rc=_ guard=true fail=bb2
  BuildArgs t8 = [expect_program_round_trip $got $prog]
  DispatchCommand argv=t8 policy=def-then-exec-command lane=exec
  BuildArgs t9 = [bpfman program list -o json]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t10 argv=t9 primary=listed rc=_ guard=true fail=bb3
  Eval t11 = ".programs[] | select(.record.program_id == ${pid})"
  BindName progFilter = t11
  Eval t12 = $listed |> jq $progFilter
  BindName ours = t12
  Require not null ours
  Assert $ours.record.meta.name == $prog.record.meta.name
  Assert $ours.status.kernel.id == $prog.status.kernel.id
  BuildArgs t13 = [bpfman link attach kprobe --fn-name try_to_wake_up $prog]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t14 argv=t13 primary=link rc=_ guard=true fail=bb4
  Eval t15 = $link.record.id
  BindName linkID = t15
  Assert $link.record.kind == kretprobe
  Assert $link.record.program_id == $pid
  Assert $link.record.details.fn_name == try_to_wake_up
  Assert $link.record.details.offset == 0
  Assert $link.record.details.retprobe
  Assert $link.status.kernel_seen
  BuildArgs t16 = [bpfman link get $linkID]
  DispatchBind t17 = t16 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t17 argv=t16 primary=gotLink rc=_ guard=true fail=bb5
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == $link.record.kind
  Assert $gotLink.record.details.fn_name == $link.record.details.fn_name
  Assert $gotLink.record.details.retprobe == $link.record.details.retprobe
  BuildArgs t18 = [bpfman link list -o json]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t19 argv=t18 primary=listedLinks rc=_ guard=true fail=bb6
  Eval t20 = ".links[] | select(.id == ${linkID})"
  BindName linkFilter = t20
  Eval t21 = $listedLinks |> jq $linkFilter
  BindName ourLink = t21
  Require not null ourLink
  Assert $ourLink.id == $link.record.id
  Assert $ourLink.kind == $link.record.kind
  Eval t22 = $prog.status.maps[0].id
  BindName mapID = t22
  Eval t23 = "fromjson | [.[0].formatted.values[].value | tonumber] | add"
  BindName sumFilter = t23
  BuildArgs t24 = [bpftool map dump id $mapID -j]
  DispatchBind t25 = t24 policy=def-then-exec-bind lane=exec
  ApplyBind src=t25 argv=t24 primary=dumpBefore rc=_ guard=true fail=bb7
  Eval t26 = $dumpBefore.stdout |> jq $sumFilter
  BindName before = t26
  BuildArgs t27 = [sleep 0.1]
  DispatchCommand argv=t27 policy=def-then-exec-command lane=exec
  BuildArgs t28 = [bpftool map dump id $mapID -j]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=exec
  ApplyBind src=t29 argv=t28 primary=dumpAfter rc=_ guard=true fail=bb8
  Eval t30 = $dumpAfter.stdout |> jq $sumFilter
  BindName after = t30
  Eval t31 = $after - $before
  BindName delta = t31
  Assert $delta > 0
  BuildArgs t32 = [bpfman link detach $link]
  DispatchCommand argv=t32 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t33 = [bpfman program unload $pid]
  DispatchCommand argv=t33 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $prog
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError
