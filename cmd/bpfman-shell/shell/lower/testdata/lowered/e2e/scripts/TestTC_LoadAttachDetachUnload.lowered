body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  BuildArgs t1 = [net veth-pair]
  DispatchBind t2 = t1 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t2 argv=t1 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t3 = [net release $pair]
  RegisterDefer argv=t3 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t4 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t5 argv=t4 primary=loaded rc=_ guard=true fail=bb2
  Eval t6 = $loaded.programs[0]
  BindName prog = t6
  Eval t7 = $prog.record.program_id
  BindName pid = t7
  BuildArgs t8 = [expect_program_load $prog tc extension stats]
  DispatchCommand argv=t8 policy=def-then-exec-command lane=exec
  BuildArgs t9 = [bpfman program get $pid]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t10 argv=t9 primary=got rc=_ guard=true fail=bb3
  BuildArgs t11 = [expect_program_round_trip $got $prog]
  DispatchCommand argv=t11 policy=def-then-exec-command lane=exec
  BuildArgs t12 = [bpfman program list -o json]
  DispatchBind t13 = t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t13 argv=t12 primary=listed rc=_ guard=true fail=bb4
  Eval t14 = ".programs[] | select(.record.program_id == ${pid})"
  BindName progFilter = t14
  Eval t15 = $listed |> jq $progFilter
  BindName ours = t15
  Require not null ours
  Assert $ours.record.meta.name == $prog.record.meta.name
  Assert $ours.status.kernel.id == $prog.status.kernel.id
  BuildArgs t16 = [bpfman link attach tc --iface $pair.host_link --direction ingress --priority 50 $prog]
  DispatchBind t17 = t16 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t17 argv=t16 primary=link rc=_ guard=true fail=bb5
  Eval t18 = $link.record.id
  BindName linkID = t18
  Assert $link.record.kind == tc
  Assert $link.record.details.interface == $pair.host_link
  Assert $link.record.details.direction == ingress
  Assert $link.record.details.priority == 50
  Assert $link.record.details.dispatcher_id > 0
  Assert $link.record.details.revision > 0
  Assert $link.status.kernel_seen
  BuildArgs t19 = [tc filter show dev $pair.host_link ingress]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=exec
  ApplyBind src=t20 argv=t19 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t21 = [bpfman link get $linkID]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t22 argv=t21 primary=gotLink rc=_ guard=true fail=bb7
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == $link.record.kind
  Assert $gotLink.record.details.interface == $link.record.details.interface
  Assert $gotLink.record.details.direction == $link.record.details.direction
  Assert $gotLink.record.details.priority == $link.record.details.priority
  Assert $gotLink.record.details.dispatcher_id == $link.record.details.dispatcher_id
  BuildArgs t23 = [bpfman link list -o json]
  DispatchBind t24 = t23 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t24 argv=t23 primary=listedLinks rc=_ guard=true fail=bb8
  Eval t25 = ".links[] | select(.id == ${linkID})"
  BindName linkFilter = t25
  Eval t26 = $listedLinks |> jq $linkFilter
  BindName ourLink = t26
  Require not null ourLink
  Assert $ourLink.id == $link.record.id
  Assert $ourLink.kind == $link.record.kind
  Eval t27 = $prog.status.maps[0].id
  BindName mapID = t27
  Eval t28 = "fromjson | [.[] | select(.formatted.key == 0) | .formatted.values[].value.rx_packets] | add"
  BindName sumFilter = t28
  BuildArgs t29 = [bpftool map dump id $mapID -j]
  DispatchBind t30 = t29 policy=def-then-exec-bind lane=exec
  ApplyBind src=t30 argv=t29 primary=dumpBefore rc=_ guard=true fail=bb9
  Eval t31 = $dumpBefore.stdout |> jq $sumFilter
  BindName before = t31
  BuildArgs t32 = [net exec $pair ping -c 5 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t33 = t32 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t33 argv=t32 primary=_ rc=_ guard=true fail=bb10
  BuildArgs t34 = [bpftool map dump id $mapID -j]
  DispatchBind t35 = t34 policy=def-then-exec-bind lane=exec
  ApplyBind src=t35 argv=t34 primary=dumpAfter rc=_ guard=true fail=bb11
  Eval t36 = $dumpAfter.stdout |> jq $sumFilter
  BindName after = t36
  Eval t37 = $after - $before
  BindName delta = t37
  Assert $delta >= 5
  BuildArgs t38 = [bpfman link detach $link]
  DispatchCommand argv=t38 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t39 = [bpfman program unload $pid]
  DispatchCommand argv=t39 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $prog
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError
