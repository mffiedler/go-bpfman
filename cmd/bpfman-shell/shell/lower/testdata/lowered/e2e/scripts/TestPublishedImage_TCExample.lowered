body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = "quay.io/bpfman-bytecode/go-tc-counter"
  BindName image = t1
  BuildArgs t2 = [inspect_published_image $image stats]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=exec
  ApplyBind src=t3 argv=t2 primary=published rc=_ guard=true fail=bb1
  Eval t4 = $published
  BindDestructure [inspected manifest] = t4
  Assert $manifest.programs.stats == tc
  Assert $manifest.maps.tc_stats_map == per_cpu_array
  BuildArgs t5 = [net veth-pair]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t6 argv=t5 primary=pair rc=_ guard=true fail=bb2
  BuildArgs t7 = [net release $pair]
  RegisterDefer argv=t7 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t8 = [bpfman program load image --image-url $image --pull-policy Always --programs tc:stats]
  DispatchBind t9 = t8 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t9 argv=t8 primary=loaded rc=_ guard=true fail=bb3
  Eval t10 = $loaded.programs[0]
  BindName prog = t10
  Eval t11 = $prog.record.program_id
  BindName pid = t11
  BuildArgs t12 = [bpfman program unload $pid]
  RegisterDefer argv=t12 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t13 = [expect_program_load $prog tc extension stats]
  DispatchCommand argv=t13 policy=def-then-exec-command lane=exec
  BuildArgs t14 = [expect_loaded_image_source $prog $image $inspected]
  DispatchCommand argv=t14 policy=def-then-exec-command lane=exec
  BuildArgs t15 = [bpfman link attach tc --iface $pair.host_link --direction ingress --priority 50 $prog]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=link rc=_ guard=true fail=bb4
  Eval t17 = $link.record.id
  BindName linkID = t17
  Assert $link.record.kind == tc
  Assert $link.record.program_id == $pid
  Assert $link.record.details.interface == $pair.host_link
  Assert $link.record.details.direction == ingress
  Assert $link.record.details.priority == 50
  Assert $link.status.kernel_seen
  Eval t18 = $prog.status.maps[0].id
  BindName mapID = t18
  Eval t19 = "fromjson | [.[] | select(.formatted.key == 0) | .formatted.values[].value.rx_packets | tonumber] | add"
  BindName sumFilter = t19
  BuildArgs t20 = [bpftool map dump id $mapID -j]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=exec
  ApplyBind src=t21 argv=t20 primary=dumpBefore rc=_ guard=true fail=bb5
  Eval t22 = $dumpBefore.stdout |> jq $sumFilter
  BindName before = t22
  BuildArgs t23 = [net exec $pair ping -c 5 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t24 = t23 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t24 argv=t23 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t25 = [bpftool map dump id $mapID -j]
  DispatchBind t26 = t25 policy=def-then-exec-bind lane=exec
  ApplyBind src=t26 argv=t25 primary=dumpAfter rc=_ guard=true fail=bb7
  Eval t27 = $dumpAfter.stdout |> jq $sumFilter
  BindName after = t27
  Eval t28 = $after - $before
  BindName delta = t28
  BuildArgs t29 = [print "published tc image: packets=${delta}"]
  DispatchCommand argv=t29 policy=def-then-exec-command lane=builtin(print)
  Assert $delta >= 5
  BuildArgs t30 = [bpfman link detach $link]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t31 = [sleep 0.1]
  DispatchCommand argv=t31 policy=def-then-exec-command lane=exec
  BuildArgs t32 = [bpftool map dump id $mapID -j]
  DispatchBind t33 = t32 policy=def-then-exec-bind lane=exec
  ApplyBind src=t33 argv=t32 primary=dumpDetached rc=_ guard=true fail=bb8
  Eval t34 = $dumpDetached.stdout |> jq $sumFilter
  BindName detached = t34
  BuildArgs t35 = [net exec $pair ping -c 5 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t36 = t35 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t36 argv=t35 primary=_ rc=_ guard=true fail=bb9
  BuildArgs t37 = [bpftool map dump id $mapID -j]
  DispatchBind t38 = t37 policy=def-then-exec-bind lane=exec
  ApplyBind src=t38 argv=t37 primary=dumpAfterDetach rc=_ guard=true fail=bb10
  Eval t39 = $dumpAfterDetach.stdout |> jq $sumFilter
  BindName afterDetach = t39
  BuildArgs t40 = [print "published tc image after-detach=${afterDetach} want=${detached}"]
  DispatchCommand argv=t40 policy=def-then-exec-command lane=builtin(print)
  Assert $afterDetach == $detached
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError
