body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  BuildArgs t1 = [uprobe-target]
  DispatchBind t2 = t1 policy=def-then-exec-bind lane=builtin(uprobe-target)
  ApplyBind src=t2 argv=t1 primary=target rc=_ guard=true fail=bb1
  BuildArgs t3 = [bpfman program load file --path testdata/bpf/uprobe_counter.bpf.o --programs uprobe:uprobe_counter]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded rc=_ guard=true fail=bb2
  Eval t5 = $loaded.programs[0]
  BindName prog = t5
  Eval t6 = $prog.record.program_id
  BindName pid = t6
  BuildArgs t7 = [bpfman program unload $pid]
  RegisterDefer argv=t7 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t8 = [bpfman link attach uprobe --target $target.path --fn-name $target.symbol $prog]
  DispatchBind t9 = t8 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t9 argv=t8 primary=link rc=_ guard=true fail=bb3
  Eval t10 = $link.record.id
  BindName linkID = t10
  Assert $link.record.kind == uprobe
  Assert $link.record.program_id == $pid
  Assert $link.record.details.target == $target.path
  Assert $link.record.details.fn_name == $target.symbol
  Assert $link.record.details.offset == 0
  Assert not $link.record.details.retprobe
  Assert $link.status.kernel_seen
  BuildArgs t11 = [bpfman link get $linkID]
  DispatchBind t12 = t11 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t12 argv=t11 primary=gotLink rc=_ guard=true fail=bb4
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == uprobe
  Assert $gotLink.record.program_id == $pid
  Assert $gotLink.record.details.target == $target.path
  Assert $gotLink.record.details.fn_name == $target.symbol
  Assert $gotLink.record.details.offset == 0
  Assert not $gotLink.record.details.retprobe
  BuildArgs t13 = [bpfman link list -o json]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t14 argv=t13 primary=listed rc=_ guard=true fail=bb5
  Eval t15 = $listed |> jq ".links[] | select(.id == ${linkID})"
  BindName ourLink = t15
  Require not null ourLink
  Assert $ourLink.id == $linkID
  Assert $ourLink.kind == uprobe
  BuildArgs t16 = [bpfman link detach $link]
  DispatchCommand argv=t16 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t17 = [bpfman link list -o json]
  DispatchBind t18 = t17 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t18 argv=t17 primary=listedAfter rc=_ guard=true fail=bb6
  BuildArgs t19 = [assert_link_absent $listedAfter $linkID]
  DispatchCommand argv=t19 policy=def-then-exec-command lane=exec
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError
