body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = 5
  BindName n = t1
  Eval t2 = 11
  BindName weight = t2
  BuildArgs t3 = [uprobe target]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(uprobe)
  ApplyBind src=t4 argv=t3 primary=target rc=_ guard=true fail=bb1
  BuildArgs t5 = [bpfman program load file --path testdata/bpf/uprobe_exact.bpf.o --programs uprobe:uprobe_counter -g "expected_pid=0x${u32le $target.pid}" -g "weight=0x${u64le $weight}"]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t6 argv=t5 primary=loaded rc=_ guard=true fail=bb2
  Eval t7 = $loaded.programs[0]
  BindName prog = t7
  Eval t8 = $prog.record.program_id
  BindName pid = t8
  BuildArgs t9 = [bpfman program unload $pid]
  RegisterDefer argv=t9 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t10 = [bpfman link attach uprobe --target $target.path --fn-name $target.symbol $prog]
  DispatchBind t11 = t10 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t11 argv=t10 primary=link rc=_ guard=true fail=bb3
  Eval t12 = $link.record.id
  BindName linkID = t12
  Assert $link.record.kind == uprobe
  Assert $link.record.program_id == $pid
  Assert $link.record.details.target == $target.path
  Assert $link.record.details.fn_name == $target.symbol
  Assert $link.record.details.offset == 0
  Assert not $link.record.details.retprobe
  Assert $link.status.kernel_seen
  BuildArgs t13 = [bpfman link get $linkID]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t14 argv=t13 primary=gotLink rc=_ guard=true fail=bb4
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == uprobe
  Assert $gotLink.record.program_id == $pid
  Assert $gotLink.record.details.target == $target.path
  Assert $gotLink.record.details.fn_name == $target.symbol
  Assert $gotLink.record.details.offset == 0
  Assert not $gotLink.record.details.retprobe
  BuildArgs t15 = [bpfman link list -o json]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=listed rc=_ guard=true fail=bb5
  Eval t17 = $listed |> jq ".links[] | select(.id == ${linkID})"
  BindName ourLink = t17
  Require not null ourLink
  Assert $ourLink.id == $linkID
  Assert $ourLink.kind == uprobe
  Eval t18 = $prog |> jq "[.status.maps[] | select(.name == \"up_count\") | .id][0]"
  BindName mapID = t18
  Eval t19 = "fromjson | .[0].formatted.value | tonumber"
  BindName counter_filter = t19
  BuildArgs t20 = [uprobe fire $n]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(uprobe)
  ApplyBind src=t21 argv=t20 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t22 = [bpftool map dump id $mapID -j]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=exec
  ApplyBind src=t23 argv=t22 primary=dump rc=_ guard=true fail=bb7
  Eval t24 = $dump.stdout |> jq $counter_filter
  BindName count = t24
  Eval t25 = $n * $weight
  BindName want = t25
  BuildArgs t26 = [print "uprobe count: got=${count} want=${want}"]
  DispatchCommand argv=t26 policy=def-then-exec-command lane=builtin(print)
  Assert $count == $want
  BuildArgs t27 = [bpfman link detach $link]
  DispatchCommand argv=t27 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t28 = [bpfman link list -o json]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t29 argv=t28 primary=listedAfter rc=_ guard=true fail=bb8
  BuildArgs t30 = [assert_link_absent $listedAfter $linkID]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=exec
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError
