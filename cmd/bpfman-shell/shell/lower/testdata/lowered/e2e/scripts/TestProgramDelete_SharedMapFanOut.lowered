body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  BuildArgs t1 = [print "PROOF: shared-map delete fan-out (one owner, three dependants)"]
  DispatchCommand argv=t1 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t2 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats -m role=owner]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t3 argv=t2 primary=ownerA rc=_ guard=true fail=bb1
  Eval t4 = $ownerA.programs[0]
  BindName progOwnerA = t4
  Eval t5 = $progOwnerA.record.program_id
  BindName oA = t5
  BuildArgs t6 = [expect_program_load $progOwnerA tcx schedcls tcx_stats]
  DispatchCommand argv=t6 policy=def-then-exec-command lane=exec
  BuildArgs t7 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oA]
  DispatchBind t8 = t7 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t8 argv=t7 primary=depA1 rc=_ guard=true fail=bb2
  Eval t9 = $depA1.programs[0].record.program_id
  BindName dA1 = t9
  Assert $depA1.programs[0].record.handles.map_owner_id == $oA
  BuildArgs t10 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oA]
  DispatchBind t11 = t10 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t11 argv=t10 primary=depA2 rc=_ guard=true fail=bb3
  Eval t12 = $depA2.programs[0].record.program_id
  BindName dA2 = t12
  Assert $depA2.programs[0].record.handles.map_owner_id == $oA
  BuildArgs t13 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oA]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t14 argv=t13 primary=depA3 rc=_ guard=true fail=bb4
  Eval t15 = $depA3.programs[0].record.program_id
  BindName dA3 = t15
  Assert $depA3.programs[0].record.handles.map_owner_id == $oA
  BuildArgs t16 = [print "A: owner=${oA} with dependants ${dA1}, ${dA2}, ${dA3} sharing its maps"]
  DispatchCommand argv=t16 policy=def-then-exec-command lane=builtin(print)
  Assert fail bpfman program delete $oA
  BuildArgs t17 = [bpfman program list -o json]
  DispatchBind t18 = t17 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t18 argv=t17 primary=afterFailA rc=_ guard=true fail=bb5
  Eval t19 = $afterFailA |> jq "[.programs[]] | length"
  BindName survivorsA = t19
  Assert $survivorsA == 4
  BuildArgs t20 = [print "A: non-recursive delete of owner ${oA} alone refused; all 4 survive"]
  DispatchCommand argv=t20 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t21 = [bpfman program delete $dA2 $oA $dA3 $dA1]
  DispatchCommand argv=t21 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $oA
  Assert fail bpfman program get $dA1
  Assert fail bpfman program get $dA2
  Assert fail bpfman program get $dA3
  BuildArgs t22 = [print "A: scrambled batch (${dA2} ${oA} ${dA3} ${dA1}) deleted all four"]
  DispatchCommand argv=t22 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t23 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats]
  DispatchBind t24 = t23 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t24 argv=t23 primary=ownerB rc=_ guard=true fail=bb6
  Eval t25 = $ownerB.programs[0].record.program_id
  BindName oB = t25
  BuildArgs t26 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oB]
  DispatchBind t27 = t26 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t27 argv=t26 primary=depB1 rc=_ guard=true fail=bb7
  Eval t28 = $depB1.programs[0].record.program_id
  BindName dB1 = t28
  BuildArgs t29 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oB]
  DispatchBind t30 = t29 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t30 argv=t29 primary=depB2 rc=_ guard=true fail=bb8
  Eval t31 = $depB2.programs[0].record.program_id
  BindName dB2 = t31
  BuildArgs t32 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oB]
  DispatchBind t33 = t32 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t33 argv=t32 primary=depB3 rc=_ guard=true fail=bb9
  Eval t34 = $depB3.programs[0].record.program_id
  BindName dB3 = t34
  Assert $depB1.programs[0].record.handles.map_owner_id == $oB
  Assert $depB3.programs[0].record.handles.map_owner_id == $oB
  BuildArgs t35 = [bpfman program delete $oB -r]
  DispatchCommand argv=t35 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $oB
  Assert fail bpfman program get $dB1
  Assert fail bpfman program get $dB2
  Assert fail bpfman program get $dB3
  BuildArgs t36 = [print "B: recursive delete of ${oB} removed unnamed dependants ${dB1}, ${dB2}, ${dB3}"]
  DispatchCommand argv=t36 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t37 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats]
  DispatchBind t38 = t37 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t38 argv=t37 primary=ownerC rc=_ guard=true fail=bb10
  Eval t39 = $ownerC.programs[0].record.program_id
  BindName oC = t39
  BuildArgs t40 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oC]
  DispatchBind t41 = t40 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t41 argv=t40 primary=depC1 rc=_ guard=true fail=bb11
  Eval t42 = $depC1.programs[0].record.program_id
  BindName dC1 = t42
  BuildArgs t43 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oC]
  DispatchBind t44 = t43 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t44 argv=t43 primary=depC2 rc=_ guard=true fail=bb12
  Eval t45 = $depC2.programs[0].record.program_id
  BindName dC2 = t45
  BuildArgs t46 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oC]
  DispatchBind t47 = t46 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t47 argv=t46 primary=depC3 rc=_ guard=true fail=bb13
  Eval t48 = $depC3.programs[0].record.program_id
  BindName dC3 = t48
  Assert $depC1.programs[0].record.handles.map_owner_id == $oC
  Assert $depC2.programs[0].record.handles.map_owner_id == $oC
  Assert $depC3.programs[0].record.handles.map_owner_id == $oC
  BuildArgs t49 = [bpfman program delete $oC $dC2 $dC1 -r]
  DispatchCommand argv=t49 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $oC
  Assert fail bpfman program get $dC1
  Assert fail bpfman program get $dC2
  Assert fail bpfman program get $dC3
  BuildArgs t50 = [print "C: recursive owner-plus-named batch (${oC} ${dC2} ${dC1}) deduped all dependants"]
  DispatchCommand argv=t50 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t51 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats]
  DispatchBind t52 = t51 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t52 argv=t51 primary=ownerD rc=_ guard=true fail=bb14
  Eval t53 = $ownerD.programs[0].record.program_id
  BindName oD = t53
  BuildArgs t54 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oD]
  DispatchBind t55 = t54 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t55 argv=t54 primary=depD1 rc=_ guard=true fail=bb15
  BuildArgs t56 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oD]
  DispatchBind t57 = t56 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t57 argv=t56 primary=depD2 rc=_ guard=true fail=bb16
  BuildArgs t58 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oD]
  DispatchBind t59 = t58 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t59 argv=t58 primary=depD3 rc=_ guard=true fail=bb17
  Assert $depD1.programs[0].record.handles.map_owner_id == $oD
  BuildArgs t60 = [bpfman program delete --all]
  DispatchCommand argv=t60 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t61 = [bpfman program list -o json]
  DispatchBind t62 = t61 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t62 argv=t61 primary=listedD rc=_ guard=true fail=bb18
  Eval t63 = $listedD |> jq "[.programs[]] | length"
  BindName remainingD = t63
  Assert $remainingD == 0
  BuildArgs t64 = [print "D: --all cleared the fan-out; remaining=${remainingD}"]
  DispatchCommand argv=t64 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t65 = [print "PROOF complete: fan-out ordering holds for scrambled batch, recursive, dedup, and --all"]
  DispatchCommand argv=t65 policy=def-then-exec-command lane=builtin(print)
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError

bb12:
  RunDefers policy=program
  PropagateError

bb13:
  RunDefers policy=program
  PropagateError

bb14:
  RunDefers policy=program
  PropagateError

bb15:
  RunDefers policy=program
  PropagateError

bb16:
  RunDefers policy=program
  PropagateError

bb17:
  RunDefers policy=program
  PropagateError

bb18:
  RunDefers policy=program
  PropagateError
