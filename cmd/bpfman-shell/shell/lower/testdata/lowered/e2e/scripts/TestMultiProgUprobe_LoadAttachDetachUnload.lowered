body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = 5
  BindName n = t1
  Eval t2 = 41
  BindName weight_a = t2
  Eval t3 = 42
  BindName weight_b = t3
  Eval t4 = 43
  BindName weight_c = t4
  BuildArgs t5 = [uprobe target]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(uprobe)
  ApplyBind src=t6 argv=t5 primary=target rc=_ guard=true fail=bb1
  BuildArgs t7 = [bpfman program load file --path testdata/bpf/multi_prog_uprobe_counter.bpf.o --programs uprobe:mup_a,uprobe:mup_b,uprobe:mup_c -g "expected_pid=0x${u32le $target.pid}" -g "weight_a=0x${u64le $weight_a}" -g "weight_b=0x${u64le $weight_b}" -g "weight_c=0x${u64le $weight_c}"]
  DispatchBind t8 = t7 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t8 argv=t7 primary=loaded rc=_ guard=true fail=bb2
  Eval t9 = [$loaded.programs[0] $loaded.programs[0].record.program_id]
  BindDestructure [prog_a pid_a] = t9
  Eval t10 = [$loaded.programs[1] $loaded.programs[1].record.program_id]
  BindDestructure [prog_b pid_b] = t10
  Eval t11 = [$loaded.programs[2] $loaded.programs[2].record.program_id]
  BindDestructure [prog_c pid_c] = t11
  BuildArgs t12 = [bpfman program unload $pid_a]
  RegisterDefer argv=t12 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t13 = [bpfman program unload $pid_b]
  RegisterDefer argv=t13 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t14 = [bpfman program unload $pid_c]
  RegisterDefer argv=t14 policy=def-then-exec-bind lane=builtin(bpfman)
  Eval t15 = $prog_a |> jq "[.status.maps[] | select(.name == \"mup_a_count\") | .id][0]"
  BindName mapID_a = t15
  Eval t16 = $prog_b |> jq "[.status.maps[] | select(.name == \"mup_b_count\") | .id][0]"
  BindName mapID_b = t16
  Eval t17 = $prog_c |> jq "[.status.maps[] | select(.name == \"mup_c_count\") | .id][0]"
  BindName mapID_c = t17
  BuildArgs t18 = [bpfman link attach uprobe --target $target.path -f $target.symbol $pid_a]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t19 argv=t18 primary=link_a rc=_ guard=true fail=bb3
  BuildArgs t20 = [bpfman link attach uprobe --target $target.path -f $target.symbol $pid_b]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t21 argv=t20 primary=link_b rc=_ guard=true fail=bb4
  BuildArgs t22 = [bpfman link attach uprobe --target $target.path -f $target.symbol $pid_c]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t23 argv=t22 primary=link_c rc=_ guard=true fail=bb5
  Eval t24 = "fromjson | .[0].formatted.value | tonumber"
  BindName counter_filter = t24
  BuildArgs t25 = [uprobe fire $n]
  DispatchBind t26 = t25 policy=def-then-exec-bind lane=builtin(uprobe)
  ApplyBind src=t26 argv=t25 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t27 = [bpfman link detach $link_c]
  DispatchCommand argv=t27 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t28 = [sleep 0.1]
  DispatchCommand argv=t28 policy=def-then-exec-command lane=exec
  BuildArgs t29 = [uprobe fire $n]
  DispatchBind t30 = t29 policy=def-then-exec-bind lane=builtin(uprobe)
  ApplyBind src=t30 argv=t29 primary=_ rc=_ guard=true fail=bb7
  BuildArgs t31 = [bpfman link detach $link_b]
  DispatchCommand argv=t31 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t32 = [sleep 0.1]
  DispatchCommand argv=t32 policy=def-then-exec-command lane=exec
  BuildArgs t33 = [uprobe fire $n]
  DispatchBind t34 = t33 policy=def-then-exec-bind lane=builtin(uprobe)
  ApplyBind src=t34 argv=t33 primary=_ rc=_ guard=true fail=bb8
  BuildArgs t35 = [bpftool map dump id $mapID_a -j]
  DispatchBind t36 = t35 policy=def-then-exec-bind lane=exec
  ApplyBind src=t36 argv=t35 primary=dump_a rc=_ guard=true fail=bb9
  BuildArgs t37 = [bpftool map dump id $mapID_b -j]
  DispatchBind t38 = t37 policy=def-then-exec-bind lane=exec
  ApplyBind src=t38 argv=t37 primary=dump_b rc=_ guard=true fail=bb10
  BuildArgs t39 = [bpftool map dump id $mapID_c -j]
  DispatchBind t40 = t39 policy=def-then-exec-bind lane=exec
  ApplyBind src=t40 argv=t39 primary=dump_c rc=_ guard=true fail=bb11
  Eval t41 = $dump_a.stdout |> jq $counter_filter
  BindName count_a = t41
  Eval t42 = $dump_b.stdout |> jq $counter_filter
  BindName count_b = t42
  Eval t43 = $dump_c.stdout |> jq $counter_filter
  BindName count_c = t43
  Eval t44 = (3 * $n) * $weight_a
  BindName want_a = t44
  Eval t45 = (2 * $n) * $weight_b
  BindName want_b = t45
  Eval t46 = (1 * $n) * $weight_c
  BindName want_c = t46
  BuildArgs t47 = [print "a: got=${count_a} want=${want_a}"]
  DispatchCommand argv=t47 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t48 = [print "b: got=${count_b} want=${want_b}"]
  DispatchCommand argv=t48 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t49 = [print "c: got=${count_c} want=${want_c}"]
  DispatchCommand argv=t49 policy=def-then-exec-command lane=builtin(print)
  Assert $count_a == $want_a
  Assert $count_b == $want_b
  Assert $count_c == $want_c
  BuildArgs t50 = [bpfman link detach $link_a]
  DispatchCommand argv=t50 policy=def-then-exec-command lane=builtin(bpfman)
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError
