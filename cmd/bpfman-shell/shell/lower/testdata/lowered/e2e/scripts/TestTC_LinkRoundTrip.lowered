body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  BuildArgs t1 = [net veth-pair]
  DispatchBind t2 = t1 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t2 argv=t1 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t3 = [net release $pair]
  RegisterDefer argv=t3 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t4 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t5 argv=t4 primary=loaded rc=_ guard=true fail=bb2
  Eval t6 = $loaded.programs[0]
  BindName prog = t6
  Eval t7 = $prog.record.program_id
  BindName pid = t7
  BuildArgs t8 = [bpfman program unload $pid]
  RegisterDefer argv=t8 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t9 = [bpfman link attach tc --iface $pair.host_link --direction ingress --priority 50 $prog]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t10 argv=t9 primary=link rc=_ guard=true fail=bb3
  Eval t11 = $link.record.id
  BindName linkID = t11
  Assert $link.record.kind == tc
  Assert $link.record.program_id == $pid
  Assert $link.record.details.interface == $pair.host_link
  Assert $link.record.details.direction == ingress
  Assert $link.record.details.priority == 50
  Assert $link.record.details.dispatcher_id > 0
  Assert $link.record.details.revision > 0
  Assert $link.status.kernel_seen
  BuildArgs t12 = [bpfman link get $linkID]
  DispatchBind t13 = t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t13 argv=t12 primary=gotLink rc=_ guard=true fail=bb4
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == tc
  Assert $gotLink.record.program_id == $pid
  Assert $gotLink.record.details.interface == $pair.host_link
  Assert $gotLink.record.details.direction == ingress
  Assert $gotLink.record.details.priority == 50
  Assert $gotLink.record.details.dispatcher_id == $link.record.details.dispatcher_id
  BuildArgs t14 = [tc filter show dev $pair.host_link ingress]
  DispatchBind t15 = t14 policy=def-then-exec-bind lane=exec
  ApplyBind src=t15 argv=t14 primary=_ rc=_ guard=true fail=bb5
  BuildArgs t16 = [bpfman link list -o json]
  DispatchBind t17 = t16 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t17 argv=t16 primary=listed rc=_ guard=true fail=bb6
  Eval t18 = $listed |> jq ".links[] | select(.id == ${linkID})"
  BindName ourLink = t18
  Require not null ourLink
  Assert $ourLink.id == $linkID
  Assert $ourLink.kind == tc
  Eval t19 = $prog.status.maps[0].id
  BindName mapID = t19
  Eval t20 = "fromjson | [.[] | select(.formatted.key == 0) | .formatted.values[].value.rx_packets] | add"
  BindName sumFilter = t20
  BuildArgs t21 = [bpftool map dump id $mapID -j]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=exec
  ApplyBind src=t22 argv=t21 primary=dumpBefore rc=_ guard=true fail=bb7
  Eval t23 = $dumpBefore.stdout |> jq $sumFilter
  BindName before = t23
  BuildArgs t24 = [net exec $pair ping -c 5 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t25 = t24 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t25 argv=t24 primary=_ rc=_ guard=true fail=bb8
  BuildArgs t26 = [bpftool map dump id $mapID -j]
  DispatchBind t27 = t26 policy=def-then-exec-bind lane=exec
  ApplyBind src=t27 argv=t26 primary=dumpAfter rc=_ guard=true fail=bb9
  Eval t28 = $dumpAfter.stdout |> jq $sumFilter
  BindName after = t28
  Eval t29 = $after - $before
  BindName delta = t29
  BuildArgs t30 = [print "tc count: before=${before} after=${after} delta=${delta}"]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=builtin(print)
  Assert $delta >= 5
  BuildArgs t31 = [bpfman link detach $link]
  DispatchCommand argv=t31 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t32 = [bpfman link list -o json]
  DispatchBind t33 = t32 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t33 argv=t32 primary=listedAfter rc=_ guard=true fail=bb10
  BuildArgs t34 = [assert_link_absent $listedAfter $linkID]
  DispatchCommand argv=t34 policy=def-then-exec-command lane=exec
  BuildArgs t35 = [sleep 0.1]
  DispatchCommand argv=t35 policy=def-then-exec-command lane=exec
  BuildArgs t36 = [bpftool map dump id $mapID -j]
  DispatchBind t37 = t36 policy=def-then-exec-bind lane=exec
  ApplyBind src=t37 argv=t36 primary=dumpDetached rc=_ guard=true fail=bb11
  Eval t38 = $dumpDetached.stdout |> jq $sumFilter
  BindName detached = t38
  BuildArgs t39 = [net exec $pair ping -c 5 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t40 = t39 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t40 argv=t39 primary=_ rc=_ guard=true fail=bb12
  BuildArgs t41 = [bpftool map dump id $mapID -j]
  DispatchBind t42 = t41 policy=def-then-exec-bind lane=exec
  ApplyBind src=t42 argv=t41 primary=dumpAfterDetach rc=_ guard=true fail=bb13
  Eval t43 = $dumpAfterDetach.stdout |> jq $sumFilter
  BindName afterDetach = t43
  BuildArgs t44 = [print "tc after-detach=${afterDetach} want=${detached}"]
  DispatchCommand argv=t44 policy=def-then-exec-command lane=builtin(print)
  Assert $afterDetach == $detached
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError

bb12:
  RunDefers policy=program
  PropagateError

bb13:
  RunDefers policy=program
  PropagateError
