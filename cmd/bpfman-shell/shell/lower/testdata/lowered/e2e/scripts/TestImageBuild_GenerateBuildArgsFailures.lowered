body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [exec bpfman image generate-build-args testdata/bpf/does-not-exist.bpf.o -o json]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t1 argv=t0 primary=_ rc=missing_rc guard=false
  Assert not $missing_rc.ok
  Assert contains $missing_rc.stderr "open bytecode ELF"
  BuildArgs t2 = [tempdir image-build-failures]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(tempdir)
  ApplyBind src=t3 argv=t2 primary=dir rc=_ guard=false
  BuildArgs t4 = [exec rm -rf $dir.path]
  RegisterDefer argv=t4 policy=def-then-exec-bind lane=builtin(exec)
  Eval t5 = "${dir.path}/malformed.o"
  BindName malformed = t5
  BuildArgs t6 = [exec sh -c "printf \"not an elf\" > \"$1\"" sh $malformed]
  DispatchBind t7 = t6 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t7 argv=t6 primary=_ rc=_ guard=true fail=bb1
  BuildArgs t8 = [exec bpfman image generate-build-args $malformed -o json]
  DispatchBind t9 = t8 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t9 argv=t8 primary=_ rc=malformed_rc guard=false
  Assert not $malformed_rc.ok
  Assert contains $malformed_rc.stderr "open bytecode ELF"
  BuildArgs t10 = [exec bpfman image generate-build-args linux/s390x=testdata/bpf/xdp_pass.bpf.o -o json]
  DispatchBind t11 = t10 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t11 argv=t10 primary=_ rc=endian_rc guard=false
  Assert not $endian_rc.ok
  Assert contains $endian_rc.stderr "expected ELFDATA2MSB"
  Eval t12 = "${dir.path}/bpf_x86_bpfel.o"
  BindName recognised = t12
  Eval t13 = "${dir.path}/bpf_future_bpfel.o"
  BindName unrecognised = t13
  BuildArgs t14 = [exec cp testdata/bpf/xdp_pass.bpf.o $recognised]
  DispatchBind t15 = t14 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t15 argv=t14 primary=_ rc=_ guard=true fail=bb2
  BuildArgs t16 = [exec cp testdata/bpf/xdp_pass.bpf.o $unrecognised]
  DispatchBind t17 = t16 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t17 argv=t16 primary=_ rc=_ guard=true fail=bb3
  BuildArgs t18 = [exec bpfman image generate-build-args --cilium-ebpf-project $dir.path -o json]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t19 argv=t18 primary=_ rc=cilium_rc guard=false
  Assert not $cilium_rc.ok
  Assert contains $cilium_rc.stderr "unrecognised cilium/ebpf bytecode file"
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError
