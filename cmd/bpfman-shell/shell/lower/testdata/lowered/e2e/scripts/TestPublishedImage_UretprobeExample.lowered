body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = "quay.io/bpfman-bytecode/go-uretprobe-counter"
  BindName image = t1
  BuildArgs t2 = [inspect_published_image $image uretprobe_counter]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=exec
  ApplyBind src=t3 argv=t2 primary=published rc=_ guard=true fail=bb1
  Assert $published.manifest.programs.uretprobe_counter == probe
  Assert $published.manifest.maps.uretprobe_stats_map == per_cpu_array
  BuildArgs t4 = [uprobe target]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(uprobe)
  ApplyBind src=t5 argv=t4 primary=target rc=_ guard=true fail=bb2
  BuildArgs t6 = [bpfman program load image --image-url $image --pull-policy Always --programs uretprobe:uretprobe_counter]
  DispatchBind t7 = t6 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t7 argv=t6 primary=loaded rc=_ guard=true fail=bb3
  Eval t8 = $loaded.programs[0]
  BindName prog = t8
  Eval t9 = $prog.record.program_id
  BindName pid = t9
  BuildArgs t10 = [bpfman program unload $pid]
  RegisterDefer argv=t10 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t11 = [expect_program_load $prog uretprobe kprobe uretprobe_counter]
  DispatchCommand argv=t11 policy=def-then-exec-command lane=exec
  BuildArgs t12 = [expect_loaded_image_source $prog $image $published.inspected]
  DispatchCommand argv=t12 policy=def-then-exec-command lane=exec
  BuildArgs t13 = [bpfman link attach uprobe --target $target.path --fn-name $target.symbol $prog]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t14 argv=t13 primary=link rc=_ guard=true fail=bb4
  Eval t15 = $link.record.id
  BindName linkID = t15
  Assert $link.record.kind == uretprobe
  Assert $link.record.program_id == $pid
  Assert $link.record.details.target == $target.path
  Assert $link.record.details.fn_name == $target.symbol
  Assert $link.record.details.retprobe
  Assert $link.status.kernel_seen
  Eval t16 = 5
  BindName events = t16
  Eval t17 = $prog.status.maps[0].id
  BindName mapID = t17
  Eval t18 = "fromjson | [.[].formatted.values[].value | tonumber] | add"
  BindName sumFilter = t18
  BuildArgs t19 = [bpftool map dump id $mapID -j]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=exec
  ApplyBind src=t20 argv=t19 primary=dumpBefore rc=_ guard=true fail=bb5
  Eval t21 = $dumpBefore.stdout |> jq $sumFilter
  BindName before = t21
  BuildArgs t22 = [uprobe fire $events]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=builtin(uprobe)
  ApplyBind src=t23 argv=t22 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t24 = [bpftool map dump id $mapID -j]
  DispatchBind t25 = t24 policy=def-then-exec-bind lane=exec
  ApplyBind src=t25 argv=t24 primary=dumpAfter rc=_ guard=true fail=bb7
  Eval t26 = $dumpAfter.stdout |> jq $sumFilter
  BindName after = t26
  Eval t27 = $after - $before
  BindName delta = t27
  BuildArgs t28 = [print "published uretprobe image: events=${delta}"]
  DispatchCommand argv=t28 policy=def-then-exec-command lane=builtin(print)
  Assert $delta >= $events
  BuildArgs t29 = [bpfman link detach $link]
  DispatchCommand argv=t29 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t30 = [sleep 0.1]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=exec
  BuildArgs t31 = [bpftool map dump id $mapID -j]
  DispatchBind t32 = t31 policy=def-then-exec-bind lane=exec
  ApplyBind src=t32 argv=t31 primary=dumpDetached rc=_ guard=true fail=bb8
  Eval t33 = $dumpDetached.stdout |> jq $sumFilter
  BindName detached = t33
  BuildArgs t34 = [uprobe fire $events]
  DispatchBind t35 = t34 policy=def-then-exec-bind lane=builtin(uprobe)
  ApplyBind src=t35 argv=t34 primary=_ rc=_ guard=true fail=bb9
  BuildArgs t36 = [bpftool map dump id $mapID -j]
  DispatchBind t37 = t36 policy=def-then-exec-bind lane=exec
  ApplyBind src=t37 argv=t36 primary=dumpAfterDetach rc=_ guard=true fail=bb10
  Eval t38 = $dumpAfterDetach.stdout |> jq $sumFilter
  BindName afterDetach = t38
  BuildArgs t39 = [print "published uretprobe image after-detach=${afterDetach} want=${detached}"]
  DispatchCommand argv=t39 policy=def-then-exec-command lane=builtin(print)
  Assert $afterDetach == $detached
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError
