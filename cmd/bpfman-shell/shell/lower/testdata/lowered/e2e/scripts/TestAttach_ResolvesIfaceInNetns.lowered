body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  Eval t3 = "/var/run/netns/${pair.ns}"
  BindName netns = t3
  BuildArgs t4 = [print "attaching to peer-only interface ${pair.peer_link} in netns ${netns}"]
  DispatchCommand argv=t4 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t5 = [bpfman program load file --path testdata/bpf/xdp_pass.bpf.o --programs xdp:pass]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t6 argv=t5 primary=xdpLoaded rc=_ guard=true fail=bb2
  Eval t7 = $xdpLoaded.programs[0]
  BindName xdpProg = t7
  Eval t8 = $xdpProg.record.program_id
  BindName xdpPID = t8
  BuildArgs t9 = [bpfman program unload $xdpPID]
  RegisterDefer argv=t9 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t10 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t11 = t10 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t11 argv=t10 primary=tcLoaded rc=_ guard=true fail=bb3
  Eval t12 = $tcLoaded.programs[0]
  BindName tcProg = t12
  Eval t13 = $tcProg.record.program_id
  BindName tcPID = t13
  BuildArgs t14 = [bpfman program unload $tcPID]
  RegisterDefer argv=t14 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t15 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=tcxLoaded rc=_ guard=true fail=bb4
  Eval t17 = $tcxLoaded.programs[0]
  BindName tcxProg = t17
  Eval t18 = $tcxProg.record.program_id
  BindName tcxPID = t18
  BuildArgs t19 = [bpfman program unload $tcxPID]
  RegisterDefer argv=t19 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t20 = [bpfman link attach xdp --iface $pair.peer_link --netns $netns $xdpProg]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t21 argv=t20 primary=xdpLink rc=_ guard=true fail=bb5
  BuildArgs t22 = [bpfman link detach $xdpLink]
  RegisterDefer argv=t22 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t23 = [print "xdp attach resolved ${pair.peer_link} through ${netns}"]
  DispatchCommand argv=t23 policy=def-then-exec-command lane=builtin(print)
  Assert $xdpLink.record.kind == xdp
  Assert $xdpLink.record.program_id == $xdpPID
  Assert $xdpLink.record.details.interface == $pair.peer_link
  Assert $xdpLink.status.kernel_seen
  BuildArgs t24 = [bpfman link attach tc --iface $pair.peer_link --direction ingress --priority 50 --netns $netns $tcProg]
  DispatchBind t25 = t24 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t25 argv=t24 primary=tcLink rc=_ guard=true fail=bb6
  BuildArgs t26 = [bpfman link detach $tcLink]
  RegisterDefer argv=t26 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t27 = [print "tc attach resolved ${pair.peer_link} through ${netns}"]
  DispatchCommand argv=t27 policy=def-then-exec-command lane=builtin(print)
  Assert $tcLink.record.kind == tc
  Assert $tcLink.record.program_id == $tcPID
  Assert $tcLink.record.details.interface == $pair.peer_link
  Assert $tcLink.record.details.direction == ingress
  Assert $tcLink.record.details.priority == 50
  Assert $tcLink.status.kernel_seen
  BuildArgs t28 = [bpfman link attach tcx --iface $pair.peer_link --direction ingress --priority 60 --netns $netns $tcxProg]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t29 argv=t28 primary=tcxLink rc=_ guard=true fail=bb7
  BuildArgs t30 = [bpfman link detach $tcxLink]
  RegisterDefer argv=t30 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t31 = [print "tcx attach resolved ${pair.peer_link} through ${netns}"]
  DispatchCommand argv=t31 policy=def-then-exec-command lane=builtin(print)
  Assert $tcxLink.record.kind == tcx
  Assert $tcxLink.record.program_id == $tcxPID
  Assert $tcxLink.record.details.interface == $pair.peer_link
  Assert $tcxLink.record.details.direction == ingress
  Assert $tcxLink.record.details.priority == 60
  Assert $tcxLink.status.kernel_seen
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError
