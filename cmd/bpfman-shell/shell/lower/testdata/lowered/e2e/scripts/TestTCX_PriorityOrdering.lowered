body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  Eval t3 = [500 100 800 300 55]
  BindName priorities = t3
  Eval t4 = $priorities
  ForEachCollect list=t4 names=[prio] primary=links rc=_ guard=true body=bb2 exit=bb3

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  BuildArgs t5 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t6 argv=t5 primary=loaded rc=_ guard=true fail=bb4
  Eval t7 = $loaded.programs[0]
  BindName prog = t7
  BuildArgs t8 = [bpfman program unload $prog]
  RegisterDefer argv=t8 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t9 = [bpfman link attach tcx -i $pair.host_link -d ingress -p $prio $prog]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  CollectProduce t10

bb3:
  Eval t11 = $links
  ForEach list=t11 names=[l] body=bb5 exit=bb6

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  BuildArgs t12 = [bpfman link detach $l]
  RegisterDefer argv=t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ForEachContinue

bb6:
  Eval t13 = $links
  ForEachCollect list=t13 names=[l] primary=refreshed rc=_ guard=true body=bb7 exit=bb8

bb7:
  BuildArgs t14 = [bpfman link get $l]
  DispatchBind t15 = t14 policy=def-then-exec-bind lane=builtin(bpfman)
  CollectProduce t15

bb8:
  Eval t16 = $refreshed
  ForEach list=t16 names=[r] body=bb9 exit=bb10

bb9:
  Eval t17 = $r.record.details.priority
  BindName prio = t17
  Eval t18 = $r.record.details.position
  BindName pos = t18
  Eval t19 = $priorities |> jq "sort | index(${prio})"
  BindName want_pos = t19
  Assert $pos == $want_pos
  ForEachContinue

bb10:
  RunDefers policy=program
  Stop
