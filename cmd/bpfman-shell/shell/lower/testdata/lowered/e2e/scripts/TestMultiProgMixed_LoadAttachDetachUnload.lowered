body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = 5
  BindName n = t1
  Eval t2 = 41
  BindName weight_tp = t2
  Eval t3 = 42
  BindName weight_kp = t3
  Eval t4 = 43
  BindName weight_krp = t4
  BuildArgs t5 = [kfunc acquire]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t6 argv=t5 primary=fn rc=_ guard=true fail=bb1
  BuildArgs t7 = [kfunc release $fn]
  RegisterDefer argv=t7 policy=def-then-exec-bind lane=builtin(kfunc)
  BuildArgs t8 = [bpfman program load file --path testdata/bpf/multi_prog_mixed_counter_script.bpf.o --programs tracepoint:mixed_tp,kprobe:mixed_kp,kretprobe:mixed_krp -g "expected_slot=0x${u32le $fn.index}" -g "weight_tp=0x${u64le $weight_tp}" -g "weight_kp=0x${u64le $weight_kp}" -g "weight_krp=0x${u64le $weight_krp}"]
  DispatchBind t9 = t8 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t9 argv=t8 primary=loaded rc=_ guard=true fail=bb2
  Eval t10 = [$loaded.programs[0] $loaded.programs[0].record.program_id]
  BindDestructure [prog_tp pid_tp] = t10
  Eval t11 = [$loaded.programs[1] $loaded.programs[1].record.program_id]
  BindDestructure [prog_kp pid_kp] = t11
  Eval t12 = [$loaded.programs[2] $loaded.programs[2].record.program_id]
  BindDestructure [prog_krp pid_krp] = t12
  BuildArgs t13 = [bpfman program unload $pid_tp]
  RegisterDefer argv=t13 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t14 = [bpfman program unload $pid_kp]
  RegisterDefer argv=t14 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t15 = [bpfman program unload $pid_krp]
  RegisterDefer argv=t15 policy=def-then-exec-bind lane=builtin(bpfman)
  Eval t16 = $prog_tp |> jq "[.status.maps[] | select(.name == \"mtp_count\")  | .id][0]"
  BindName mapID_tp = t16
  Eval t17 = $prog_kp |> jq "[.status.maps[] | select(.name == \"mkp_count\")  | .id][0]"
  BindName mapID_kp = t17
  Eval t18 = $prog_krp |> jq "[.status.maps[] | select(.name == \"mkrp_count\") | .id][0]"
  BindName mapID_krp = t18
  BuildArgs t19 = [bpfman link attach tracepoint $pid_tp bpfman_e2e/bpfman_e2e_ping]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t20 argv=t19 primary=link_tp rc=_ guard=true fail=bb3
  BuildArgs t21 = [bpfman link attach kprobe --fn-name $fn.name $pid_kp]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t22 argv=t21 primary=link_kp rc=_ guard=true fail=bb4
  BuildArgs t23 = [bpfman link attach kprobe --fn-name $fn.name $pid_krp]
  DispatchBind t24 = t23 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t24 argv=t23 primary=link_krp rc=_ guard=true fail=bb5
  Eval t25 = "fromjson | .[0].formatted.value | tonumber"
  BindName counter_filter = t25
  BuildArgs t26 = [kfunc fire $fn $n]
  DispatchBind t27 = t26 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t27 argv=t26 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t28 = [bpfman link detach $link_krp]
  DispatchCommand argv=t28 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t29 = [sleep 0.1]
  DispatchCommand argv=t29 policy=def-then-exec-command lane=exec
  BuildArgs t30 = [kfunc fire $fn $n]
  DispatchBind t31 = t30 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t31 argv=t30 primary=_ rc=_ guard=true fail=bb7
  BuildArgs t32 = [bpfman link detach $link_kp]
  DispatchCommand argv=t32 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t33 = [sleep 0.1]
  DispatchCommand argv=t33 policy=def-then-exec-command lane=exec
  BuildArgs t34 = [kfunc fire $fn $n]
  DispatchBind t35 = t34 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t35 argv=t34 primary=_ rc=_ guard=true fail=bb8
  BuildArgs t36 = [bpftool map dump id $mapID_tp -j]
  DispatchBind t37 = t36 policy=def-then-exec-bind lane=exec
  ApplyBind src=t37 argv=t36 primary=dump_tp rc=_ guard=true fail=bb9
  BuildArgs t38 = [bpftool map dump id $mapID_kp -j]
  DispatchBind t39 = t38 policy=def-then-exec-bind lane=exec
  ApplyBind src=t39 argv=t38 primary=dump_kp rc=_ guard=true fail=bb10
  BuildArgs t40 = [bpftool map dump id $mapID_krp -j]
  DispatchBind t41 = t40 policy=def-then-exec-bind lane=exec
  ApplyBind src=t41 argv=t40 primary=dump_krp rc=_ guard=true fail=bb11
  Eval t42 = $dump_tp.stdout |> jq $counter_filter
  BindName count_tp = t42
  Eval t43 = $dump_kp.stdout |> jq $counter_filter
  BindName count_kp = t43
  Eval t44 = $dump_krp.stdout |> jq $counter_filter
  BindName count_krp = t44
  Eval t45 = (3 * $n) * $weight_tp
  BindName want_tp = t45
  Eval t46 = (2 * $n) * $weight_kp
  BindName want_kp = t46
  Eval t47 = (1 * $n) * $weight_krp
  BindName want_krp = t47
  BuildArgs t48 = [print "tp:  got=${count_tp}  want=${want_tp}"]
  DispatchCommand argv=t48 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t49 = [print "kp:  got=${count_kp}  want=${want_kp}"]
  DispatchCommand argv=t49 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t50 = [print "krp: got=${count_krp} want=${want_krp}"]
  DispatchCommand argv=t50 policy=def-then-exec-command lane=builtin(print)
  Assert $count_tp == $want_tp
  Assert $count_kp == $want_kp
  Assert $count_krp == $want_krp
  BuildArgs t51 = [bpfman link detach $link_tp]
  DispatchCommand argv=t51 policy=def-then-exec-command lane=builtin(bpfman)
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError
