body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  BuildArgs t1 = [kfunc acquire]
  DispatchBind t2 = t1 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t2 argv=t1 primary=fn rc=_ guard=true fail=bb1
  BuildArgs t3 = [kfunc release $fn]
  RegisterDefer argv=t3 policy=def-then-exec-bind lane=builtin(kfunc)
  BuildArgs t4 = [bpfman program load file --path testdata/bpf/fentry_counter.bpf.o --programs "fentry:test_fentry:${fn.name}" -m owner=e2e -m purpose=load-and-get]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t5 argv=t4 primary=loaded rc=_ guard=true fail=bb2
  Eval t6 = $loaded.programs[0]
  BindName prog = t6
  Eval t7 = $prog.record.program_id
  BindName pid = t7
  Eval t8 = $prog.record.handles.pin_path |> jq "split(\"/fs/\")[0]"
  BindName runtime_base = t8
  Eval t9 = "${runtime_base}/fs/prog_${pid}"
  BindName expect_prog_pin = t9
  Eval t10 = "${runtime_base}/fs/maps/${pid}"
  BindName expect_map_dir = t10
  Eval t11 = "${runtime_base}/fs/links/${pid}"
  BindName expect_link_dir = t11
  Eval t12 = "${runtime_base}/programs/${pid}/bytecode.o"
  BindName expect_bytecode = t12
  Eval t13 = $prog.status.maps |> jq "[.[].id]"
  BindName expect_map_ids = t13
  Eval t14 = $prog.status.kernel.map_ids[0]
  BindName expect_map_id = t14
  BuildArgs t15 = [expect_program_load $prog fentry tracing test_fentry]
  DispatchCommand argv=t15 policy=def-then-exec-command lane=exec
  Assert $prog matches exhaustive { record: matches exhaustive { program_id: $pid, license: "Dual BSD/GPL", gpl_compatible: true, created_at: not-empty, updated_at: null, load: matches exhaustive { object_path: $expect_bytecode, program_name: test_fentry, program_type: fentry, attach_func: $fn.name, map_owner_id: null, global_data: empty, image_source: null }, handles: matches exhaustive { pin_path: $expect_prog_pin, map_pin_path: $expect_map_dir, map_owner_id: null }, meta: matches exhaustive { name: test_fentry, owner: "", description: "", metadata: matches exhaustive { owner: e2e, purpose: load-and-get } } }, status: matches exhaustive { kernel: matches exhaustive { id: $pid, name: test_fentry, program_type: tracing, tag: not-empty, loaded_at: not-empty, uid: 0, has_uid: true, btf_id: not-empty, has_btf_id: true, map_ids: $expect_map_ids, has_map_ids: true, jited_size: not-empty, xlated_size: not-empty, verified_insns: not-empty, memlock: not-empty, has_memlock: true, restricted: false }, stats: null, prog_pin: $expect_prog_pin, map_dir: $expect_map_dir, link_dir: $expect_link_dir, bytecode: $expect_bytecode, links: empty, maps: not-empty } }
  Assert $pid > 0
  Assert $prog.status.kernel.jited_size > 0
  Assert $prog.status.kernel.xlated_size > 0
  Assert $prog.status.kernel.verified_insns > 0
  Assert $prog.status.kernel.btf_id > 0
  Assert $prog.status.kernel.memlock > 0
  Eval t16 = $prog.status.maps[0]
  BindName m = t16
  Assert $m matches exhaustive { id: $expect_map_id, name: fentry_stats_ma, map_type: percpuarray, key_size: 4, value_size: 8, max_entries: 2, flags: 0, btf_id: not-empty, has_btf_id: true, map_extra: 0, has_map_extra: false, memlock: not-empty, has_memlock: true, frozen: false, pin_path: "", present: false }
  Assert $m.id > 0
  Assert $m.btf_id > 0
  Assert $m.memlock > 0
  BuildArgs t17 = [bpfman program get $pid]
  DispatchBind t18 = t17 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t18 argv=t17 primary=got rc=_ guard=true fail=bb3
  Assert $got matches exhaustive { record: matches exhaustive { program_id: $prog.record.program_id, license: $prog.record.license, gpl_compatible: $prog.record.gpl_compatible, created_at: $prog.record.created_at, updated_at: null, load: matches exhaustive { object_path: $prog.record.load.object_path, program_name: $prog.record.load.program_name, program_type: $prog.record.load.program_type, attach_func: $fn.name, map_owner_id: $prog.record.load.map_owner_id, global_data: empty, image_source: null }, handles: matches exhaustive { pin_path: $prog.record.handles.pin_path, map_pin_path: $prog.record.handles.map_pin_path, map_owner_id: null }, meta: matches exhaustive { name: $prog.record.meta.name, owner: $prog.record.meta.owner, description: $prog.record.meta.description, metadata: matches exhaustive { owner: $prog.record.meta.metadata.owner, purpose: $prog.record.meta.metadata.purpose } } }, status: matches exhaustive { kernel: matches exhaustive { id: $prog.status.kernel.id, name: test_fentry, program_type: tracing, tag: $prog.status.kernel.tag, loaded_at: $prog.status.kernel.loaded_at, uid: 0, has_uid: true, btf_id: $prog.status.kernel.btf_id, has_btf_id: true, map_ids: $expect_map_ids, has_map_ids: true, jited_size: $prog.status.kernel.jited_size, xlated_size: $prog.status.kernel.xlated_size, verified_insns: $prog.status.kernel.verified_insns, memlock: $prog.status.kernel.memlock, has_memlock: true, restricted: false }, stats: matches exhaustive { runtime: 0, run_count: 0, recursion_misses: 0 }, prog_pin: $expect_prog_pin, map_dir: $expect_map_dir, link_dir: $expect_link_dir, bytecode: $expect_bytecode, links: empty, maps: not-empty } }
  Eval t19 = $got.status.maps[0]
  BindName gm = t19
  Eval t20 = "${runtime_base}/fs/maps/${pid}/fentry_stats_map"
  BindName expect_map_pin = t20
  Assert $gm matches exhaustive { id: $m.id, name: $m.name, map_type: $m.map_type, key_size: $m.key_size, value_size: $m.value_size, max_entries: $m.max_entries, flags: $m.flags, btf_id: $m.btf_id, has_btf_id: $m.has_btf_id, map_extra: $m.map_extra, has_map_extra: $m.has_map_extra, memlock: $m.memlock, has_memlock: $m.has_memlock, frozen: $m.frozen, pin_path: $expect_map_pin, present: true }
  BuildArgs t21 = [bpfman program list -o json]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t22 argv=t21 primary=listed rc=_ guard=true fail=bb4
  Eval t23 = $listed |> jq ".programs[] | select(.record.program_id == ${pid})"
  BindName ours = t23
  Assert present $ours
  Assert $ours.record.meta.name == $prog.record.meta.name
  Assert $ours.status.kernel.id == $prog.status.kernel.id
  BuildArgs t24 = [bpfman program unload $pid]
  DispatchCommand argv=t24 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $pid
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError
