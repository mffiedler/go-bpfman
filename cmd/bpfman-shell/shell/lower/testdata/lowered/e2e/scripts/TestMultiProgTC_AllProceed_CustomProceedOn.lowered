body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = 5
  BindName n = t1
  Eval t2 = 41
  BindName weight_a = t2
  Eval t3 = 42
  BindName weight_b = t3
  Eval t4 = 43
  BindName weight_c = t4
  BuildArgs t5 = [net veth-pair]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t6 argv=t5 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t7 = [net release $pair]
  RegisterDefer argv=t7 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t8 = [bpfman program load file --path testdata/bpf/multi_prog_tc_param_verdict.bpf.o --programs tc:mtcv_a,tc:mtcv_b,tc:mtcv_c -g "weight_a=0x${u64le $weight_a}" -g "weight_b=0x${u64le $weight_b}" -g "weight_c=0x${u64le $weight_c}" -g verdict_a=0x00000000 -g verdict_b=0x00000000 -g verdict_c=0x00000000]
  DispatchBind t9 = t8 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t9 argv=t8 primary=loaded rc=_ guard=true fail=bb2
  Eval t10 = [$loaded.programs[0] $loaded.programs[0].record.program_id]
  BindDestructure [prog_a pid_a] = t10
  Eval t11 = [$loaded.programs[1] $loaded.programs[1].record.program_id]
  BindDestructure [prog_b pid_b] = t11
  Eval t12 = [$loaded.programs[2] $loaded.programs[2].record.program_id]
  BindDestructure [prog_c pid_c] = t12
  BuildArgs t13 = [bpfman program unload $pid_a]
  RegisterDefer argv=t13 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t14 = [bpfman program unload $pid_b]
  RegisterDefer argv=t14 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t15 = [bpfman program unload $pid_c]
  RegisterDefer argv=t15 policy=def-then-exec-bind lane=builtin(bpfman)
  Eval t16 = $prog_a |> jq "[.status.maps[] | select(.name == \"mtcv_a_count\") | .id][0]"
  BindName mapID_a = t16
  Eval t17 = $prog_b |> jq "[.status.maps[] | select(.name == \"mtcv_b_count\") | .id][0]"
  BindName mapID_b = t17
  Eval t18 = $prog_c |> jq "[.status.maps[] | select(.name == \"mtcv_c_count\") | .id][0]"
  BindName mapID_c = t18
  BuildArgs t19 = [bpfman link attach tc -i $pair.host_link -d ingress -p 50 --proceed-on ok,dispatcher_return $pid_a]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t20 argv=t19 primary=link_a rc=_ guard=true fail=bb3
  BuildArgs t21 = [bpfman link attach tc -i $pair.host_link -d ingress -p 60 --proceed-on ok,dispatcher_return $pid_b]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t22 argv=t21 primary=link_b rc=_ guard=true fail=bb4
  BuildArgs t23 = [bpfman link attach tc -i $pair.host_link -d ingress -p 70 --proceed-on ok,dispatcher_return $pid_c]
  DispatchBind t24 = t23 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t24 argv=t23 primary=link_c rc=_ guard=true fail=bb5
  Eval t25 = "fromjson | .[0].formatted.value | tonumber"
  BindName counter_filter = t25
  BuildArgs t26 = [net exec $pair ping -c $n -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t27 = t26 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t27 argv=t26 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t28 = [bpftool map dump id $mapID_a -j]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=exec
  ApplyBind src=t29 argv=t28 primary=dump_a rc=_ guard=true fail=bb7
  BuildArgs t30 = [bpftool map dump id $mapID_b -j]
  DispatchBind t31 = t30 policy=def-then-exec-bind lane=exec
  ApplyBind src=t31 argv=t30 primary=dump_b rc=_ guard=true fail=bb8
  BuildArgs t32 = [bpftool map dump id $mapID_c -j]
  DispatchBind t33 = t32 policy=def-then-exec-bind lane=exec
  ApplyBind src=t33 argv=t32 primary=dump_c rc=_ guard=true fail=bb9
  Eval t34 = $dump_a.stdout |> jq $counter_filter
  BindName count_a = t34
  Eval t35 = $dump_b.stdout |> jq $counter_filter
  BindName count_b = t35
  Eval t36 = $dump_c.stdout |> jq $counter_filter
  BindName count_c = t36
  Eval t37 = $n * $weight_a
  BindName want_a = t37
  Eval t38 = $n * $weight_b
  BindName want_b = t38
  Eval t39 = $n * $weight_c
  BindName want_c = t39
  BuildArgs t40 = [print "a: got=${count_a} want=${want_a}"]
  DispatchCommand argv=t40 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t41 = [print "b: got=${count_b} want=${want_b}"]
  DispatchCommand argv=t41 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t42 = [print "c: got=${count_c} want=${want_c}"]
  DispatchCommand argv=t42 policy=def-then-exec-command lane=builtin(print)
  Assert $count_a == $want_a
  Assert $count_b == $want_b
  Assert $count_c == $want_c
  BuildArgs t43 = [bpfman link detach $link_a]
  DispatchCommand argv=t43 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t44 = [bpfman link detach $link_b]
  DispatchCommand argv=t44 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t45 = [bpfman link detach $link_c]
  DispatchCommand argv=t45 policy=def-then-exec-command lane=builtin(bpfman)
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError
