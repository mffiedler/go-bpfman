body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = 5
  BindName events = t1
  Eval t2 = 17
  BindName weight = t2
  BuildArgs t3 = [kfunc acquire]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t4 argv=t3 primary=fn rc=_ guard=true fail=bb1
  BuildArgs t5 = [kfunc release $fn]
  RegisterDefer argv=t5 policy=def-then-exec-bind lane=builtin(kfunc)
  BuildArgs t6 = [bpfman program load file --path testdata/bpf/tracepoint_kmod_counter.bpf.o --programs tracepoint:tracepoint_kmod_recorder -g "expected_slot=0x${u32le $fn.index}" -g "weight=0x${u64le $weight}"]
  DispatchBind t7 = t6 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t7 argv=t6 primary=loaded rc=_ guard=true fail=bb2
  Eval t8 = $loaded.programs[0]
  BindName prog = t8
  Eval t9 = $prog.record.program_id
  BindName pid = t9
  BuildArgs t10 = [bpfman link attach tracepoint $prog bpfman_e2e/bpfman_e2e_ping]
  DispatchBind t11 = t10 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t11 argv=t10 primary=link rc=_ guard=true fail=bb3
  Eval t12 = $link.record.id
  BindName linkID = t12
  Assert $link.record.kind == tracepoint
  Assert $link.record.program_id == $pid
  Assert $link.record.details.group == bpfman_e2e
  Assert $link.record.details.name == bpfman_e2e_ping
  Assert $link.status.kernel_seen
  BuildArgs t13 = [bpfman link get $linkID]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t14 argv=t13 primary=gotLink rc=_ guard=true fail=bb4
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == tracepoint
  Assert $gotLink.record.program_id == $pid
  Assert $gotLink.record.details.group == bpfman_e2e
  Assert $gotLink.record.details.name == bpfman_e2e_ping
  BuildArgs t15 = [bpfman link list -o json]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=listed rc=_ guard=true fail=bb5
  Eval t17 = $listed |> jq ".links[] | select(.id == ${linkID})"
  BindName ourLink = t17
  Require not null ourLink
  Assert $ourLink.id == $linkID
  Assert $ourLink.kind == tracepoint
  BuildArgs t18 = [kfunc fire $fn $events]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t19 argv=t18 primary=_ rc=_ guard=true fail=bb6
  Eval t20 = $prog |> jq "[.status.maps[] | select(.name == \"tp_kmod_count\") | .id][0]"
  BindName mapID = t20
  Eval t21 = "fromjson | .[0].formatted.value | tonumber"
  BindName counterFilter = t21
  BuildArgs t22 = [bpftool map dump id $mapID -j]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=exec
  ApplyBind src=t23 argv=t22 primary=dump rc=_ guard=true fail=bb7
  Eval t24 = $dump.stdout |> jq $counterFilter
  BindName got = t24
  Eval t25 = $events * $weight
  BindName want = t25
  BuildArgs t26 = [print "tracepoint: got=${got} want=${want}"]
  DispatchCommand argv=t26 policy=def-then-exec-command lane=builtin(print)
  Assert $got == $want
  BuildArgs t27 = [bpfman link detach $link]
  DispatchCommand argv=t27 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t28 = [bpfman link list -o json]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t29 argv=t28 primary=listedAfter rc=_ guard=true fail=bb8
  BuildArgs t30 = [assert_link_absent $listedAfter $linkID]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=exec
  BuildArgs t31 = [sleep 0.1]
  DispatchCommand argv=t31 policy=def-then-exec-command lane=exec
  BuildArgs t32 = [bpftool map dump id $mapID -j]
  DispatchBind t33 = t32 policy=def-then-exec-bind lane=exec
  ApplyBind src=t33 argv=t32 primary=dumpDetached rc=_ guard=true fail=bb9
  Eval t34 = $dumpDetached.stdout |> jq $counterFilter
  BindName detached = t34
  BuildArgs t35 = [kfunc fire $fn $events]
  DispatchBind t36 = t35 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t36 argv=t35 primary=_ rc=_ guard=true fail=bb10
  BuildArgs t37 = [bpftool map dump id $mapID -j]
  DispatchBind t38 = t37 policy=def-then-exec-bind lane=exec
  ApplyBind src=t38 argv=t37 primary=dumpAfterDetach rc=_ guard=true fail=bb11
  Eval t39 = $dumpAfterDetach.stdout |> jq $counterFilter
  BindName afterDetach = t39
  BuildArgs t40 = [print "tracepoint after-detach=${afterDetach} want=${detached}"]
  DispatchCommand argv=t40 policy=def-then-exec-command lane=builtin(print)
  Assert $afterDetach == $detached
  BuildArgs t41 = [bpfman program unload $pid]
  DispatchCommand argv=t41 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $prog
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError
