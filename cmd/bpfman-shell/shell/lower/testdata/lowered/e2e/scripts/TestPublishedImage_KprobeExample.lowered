body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = "quay.io/bpfman-bytecode/go-kprobe-counter"
  BindName image = t1
  BuildArgs t2 = [inspect_published_image $image kprobe_counter]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=exec
  ApplyBind src=t3 argv=t2 primary=published rc=_ guard=true fail=bb1
  Eval t4 = $published
  BindDestructure [inspected manifest] = t4
  Assert $manifest.programs.kprobe_counter == probe
  Assert $manifest.maps.kprobe_stats_map == per_cpu_array
  BuildArgs t5 = [kfunc acquire]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t6 argv=t5 primary=fn rc=_ guard=true fail=bb2
  BuildArgs t7 = [kfunc release $fn]
  RegisterDefer argv=t7 policy=def-then-exec-bind lane=builtin(kfunc)
  BuildArgs t8 = [bpfman program load image --image-url $image --pull-policy Always --programs kprobe:kprobe_counter]
  DispatchBind t9 = t8 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t9 argv=t8 primary=loaded rc=_ guard=true fail=bb3
  Eval t10 = $loaded.programs[0]
  BindName prog = t10
  Eval t11 = $prog.record.program_id
  BindName pid = t11
  BuildArgs t12 = [bpfman program unload $pid]
  RegisterDefer argv=t12 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t13 = [expect_program_load $prog kprobe kprobe kprobe_counter]
  DispatchCommand argv=t13 policy=def-then-exec-command lane=exec
  BuildArgs t14 = [expect_loaded_image_source $prog $image $inspected]
  DispatchCommand argv=t14 policy=def-then-exec-command lane=exec
  BuildArgs t15 = [bpfman link attach kprobe --fn-name $fn.name $prog]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=link rc=_ guard=true fail=bb4
  Eval t17 = $link.record.id
  BindName linkID = t17
  Assert $link.record.kind == kprobe
  Assert $link.record.program_id == $pid
  Assert $link.record.details.fn_name == $fn.name
  Assert not $link.record.details.retprobe
  Assert $link.status.kernel_seen
  Eval t18 = 5
  BindName events = t18
  Eval t19 = $prog.status.maps[0].id
  BindName mapID = t19
  Eval t20 = "fromjson | [.[].formatted.values[].value.counter | tonumber] | add"
  BindName sumFilter = t20
  BuildArgs t21 = [bpftool map dump id $mapID -j]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=exec
  ApplyBind src=t22 argv=t21 primary=dumpBefore rc=_ guard=true fail=bb5
  Eval t23 = $dumpBefore.stdout |> jq $sumFilter
  BindName before = t23
  BuildArgs t24 = [kfunc fire $fn $events]
  DispatchBind t25 = t24 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t25 argv=t24 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t26 = [bpftool map dump id $mapID -j]
  DispatchBind t27 = t26 policy=def-then-exec-bind lane=exec
  ApplyBind src=t27 argv=t26 primary=dumpAfter rc=_ guard=true fail=bb7
  Eval t28 = $dumpAfter.stdout |> jq $sumFilter
  BindName after = t28
  Eval t29 = $after - $before
  BindName delta = t29
  BuildArgs t30 = [print "published kprobe image: events=${delta}"]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=builtin(print)
  Assert $delta >= $events
  BuildArgs t31 = [bpfman link detach $link]
  DispatchCommand argv=t31 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t32 = [sleep 0.1]
  DispatchCommand argv=t32 policy=def-then-exec-command lane=exec
  BuildArgs t33 = [bpftool map dump id $mapID -j]
  DispatchBind t34 = t33 policy=def-then-exec-bind lane=exec
  ApplyBind src=t34 argv=t33 primary=dumpDetached rc=_ guard=true fail=bb8
  Eval t35 = $dumpDetached.stdout |> jq $sumFilter
  BindName detached = t35
  BuildArgs t36 = [kfunc fire $fn $events]
  DispatchBind t37 = t36 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t37 argv=t36 primary=_ rc=_ guard=true fail=bb9
  BuildArgs t38 = [bpftool map dump id $mapID -j]
  DispatchBind t39 = t38 policy=def-then-exec-bind lane=exec
  ApplyBind src=t39 argv=t38 primary=dumpAfterDetach rc=_ guard=true fail=bb10
  Eval t40 = $dumpAfterDetach.stdout |> jq $sumFilter
  BindName afterDetach = t40
  BuildArgs t41 = [print "published kprobe image after-detach=${afterDetach} want=${detached}"]
  DispatchCommand argv=t41 policy=def-then-exec-command lane=builtin(print)
  Assert $afterDetach == $detached
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError
