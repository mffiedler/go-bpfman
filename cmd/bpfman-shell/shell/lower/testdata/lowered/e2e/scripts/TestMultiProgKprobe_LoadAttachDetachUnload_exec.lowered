body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = 5
  BindName n = t1
  Eval t2 = 41
  BindName weight_a = t2
  Eval t3 = 42
  BindName weight_b = t3
  Eval t4 = 43
  BindName weight_c = t4
  BuildArgs t5 = [kfunc acquire]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t6 argv=t5 primary=fn rc=_ guard=true fail=bb1
  BuildArgs t7 = [kfunc release $fn]
  RegisterDefer argv=t7 policy=def-then-exec-bind lane=builtin(kfunc)
  BuildArgs t8 = [exec bpfman program load file --path testdata/bpf/multi_prog_kprobe_kmod_counter.bpf.o --programs kprobe:mkp_a,kprobe:mkp_b,kprobe:mkp_c -g "weight_a=0x${u64le $weight_a}" -g "weight_b=0x${u64le $weight_b}" -g "weight_c=0x${u64le $weight_c}" -o json]
  DispatchBind t9 = t8 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t9 argv=t8 primary=load_r rc=_ guard=true fail=bb2
  Eval t10 = $load_r.stdout |> jq "fromjson"
  BindName loaded = t10
  Eval t11 = [$loaded.programs[0] $loaded.programs[0].record.program_id]
  BindDestructure [prog_a pid_a] = t11
  Eval t12 = [$loaded.programs[1] $loaded.programs[1].record.program_id]
  BindDestructure [prog_b pid_b] = t12
  Eval t13 = [$loaded.programs[2] $loaded.programs[2].record.program_id]
  BindDestructure [prog_c pid_c] = t13
  BuildArgs t14 = [exec bpfman program unload $pid_a]
  RegisterDefer argv=t14 policy=def-then-exec-bind lane=builtin(exec)
  BuildArgs t15 = [exec bpfman program unload $pid_b]
  RegisterDefer argv=t15 policy=def-then-exec-bind lane=builtin(exec)
  BuildArgs t16 = [exec bpfman program unload $pid_c]
  RegisterDefer argv=t16 policy=def-then-exec-bind lane=builtin(exec)
  Eval t17 = $prog_a |> jq "[.status.maps[] | select(.name == \"mkp_a_count\") | .id][0]"
  BindName mapID_a = t17
  Eval t18 = $prog_b |> jq "[.status.maps[] | select(.name == \"mkp_b_count\") | .id][0]"
  BindName mapID_b = t18
  Eval t19 = $prog_c |> jq "[.status.maps[] | select(.name == \"mkp_c_count\") | .id][0]"
  BindName mapID_c = t19
  BuildArgs t20 = [exec bpfman link attach kprobe --fn-name $fn.name $pid_a -o json]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t21 argv=t20 primary=attach_a_r rc=_ guard=true fail=bb3
  BuildArgs t22 = [exec bpfman link attach kprobe --fn-name $fn.name $pid_b -o json]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t23 argv=t22 primary=attach_b_r rc=_ guard=true fail=bb4
  BuildArgs t24 = [exec bpfman link attach kprobe --fn-name $fn.name $pid_c -o json]
  DispatchBind t25 = t24 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t25 argv=t24 primary=attach_c_r rc=_ guard=true fail=bb5
  Eval t26 = $attach_a_r.stdout |> jq "fromjson"
  BindName link_a = t26
  Eval t27 = $attach_b_r.stdout |> jq "fromjson"
  BindName link_b = t27
  Eval t28 = $attach_c_r.stdout |> jq "fromjson"
  BindName link_c = t28
  Eval t29 = $link_a.record.id
  BindName link_a_id = t29
  Eval t30 = $link_b.record.id
  BindName link_b_id = t30
  Eval t31 = $link_c.record.id
  BindName link_c_id = t31
  Eval t32 = "fromjson | .[0].formatted.value | tonumber"
  BindName counter_filter = t32
  BuildArgs t33 = [kfunc fire $fn $n]
  DispatchCommand argv=t33 policy=def-then-exec-command lane=builtin(kfunc)
  BuildArgs t34 = [bpftool map dump id $mapID_a -j]
  DispatchBind t35 = t34 policy=def-then-exec-bind lane=exec
  ApplyBind src=t35 argv=t34 primary=dump_a rc=_ guard=true fail=bb6
  BuildArgs t36 = [bpftool map dump id $mapID_b -j]
  DispatchBind t37 = t36 policy=def-then-exec-bind lane=exec
  ApplyBind src=t37 argv=t36 primary=dump_b rc=_ guard=true fail=bb7
  BuildArgs t38 = [bpftool map dump id $mapID_c -j]
  DispatchBind t39 = t38 policy=def-then-exec-bind lane=exec
  ApplyBind src=t39 argv=t38 primary=dump_c rc=_ guard=true fail=bb8
  Eval t40 = $dump_a.stdout |> jq $counter_filter
  BindName count_a = t40
  Eval t41 = $dump_b.stdout |> jq $counter_filter
  BindName count_b = t41
  Eval t42 = $dump_c.stdout |> jq $counter_filter
  BindName count_c = t42
  Eval t43 = $n * $weight_a
  BindName want_a = t43
  Eval t44 = $n * $weight_b
  BindName want_b = t44
  Eval t45 = $n * $weight_c
  BindName want_c = t45
  BuildArgs t46 = [print "a: got=${count_a} want=${want_a}"]
  DispatchCommand argv=t46 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t47 = [print "b: got=${count_b} want=${want_b}"]
  DispatchCommand argv=t47 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t48 = [print "c: got=${count_c} want=${want_c}"]
  DispatchCommand argv=t48 policy=def-then-exec-command lane=builtin(print)
  Assert $count_a == $want_a
  Assert $count_b == $want_b
  Assert $count_c == $want_c
  BuildArgs t49 = [exec bpfman link detach $link_c_id]
  DispatchCommand argv=t49 policy=def-then-exec-command lane=builtin(exec)
  BuildArgs t50 = [exec bpfman link detach $link_b_id]
  DispatchCommand argv=t50 policy=def-then-exec-command lane=builtin(exec)
  BuildArgs t51 = [exec bpfman link detach $link_a_id]
  DispatchCommand argv=t51 policy=def-then-exec-command lane=builtin(exec)
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError
