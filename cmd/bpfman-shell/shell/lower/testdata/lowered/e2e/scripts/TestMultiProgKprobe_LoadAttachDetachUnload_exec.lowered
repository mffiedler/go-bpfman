body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = 5
  BindName n = t1
  Eval t2 = 3
  BindName waves = t2
  Eval t3 = 41
  BindName weight_a = t3
  Eval t4 = 42
  BindName weight_b = t4
  Eval t5 = 43
  BindName weight_c = t5
  BuildArgs t6 = [tempdir bpfman-shell-mkp-exec]
  DispatchBind t7 = t6 policy=def-then-exec-bind lane=builtin(tempdir)
  ApplyBind src=t7 argv=t6 primary=workdir rc=_ guard=true fail=bb1
  BuildArgs t8 = [rm -rf $workdir.path]
  RegisterDefer argv=t8 policy=def-then-exec-bind lane=exec
  Eval t9 = "${workdir.path}/sentinel"
  BindName sentinel = t9
  Eval t10 = "${workdir.path}/ack"
  BindName ack = t10
  BuildArgs t11 = [fire unlinkat $sentinel $ack --count $n --waves $waves]
  DispatchBind t12 = t11 policy=def-then-exec-bind lane=builtin(fire)
  ApplyBind src=t12 argv=t11 primary=work rc=_ guard=true fail=bb2
  BuildArgs t13 = [kill --signal=KILL $work]
  RegisterDefer argv=t13 policy=def-then-exec-bind lane=builtin(kill)
  BuildArgs t14 = [exec bpfman program load file --path testdata/bpf/multi_prog_kprobe_counter.bpf.o --programs kprobe:mkp_a,kprobe:mkp_b,kprobe:mkp_c -g "expected_pid=0x${u32le $work.pid}" -g "weight_a=0x${u64le $weight_a}" -g "weight_b=0x${u64le $weight_b}" -g "weight_c=0x${u64le $weight_c}" -o json]
  DispatchBind t15 = t14 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t15 argv=t14 primary=load_r rc=_ guard=true fail=bb3
  Eval t16 = $load_r.stdout |> jq "fromjson"
  BindName loaded = t16
  Eval t17 = [$loaded.programs[0] $loaded.programs[0].record.program_id]
  BindDestructure [prog_a pid_a] = t17
  Eval t18 = [$loaded.programs[1] $loaded.programs[1].record.program_id]
  BindDestructure [prog_b pid_b] = t18
  Eval t19 = [$loaded.programs[2] $loaded.programs[2].record.program_id]
  BindDestructure [prog_c pid_c] = t19
  BuildArgs t20 = [exec bpfman program unload $pid_a]
  RegisterDefer argv=t20 policy=def-then-exec-bind lane=builtin(exec)
  BuildArgs t21 = [exec bpfman program unload $pid_b]
  RegisterDefer argv=t21 policy=def-then-exec-bind lane=builtin(exec)
  BuildArgs t22 = [exec bpfman program unload $pid_c]
  RegisterDefer argv=t22 policy=def-then-exec-bind lane=builtin(exec)
  Eval t23 = $prog_a |> jq "[.status.maps[] | select(.name == \"mkp_a_count\") | .id][0]"
  BindName mapID_a = t23
  Eval t24 = $prog_b |> jq "[.status.maps[] | select(.name == \"mkp_b_count\") | .id][0]"
  BindName mapID_b = t24
  Eval t25 = $prog_c |> jq "[.status.maps[] | select(.name == \"mkp_c_count\") | .id][0]"
  BindName mapID_c = t25
  BuildArgs t26 = [exec bpfman link attach kprobe --fn-name do_unlinkat $pid_a -o json]
  DispatchBind t27 = t26 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t27 argv=t26 primary=attach_a_r rc=_ guard=true fail=bb4
  BuildArgs t28 = [exec bpfman link attach kprobe --fn-name do_unlinkat $pid_b -o json]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t29 argv=t28 primary=attach_b_r rc=_ guard=true fail=bb5
  BuildArgs t30 = [exec bpfman link attach kprobe --fn-name do_unlinkat $pid_c -o json]
  DispatchBind t31 = t30 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t31 argv=t30 primary=attach_c_r rc=_ guard=true fail=bb6
  Eval t32 = $attach_a_r.stdout |> jq "fromjson"
  BindName link_a = t32
  Eval t33 = $attach_b_r.stdout |> jq "fromjson"
  BindName link_b = t33
  Eval t34 = $attach_c_r.stdout |> jq "fromjson"
  BindName link_c = t34
  Eval t35 = $link_a.record.id
  BindName link_a_id = t35
  Eval t36 = $link_b.record.id
  BindName link_b_id = t36
  Eval t37 = $link_c.record.id
  BindName link_c_id = t37
  Eval t38 = "fromjson | .[0].formatted.value | tonumber"
  BindName counter_filter = t38
  BuildArgs t39 = [touch "${sentinel}.1"]
  DispatchBind t40 = t39 policy=def-then-exec-bind lane=exec
  ApplyBind src=t40 argv=t39 primary=_ rc=_ guard=true fail=bb7
  BeginPoll timeout=5s every=100ms attempt=bb8 timeout=bb9 success=bb10

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  EnterFrame kind=poll-attempt
  EnterDeferScope kind=poll-attempt
  BuildArgs t41 = [await_wave_completion $ack 1]
  DispatchCommand argv=t41 policy=def-then-exec-command lane=exec
  RunDefers policy=attempt-fatal
  ExitFrame
  Jump bb10

bb9:
  PropagateError

bb10:
  BuildArgs t42 = [exec bpfman link detach $link_c_id]
  DispatchCommand argv=t42 policy=def-then-exec-command lane=builtin(exec)
  BuildArgs t43 = [sleep 0.1]
  DispatchCommand argv=t43 policy=def-then-exec-command lane=exec
  BuildArgs t44 = [touch "${sentinel}.2"]
  DispatchBind t45 = t44 policy=def-then-exec-bind lane=exec
  ApplyBind src=t45 argv=t44 primary=_ rc=_ guard=true fail=bb11
  BeginPoll timeout=5s every=100ms attempt=bb12 timeout=bb13 success=bb14

bb11:
  RunDefers policy=program
  PropagateError

bb12:
  EnterFrame kind=poll-attempt
  EnterDeferScope kind=poll-attempt
  BuildArgs t46 = [await_wave_completion $ack 2]
  DispatchCommand argv=t46 policy=def-then-exec-command lane=exec
  RunDefers policy=attempt-fatal
  ExitFrame
  Jump bb14

bb13:
  PropagateError

bb14:
  BuildArgs t47 = [exec bpfman link detach $link_b_id]
  DispatchCommand argv=t47 policy=def-then-exec-command lane=builtin(exec)
  BuildArgs t48 = [sleep 0.1]
  DispatchCommand argv=t48 policy=def-then-exec-command lane=exec
  BuildArgs t49 = [touch "${sentinel}.3"]
  DispatchBind t50 = t49 policy=def-then-exec-bind lane=exec
  ApplyBind src=t50 argv=t49 primary=_ rc=_ guard=true fail=bb15
  BeginPoll timeout=5s every=100ms attempt=bb16 timeout=bb17 success=bb18

bb15:
  RunDefers policy=program
  PropagateError

bb16:
  EnterFrame kind=poll-attempt
  EnterDeferScope kind=poll-attempt
  BuildArgs t51 = [await_wave_completion $ack 3]
  DispatchCommand argv=t51 policy=def-then-exec-command lane=exec
  RunDefers policy=attempt-fatal
  ExitFrame
  Jump bb18

bb17:
  PropagateError

bb18:
  BuildArgs t52 = [wait $work]
  DispatchBind t53 = t52 policy=def-then-exec-bind lane=builtin(wait)
  ApplyBind src=t53 argv=t52 primary=_ rc=_ guard=true fail=bb19
  BuildArgs t54 = [bpftool map dump id $mapID_a -j]
  DispatchBind t55 = t54 policy=def-then-exec-bind lane=exec
  ApplyBind src=t55 argv=t54 primary=dump_a rc=_ guard=true fail=bb20
  BuildArgs t56 = [bpftool map dump id $mapID_b -j]
  DispatchBind t57 = t56 policy=def-then-exec-bind lane=exec
  ApplyBind src=t57 argv=t56 primary=dump_b rc=_ guard=true fail=bb21
  BuildArgs t58 = [bpftool map dump id $mapID_c -j]
  DispatchBind t59 = t58 policy=def-then-exec-bind lane=exec
  ApplyBind src=t59 argv=t58 primary=dump_c rc=_ guard=true fail=bb22
  Eval t60 = $dump_a.stdout |> jq $counter_filter
  BindName count_a = t60
  Eval t61 = $dump_b.stdout |> jq $counter_filter
  BindName count_b = t61
  Eval t62 = $dump_c.stdout |> jq $counter_filter
  BindName count_c = t62
  Eval t63 = (3 * $n) * $weight_a
  BindName want_a = t63
  Eval t64 = (2 * $n) * $weight_b
  BindName want_b = t64
  Eval t65 = (1 * $n) * $weight_c
  BindName want_c = t65
  BuildArgs t66 = [print "a: got=${count_a} want=${want_a}"]
  DispatchCommand argv=t66 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t67 = [print "b: got=${count_b} want=${want_b}"]
  DispatchCommand argv=t67 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t68 = [print "c: got=${count_c} want=${want_c}"]
  DispatchCommand argv=t68 policy=def-then-exec-command lane=builtin(print)
  Assert $count_a == $want_a
  Assert $count_b == $want_b
  Assert $count_c == $want_c
  BuildArgs t69 = [exec bpfman link detach $link_a_id]
  DispatchCommand argv=t69 policy=def-then-exec-command lane=builtin(exec)
  RunDefers policy=program
  Stop

bb19:
  RunDefers policy=program
  PropagateError

bb20:
  RunDefers policy=program
  PropagateError

bb21:
  RunDefers policy=program
  PropagateError

bb22:
  RunDefers policy=program
  PropagateError
