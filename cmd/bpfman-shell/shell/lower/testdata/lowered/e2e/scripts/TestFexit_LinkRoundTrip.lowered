body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Require path-exists /sys/kernel/btf/vmlinux
  BuildArgs t1 = [bpfman program load file --path testdata/bpf/fentry_counter.bpf.o --programs fexit:test_fexit:vfs_read]
  DispatchBind t2 = t1 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t2 argv=t1 primary=loaded rc=_ guard=true fail=bb1
  Eval t3 = $loaded.programs[0]
  BindName prog = t3
  Eval t4 = $prog.record.program_id
  BindName pid = t4
  BuildArgs t5 = [bpfman program unload $pid]
  RegisterDefer argv=t5 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t6 = [bpfman link attach fexit $prog]
  DispatchBind t7 = t6 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t7 argv=t6 primary=link rc=_ guard=true fail=bb2
  Eval t8 = $link.record.id
  BindName linkID = t8
  Assert $link.record.kind == fexit
  Assert $link.record.program_id == $pid
  Assert $link.record.details.fn_name == vfs_read
  Assert $link.status.kernel_seen
  BuildArgs t9 = [bpfman link get $linkID]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t10 argv=t9 primary=gotLink rc=_ guard=true fail=bb3
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == fexit
  Assert $gotLink.record.program_id == $pid
  Assert $gotLink.record.details.fn_name == vfs_read
  BuildArgs t11 = [bpfman link list -o json]
  DispatchBind t12 = t11 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t12 argv=t11 primary=listed rc=_ guard=true fail=bb4
  Eval t13 = $listed |> jq ".links[] | select(.id == ${linkID})"
  BindName ourLink = t13
  Require not null ourLink
  Assert $ourLink.id == $linkID
  Assert $ourLink.kind == fexit
  BuildArgs t14 = [bpfman link detach $link]
  DispatchCommand argv=t14 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t15 = [bpfman link list -o json]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=listedAfter rc=_ guard=true fail=bb5
  BuildArgs t17 = [assert_link_absent $listedAfter $linkID]
  DispatchCommand argv=t17 policy=def-then-exec-command lane=exec
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError
