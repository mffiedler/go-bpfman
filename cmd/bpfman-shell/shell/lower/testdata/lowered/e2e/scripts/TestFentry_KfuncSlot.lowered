body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = 5
  BindName events = t1
  Eval t2 = 1
  BindName weight = t2
  Eval t3 = $events * $weight
  BindName want = t3
  BuildArgs t4 = [kfunc acquire]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t5 argv=t4 primary=fn rc=_ guard=true fail=bb1
  BuildArgs t6 = [kfunc release $fn]
  RegisterDefer argv=t6 policy=def-then-exec-bind lane=builtin(kfunc)
  BuildArgs t7 = [bpfman program load file --path testdata/bpf/fentry_kmod_exact.bpf.o --programs "fentry:test_fentry:${fn.name}" -g "weight=0x${u64le $weight}"]
  DispatchBind t8 = t7 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t8 argv=t7 primary=loaded rc=_ guard=true fail=bb2
  Eval t9 = $loaded.programs[0]
  BindName prog = t9
  Eval t10 = $prog.record.program_id
  BindName pid = t10
  BuildArgs t11 = [expect_program_load $prog fentry tracing test_fentry]
  DispatchCommand argv=t11 policy=def-then-exec-command lane=exec
  BuildArgs t12 = [bpfman link attach fentry $prog]
  DispatchBind t13 = t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t13 argv=t12 primary=link rc=_ guard=true fail=bb3
  Eval t14 = $link.record.id
  BindName linkID = t14
  Assert $link.record.kind == fentry
  Assert $link.record.program_id == $pid
  Assert $link.record.details.fn_name == $fn.name
  Assert $link.status.kernel_seen
  BuildArgs t15 = [bpfman link get $linkID]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=gotLink rc=_ guard=true fail=bb4
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == fentry
  Assert $gotLink.record.program_id == $pid
  Assert $gotLink.record.details.fn_name == $fn.name
  BuildArgs t17 = [bpfman link list -o json]
  DispatchBind t18 = t17 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t18 argv=t17 primary=listed rc=_ guard=true fail=bb5
  Eval t19 = $listed |> jq ".links[] | select(.id == ${linkID})"
  BindName ourLink = t19
  Require not null ourLink
  Assert $ourLink.id == $linkID
  Assert $ourLink.kind == fentry
  BuildArgs t20 = [kfunc fire $fn $events]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t21 argv=t20 primary=fired rc=_ guard=true fail=bb6
  Assert $fired.ok
  Eval t22 = $prog.status.maps[0].id
  BindName mapID = t22
  Eval t23 = "fromjson | .[0].formatted.value | tonumber"
  BindName counterFilter = t23
  BuildArgs t24 = [bpftool map dump id $mapID -j]
  DispatchBind t25 = t24 policy=def-then-exec-bind lane=exec
  ApplyBind src=t25 argv=t24 primary=dump rc=_ guard=true fail=bb7
  Eval t26 = $dump.stdout |> jq $counterFilter
  BindName got = t26
  BuildArgs t27 = [print "kfunc=${fn.name} got=${got} want=${want}"]
  DispatchCommand argv=t27 policy=def-then-exec-command lane=builtin(print)
  Assert $got == $want
  BuildArgs t28 = [bpfman link detach $link]
  DispatchCommand argv=t28 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t29 = [bpfman link list -o json]
  DispatchBind t30 = t29 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t30 argv=t29 primary=listedAfter rc=_ guard=true fail=bb8
  BuildArgs t31 = [assert_link_absent $listedAfter $linkID]
  DispatchCommand argv=t31 policy=def-then-exec-command lane=exec
  BuildArgs t32 = [bpfman program unload $pid]
  DispatchCommand argv=t32 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $prog
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError
