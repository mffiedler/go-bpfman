body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [exec bpfman image generate-build-args linux/amd64=testdata/bpf/xdp_pass.bpf.o linux/arm64=testdata/bpf/xdp_pass.bpf.o -o json]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t1 argv=t0 primary=rc rc=_ guard=false
  Assert $rc.ok
  Eval t2 = $rc.stdout |> jq "fromjson | .platforms | join(\",\")"
  BindName platforms = t2
  Assert $platforms == "linux/amd64,linux/arm64"
  Eval t3 = $rc.stdout |> jq "fromjson | .build_args.BC_AMD64_EL"
  BindName amd64 = t3
  Assert $amd64 == "testdata/bpf/xdp_pass.bpf.o"
  Eval t4 = $rc.stdout |> jq "fromjson | .build_args.BC_ARM64_EL"
  BindName arm64 = t4
  Assert $arm64 == "testdata/bpf/xdp_pass.bpf.o"
  Eval t5 = $rc.stdout |> jq "fromjson | .programs.pass"
  BindName prog_type = t5
  Assert $prog_type == xdp
  Eval t6 = $rc.stdout |> jq "fromjson | .maps.xdp_pass_stats_map"
  BindName map_type = t6
  Assert $map_type == per_cpu_array
  RunDefers policy=program
  Stop
