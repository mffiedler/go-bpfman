body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = "quay.io/bpfman-bytecode/go-tracepoint-counter"
  BindName image = t1
  BuildArgs t2 = [inspect_published_image $image tracepoint_kill_recorder]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=exec
  ApplyBind src=t3 argv=t2 primary=published rc=_ guard=true fail=bb1
  Assert $published.manifest.programs.tracepoint_kill_recorder == tracepoint
  Assert $published.manifest.maps.tracepoint_stats_map == per_cpu_array
  BuildArgs t4 = [bpfman program load image --image-url $image --pull-policy Always --programs tracepoint:tracepoint_kill_recorder]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t5 argv=t4 primary=loaded rc=_ guard=true fail=bb2
  Eval t6 = $loaded.programs[0]
  BindName prog = t6
  Eval t7 = $prog.record.program_id
  BindName pid = t7
  BuildArgs t8 = [bpfman program unload $pid]
  RegisterDefer argv=t8 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t9 = [expect_program_load $prog tracepoint tracepoint tracepoint_kill_recorder]
  DispatchCommand argv=t9 policy=def-then-exec-command lane=exec
  BuildArgs t10 = [expect_loaded_image_source $prog $image $published.inspected]
  DispatchCommand argv=t10 policy=def-then-exec-command lane=exec
  BuildArgs t11 = [bpfman link attach tracepoint $prog syscalls/sys_enter_kill]
  DispatchBind t12 = t11 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t12 argv=t11 primary=link rc=_ guard=true fail=bb3
  Eval t13 = $link.record.id
  BindName linkID = t13
  Assert $link.record.kind == tracepoint
  Assert $link.record.program_id == $pid
  Assert $link.record.details.group == syscalls
  Assert $link.record.details.name == sys_enter_kill
  Assert $link.status.kernel_seen
  Eval t14 = 5
  BindName events = t14
  Eval t15 = $prog.status.maps[0].id
  BindName mapID = t15
  Eval t16 = "fromjson | [.[].formatted.values[].value.calls | tonumber] | add"
  BindName sumFilter = t16
  BuildArgs t17 = [bpftool map dump id $mapID -j]
  DispatchBind t18 = t17 policy=def-then-exec-bind lane=exec
  ApplyBind src=t18 argv=t17 primary=dumpBefore rc=_ guard=true fail=bb4
  Eval t19 = $dumpBefore.stdout |> jq $sumFilter
  BindName before = t19
  BuildArgs t20 = [exec sh -c "i=0; trap \"\" USR1; while [ $i -lt \"$1\" ]; do kill -USR1 $$; i=$((i + 1)); done" sh $events]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t21 argv=t20 primary=_ rc=_ guard=true fail=bb5
  BuildArgs t22 = [bpftool map dump id $mapID -j]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=exec
  ApplyBind src=t23 argv=t22 primary=dumpAfter rc=_ guard=true fail=bb6
  Eval t24 = $dumpAfter.stdout |> jq $sumFilter
  BindName after = t24
  Eval t25 = $after - $before
  BindName delta = t25
  BuildArgs t26 = [print "published tracepoint image: events=${delta}"]
  DispatchCommand argv=t26 policy=def-then-exec-command lane=builtin(print)
  Assert $delta >= $events
  BuildArgs t27 = [bpfman link detach $link]
  DispatchCommand argv=t27 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t28 = [sleep 0.1]
  DispatchCommand argv=t28 policy=def-then-exec-command lane=exec
  BuildArgs t29 = [bpftool map dump id $mapID -j]
  DispatchBind t30 = t29 policy=def-then-exec-bind lane=exec
  ApplyBind src=t30 argv=t29 primary=dumpDetached rc=_ guard=true fail=bb7
  Eval t31 = $dumpDetached.stdout |> jq $sumFilter
  BindName detached = t31
  BuildArgs t32 = [exec sh -c "i=0; trap \"\" USR1; while [ $i -lt \"$1\" ]; do kill -USR1 $$; i=$((i + 1)); done" sh $events]
  DispatchBind t33 = t32 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t33 argv=t32 primary=_ rc=_ guard=true fail=bb8
  BuildArgs t34 = [bpftool map dump id $mapID -j]
  DispatchBind t35 = t34 policy=def-then-exec-bind lane=exec
  ApplyBind src=t35 argv=t34 primary=dumpAfterDetach rc=_ guard=true fail=bb9
  Eval t36 = $dumpAfterDetach.stdout |> jq $sumFilter
  BindName afterDetach = t36
  BuildArgs t37 = [print "published tracepoint image after-detach=${afterDetach} want=${detached}"]
  DispatchCommand argv=t37 policy=def-then-exec-command lane=builtin(print)
  Assert $afterDetach == $detached
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError
