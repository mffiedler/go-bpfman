body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  BuildArgs t1 = [net veth-pair]
  DispatchBind t2 = t1 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t2 argv=t1 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t3 = [net release $pair]
  RegisterDefer argv=t3 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t4 = [bpfman program load file --path testdata/bpf/xdp_pass.bpf.o --programs xdp:pass]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t5 argv=t4 primary=loaded rc=_ guard=true fail=bb2
  Eval t6 = $loaded.programs[0]
  BindName prog = t6
  Eval t7 = $prog.record.program_id
  BindName pid = t7
  BuildArgs t8 = [bpfman program unload $pid]
  RegisterDefer argv=t8 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t9 = [bpfman link attach xdp --iface $pair.host_link $prog]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t10 argv=t9 primary=link rc=_ guard=true fail=bb3
  Eval t11 = $link.record.id
  BindName linkID = t11
  Assert $link.record.kind == xdp
  Assert $link.record.program_id == $pid
  Assert $link.record.details.interface == $pair.host_link
  Assert $link.record.details.dispatcher_id > 0
  Assert $link.record.details.revision > 0
  Assert $link.status.kernel_seen
  BuildArgs t12 = [bpfman link get $linkID]
  DispatchBind t13 = t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t13 argv=t12 primary=gotLink rc=_ guard=true fail=bb4
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == xdp
  Assert $gotLink.record.program_id == $pid
  Assert $gotLink.record.details.interface == $pair.host_link
  Assert $gotLink.record.details.dispatcher_id == $link.record.details.dispatcher_id
  BuildArgs t14 = [bpfman link list -o json]
  DispatchBind t15 = t14 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t15 argv=t14 primary=listed rc=_ guard=true fail=bb5
  Eval t16 = $listed |> jq ".links[] | select(.id == ${linkID})"
  BindName ourLink = t16
  Require not null ourLink
  Assert $ourLink.id == $linkID
  Assert $ourLink.kind == xdp
  Eval t17 = $prog.status.maps[0].id
  BindName mapID = t17
  Eval t18 = "fromjson | [.[0].formatted.values[].value | tonumber] | add"
  BindName sumFilter = t18
  BuildArgs t19 = [bpftool map dump id $mapID -j]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=exec
  ApplyBind src=t20 argv=t19 primary=dumpBefore rc=_ guard=true fail=bb6
  Eval t21 = $dumpBefore.stdout |> jq $sumFilter
  BindName before = t21
  BuildArgs t22 = [net exec $pair ping -c 5 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t23 argv=t22 primary=_ rc=_ guard=true fail=bb7
  BuildArgs t24 = [bpftool map dump id $mapID -j]
  DispatchBind t25 = t24 policy=def-then-exec-bind lane=exec
  ApplyBind src=t25 argv=t24 primary=dumpAfter rc=_ guard=true fail=bb8
  Eval t26 = $dumpAfter.stdout |> jq $sumFilter
  BindName after = t26
  Eval t27 = $after - $before
  BindName delta = t27
  BuildArgs t28 = [print "xdp count: before=${before} after=${after} delta=${delta}"]
  DispatchCommand argv=t28 policy=def-then-exec-command lane=builtin(print)
  Assert $delta >= 5
  BuildArgs t29 = [bpfman link detach $link]
  DispatchCommand argv=t29 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t30 = [bpfman link list -o json]
  DispatchBind t31 = t30 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t31 argv=t30 primary=listedAfter rc=_ guard=true fail=bb9
  BuildArgs t32 = [assert_link_absent $listedAfter $linkID]
  DispatchCommand argv=t32 policy=def-then-exec-command lane=exec
  BuildArgs t33 = [sleep 0.1]
  DispatchCommand argv=t33 policy=def-then-exec-command lane=exec
  BuildArgs t34 = [bpftool map dump id $mapID -j]
  DispatchBind t35 = t34 policy=def-then-exec-bind lane=exec
  ApplyBind src=t35 argv=t34 primary=dumpDetached rc=_ guard=true fail=bb10
  Eval t36 = $dumpDetached.stdout |> jq $sumFilter
  BindName detached = t36
  BuildArgs t37 = [net exec $pair ping -c 5 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t38 = t37 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t38 argv=t37 primary=_ rc=_ guard=true fail=bb11
  BuildArgs t39 = [bpftool map dump id $mapID -j]
  DispatchBind t40 = t39 policy=def-then-exec-bind lane=exec
  ApplyBind src=t40 argv=t39 primary=dumpAfterDetach rc=_ guard=true fail=bb12
  Eval t41 = $dumpAfterDetach.stdout |> jq $sumFilter
  BindName afterDetach = t41
  BuildArgs t42 = [print "xdp after-detach=${afterDetach} want=${detached}"]
  DispatchCommand argv=t42 policy=def-then-exec-command lane=builtin(print)
  Assert $afterDetach == $detached
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError

bb12:
  RunDefers policy=program
  PropagateError
