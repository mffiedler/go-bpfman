body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  BuildArgs t1 = [net veth-pair]
  DispatchBind t2 = t1 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t2 argv=t1 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t3 = [net release $pair]
  RegisterDefer argv=t3 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t4 = [bpfman program load file --path testdata/bpf/xdp_pass.bpf.o --programs xdp:pass]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t5 argv=t4 primary=loaded rc=_ guard=true fail=bb2
  Eval t6 = $loaded.programs[0]
  BindName prog = t6
  Eval t7 = $prog.record.program_id
  BindName pid = t7
  BuildArgs t8 = [bpfman program unload $pid]
  RegisterDefer argv=t8 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t9 = [bpfman link attach xdp --iface $pair.host_link $prog]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t10 argv=t9 primary=link rc=_ guard=true fail=bb3
  Eval t11 = $link.record.id
  BindName linkID = t11
  Assert $link.record.kind == xdp
  Assert $link.record.program_id == $pid
  Assert $link.record.details.interface == $pair.host_link
  Assert $link.record.details.dispatcher_id > 0
  Assert $link.record.details.revision > 0
  Assert $link.status.kernel_seen
  BuildArgs t12 = [bpfman link get $linkID]
  DispatchBind t13 = t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t13 argv=t12 primary=gotLink rc=_ guard=true fail=bb4
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == xdp
  Assert $gotLink.record.program_id == $pid
  Assert $gotLink.record.details.interface == $pair.host_link
  Assert $gotLink.record.details.dispatcher_id == $link.record.details.dispatcher_id
  BuildArgs t14 = [bpfman link list -o json]
  DispatchBind t15 = t14 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t15 argv=t14 primary=listed rc=_ guard=true fail=bb5
  Eval t16 = $listed |> jq ".links[] | select(.id == ${linkID})"
  BindName ourLink = t16
  Require not null ourLink
  Assert $ourLink.id == $linkID
  Assert $ourLink.kind == xdp
  BuildArgs t17 = [bpfman link detach $link]
  DispatchCommand argv=t17 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t18 = [bpfman link list -o json]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t19 argv=t18 primary=listedAfter rc=_ guard=true fail=bb6
  BuildArgs t20 = [assert_link_absent $listedAfter $linkID]
  DispatchCommand argv=t20 policy=def-then-exec-command lane=exec
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError
