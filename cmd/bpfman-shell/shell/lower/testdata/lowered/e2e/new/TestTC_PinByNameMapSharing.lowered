body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [bpfman program load file --path testdata/bpf/tc_counter_pinned.bpf.o --programs tc:stats]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded_a rc=_ guard=true fail=bb2
  BuildArgs t5 = [bpfman program load file --path testdata/bpf/tc_counter_pinned.bpf.o --programs tc:stats]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t6 argv=t5 primary=loaded_b rc=_ guard=true fail=bb3
  Eval t7 = $loaded_a.programs[0]
  BindName prog_a = t7
  Eval t8 = $loaded_b.programs[0]
  BindName prog_b = t8
  Eval t9 = $prog_a.record.program_id
  BindName pid_a = t9
  Eval t10 = $prog_b.record.program_id
  BindName pid_b = t10
  BuildArgs t11 = [bpfman program unload $prog_a]
  RegisterDefer argv=t11 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t12 = [bpfman program unload $prog_b]
  RegisterDefer argv=t12 policy=def-then-exec-bind lane=builtin(bpfman)
  Assert $pid_a != $pid_b
  Eval t13 = $prog_a |> jq "[.status.maps[] | select(.name == \"tc_stats_map\") | .id][0]"
  BindName mapID_a = t13
  Eval t14 = $prog_b |> jq "[.status.maps[] | select(.name == \"tc_stats_map\") | .id][0]"
  BindName mapID_b = t14
  Assert $mapID_a == $mapID_b
  BuildArgs t15 = [bpfman link attach tc -i $pair.host_link -d ingress -p 100 --proceed-on ok,pipe,dispatcher_return $prog_a]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=l_a rc=_ guard=true fail=bb4
  BuildArgs t17 = [bpfman link attach tc -i $pair.host_link -d ingress -p 200 --proceed-on ok,pipe,dispatcher_return $prog_b]
  DispatchBind t18 = t17 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t18 argv=t17 primary=l_b rc=_ guard=true fail=bb5
  Assert path-exists /run/bpfman/fs/shared/tc_stats_map
  BuildArgs t19 = [net exec $pair ping -c 20 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t20 argv=t19 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t21 = [bpfman link detach $l_a]
  DispatchCommand argv=t21 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t22 = [bpfman link detach $l_b]
  DispatchCommand argv=t22 policy=def-then-exec-command lane=builtin(bpfman)
  Eval t23 = "fromjson | [.[].formatted.values[].value.rx_packets | tonumber] | add"
  BindName sumFilter = t23
  BuildArgs t24 = [bpftool map dump id $mapID_a -j]
  DispatchBind t25 = t24 policy=def-then-exec-bind lane=exec
  ApplyBind src=t25 argv=t24 primary=dump_a rc=_ guard=true fail=bb7
  BuildArgs t26 = [bpftool map dump id $mapID_b -j]
  DispatchBind t27 = t26 policy=def-then-exec-bind lane=exec
  ApplyBind src=t27 argv=t26 primary=dump_b rc=_ guard=true fail=bb8
  Eval t28 = $dump_a.stdout |> jq $sumFilter
  BindName count_a = t28
  Eval t29 = $dump_b.stdout |> jq $sumFilter
  BindName count_b = t29
  Assert $count_a > 0
  Assert $count_a == $count_b
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError
