body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded_existing rc=_ guard=true fail=bb2
  BuildArgs t5 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t6 argv=t5 primary=loaded_incoming rc=_ guard=true fail=bb3
  Eval t7 = $loaded_existing.programs[0]
  BindName prog_existing = t7
  Eval t8 = $loaded_incoming.programs[0]
  BindName prog_incoming = t8
  Eval t9 = $prog_existing.record.program_id
  BindName pid_existing = t9
  Eval t10 = $prog_incoming.record.program_id
  BindName pid_incoming = t10
  BuildArgs t11 = [bpfman program unload $prog_existing]
  RegisterDefer argv=t11 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t12 = [bpfman program unload $prog_incoming]
  RegisterDefer argv=t12 policy=def-then-exec-bind lane=builtin(bpfman)
  Eval t13 = $prog_existing |> jq "[.status.maps[] | select(.name == \"tc_stats_map\") | .id][0]"
  BindName mapID_existing = t13
  Eval t14 = $prog_incoming |> jq "[.status.maps[] | select(.name == \"tc_stats_map\") | .id][0]"
  BindName mapID_incoming = t14
  BuildArgs t15 = [bpfman link attach tc -i $pair.host_link -d ingress -p 55 $prog_existing]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=l_existing rc=_ guard=true fail=bb4
  BuildArgs t17 = [bpfman link attach tc -i $pair.host_link -d ingress -p 55 $prog_incoming]
  DispatchBind t18 = t17 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t18 argv=t17 primary=l_incoming rc=_ guard=true fail=bb5
  BuildArgs t19 = [bpfman link detach $l_existing]
  RegisterDefer argv=t19 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t20 = [bpfman link detach $l_incoming]
  RegisterDefer argv=t20 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t21 = [bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t22 argv=t21 primary=snap rc=_ guard=true fail=bb6
  Assert ($snap |> jq ".members | length") == 2
  Eval t23 = $snap |> jq ".members[] | select(.program_id == ${pid_incoming}) | .position"
  BindName pos_incoming = t23
  Eval t24 = $snap |> jq ".members[] | select(.program_id == ${pid_existing}) | .position"
  BindName pos_existing = t24
  Assert $pos_incoming == 0
  Assert $pos_existing == 1
  BuildArgs t25 = [net exec $pair ping -c 20 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t26 = t25 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t26 argv=t25 primary=_ rc=_ guard=true fail=bb7
  Eval t27 = "fromjson | [.[].formatted.values[].value.rx_packets | tonumber] | add"
  BindName sumFilter = t27
  BuildArgs t28 = [bpftool map dump id $mapID_incoming -j]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=exec
  ApplyBind src=t29 argv=t28 primary=dump_incoming rc=_ guard=true fail=bb8
  Eval t30 = $dump_incoming.stdout |> jq $sumFilter
  BindName count_incoming = t30
  Assert $count_incoming > 0
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError
