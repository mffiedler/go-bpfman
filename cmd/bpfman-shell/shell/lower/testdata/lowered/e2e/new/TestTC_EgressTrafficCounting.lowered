body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded_a rc=_ guard=true fail=bb2
  BuildArgs t5 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t6 argv=t5 primary=loaded_b rc=_ guard=true fail=bb3
  BuildArgs t7 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t8 = t7 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t8 argv=t7 primary=loaded_c rc=_ guard=true fail=bb4
  Eval t9 = $loaded_a.programs[0]
  BindName prog_a = t9
  Eval t10 = $loaded_b.programs[0]
  BindName prog_b = t10
  Eval t11 = $loaded_c.programs[0]
  BindName prog_c = t11
  BuildArgs t12 = [bpfman program unload $prog_a]
  RegisterDefer argv=t12 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t13 = [bpfman program unload $prog_b]
  RegisterDefer argv=t13 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t14 = [bpfman program unload $prog_c]
  RegisterDefer argv=t14 policy=def-then-exec-bind lane=builtin(bpfman)
  Eval t15 = $prog_a |> jq "[.status.maps[] | select(.name == \"tc_stats_map\") | .id][0]"
  BindName mapID_a = t15
  Eval t16 = $prog_b |> jq "[.status.maps[] | select(.name == \"tc_stats_map\") | .id][0]"
  BindName mapID_b = t16
  Eval t17 = $prog_c |> jq "[.status.maps[] | select(.name == \"tc_stats_map\") | .id][0]"
  BindName mapID_c = t17
  BuildArgs t18 = [bpfman link attach tc -i $pair.host_link -d egress -p 100 --proceed-on ok,pipe,dispatcher_return $prog_a]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t19 argv=t18 primary=l_a rc=_ guard=true fail=bb5
  BuildArgs t20 = [bpfman link attach tc -i $pair.host_link -d egress -p 200 --proceed-on ok,pipe,dispatcher_return $prog_b]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t21 argv=t20 primary=l_b rc=_ guard=true fail=bb6
  BuildArgs t22 = [bpfman link attach tc -i $pair.host_link -d egress -p 300 --proceed-on ok,pipe,dispatcher_return $prog_c]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t23 argv=t22 primary=l_c rc=_ guard=true fail=bb7
  BuildArgs t24 = [bpfman link detach $l_a]
  RegisterDefer argv=t24 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t25 = [bpfman link detach $l_b]
  RegisterDefer argv=t25 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t26 = [bpfman link detach $l_c]
  RegisterDefer argv=t26 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t27 = [net exec $pair ping -c 20 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t28 = t27 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t28 argv=t27 primary=_ rc=_ guard=true fail=bb8
  Eval t29 = "fromjson | [.[].formatted.values[].value.rx_packets | tonumber] | add"
  BindName sumFilter = t29
  BuildArgs t30 = [bpftool map dump id $mapID_a -j]
  DispatchBind t31 = t30 policy=def-then-exec-bind lane=exec
  ApplyBind src=t31 argv=t30 primary=dump_a rc=_ guard=true fail=bb9
  BuildArgs t32 = [bpftool map dump id $mapID_b -j]
  DispatchBind t33 = t32 policy=def-then-exec-bind lane=exec
  ApplyBind src=t33 argv=t32 primary=dump_b rc=_ guard=true fail=bb10
  BuildArgs t34 = [bpftool map dump id $mapID_c -j]
  DispatchBind t35 = t34 policy=def-then-exec-bind lane=exec
  ApplyBind src=t35 argv=t34 primary=dump_c rc=_ guard=true fail=bb11
  Eval t36 = $dump_a.stdout |> jq $sumFilter
  BindName count_a = t36
  Eval t37 = $dump_b.stdout |> jq $sumFilter
  BindName count_b = t37
  Eval t38 = $dump_c.stdout |> jq $sumFilter
  BindName count_c = t38
  Assert $count_a > 0
  Assert $count_b > 0
  Assert $count_c > 0
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError
