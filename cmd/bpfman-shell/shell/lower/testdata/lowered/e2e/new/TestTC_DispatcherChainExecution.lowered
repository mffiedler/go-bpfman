body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  Eval t3 = [500 100 300 200 400]
  BindName priorities = t3
  Eval t4 = $priorities
  ForEachCollect list=t4 names=[prio] primary=links rc=_ guard=true body=bb2 exit=bb3

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  BuildArgs t5 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t6 argv=t5 primary=loaded rc=_ guard=true fail=bb4
  Eval t7 = $loaded.programs[0]
  BindName prog = t7
  BuildArgs t8 = [bpfman program unload $prog]
  RegisterDefer argv=t8 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t9 = [bpfman link attach tc -i $pair.host_link -d ingress -p $prio --proceed-on ok,pipe,dispatcher_return $prog]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  CollectProduce t10

bb3:
  Eval t11 = $links
  ForEach list=t11 names=[l] body=bb5 exit=bb6

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  BuildArgs t12 = [bpfman link detach $l]
  RegisterDefer argv=t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ForEachContinue

bb6:
  Eval t13 = $links
  ForEachCollect list=t13 names=[l] primary=progs rc=_ guard=true body=bb7 exit=bb8

bb7:
  BuildArgs t14 = [bpfman program get $l.record.program_id]
  DispatchBind t15 = t14 policy=def-then-exec-bind lane=builtin(bpfman)
  CollectProduce t15

bb8:
  Eval t16 = "[.status.maps[] | select(.name == \"tc_stats_map\") | .id][0]"
  BindName mapFilter = t16
  Eval t17 = $progs
  ForEachCollect list=t17 names=[p] primary=mapIDs rc=_ guard=false body=bb9 exit=bb10

bb9:
  BuildArgs t18 = [jq $mapFilter $p]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(jq)
  CollectProduce t19

bb10:
  BuildArgs t20 = [net exec $pair ping -c 20 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t21 argv=t20 primary=_ rc=_ guard=true fail=bb11
  Eval t22 = "fromjson | [.[].formatted.values[].value.rx_packets | tonumber] | add"
  BindName sumFilter = t22
  Eval t23 = $mapIDs
  ForEachCollect list=t23 names=[m] primary=dumps rc=_ guard=true body=bb12 exit=bb13

bb11:
  RunDefers policy=program
  PropagateError

bb12:
  BuildArgs t24 = [bpftool map dump id $m -j]
  DispatchBind t25 = t24 policy=def-then-exec-bind lane=exec
  CollectProduce t25

bb13:
  Eval t26 = $dumps
  ForEachCollect list=t26 names=[d] primary=counts rc=_ guard=false body=bb14 exit=bb15

bb14:
  BuildArgs t27 = [jq $sumFilter $d.stdout]
  DispatchBind t28 = t27 policy=def-then-exec-bind lane=builtin(jq)
  CollectProduce t28

bb15:
  Eval t29 = $counts
  ForEach list=t29 names=[c] body=bb16 exit=bb17

bb16:
  Assert $c > 0
  ForEachContinue

bb17:
  RunDefers policy=program
  Stop
