body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  Eval t1 = 5
  BindName n = t1
  Eval t2 = 41
  BindName weight_a = t2
  Eval t3 = 42
  BindName weight_b = t3
  Eval t4 = 43
  BindName weight_c = t4
  BuildArgs t5 = [net veth-pair]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t6 argv=t5 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t7 = [net release $pair]
  RegisterDefer argv=t7 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t8 = [net exec $pair ping -c 1 -W 1 $pair.host_addr]
  DispatchBind t9 = t8 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t9 argv=t8 primary=_ rc=_ guard=true fail=bb2
  BuildArgs t10 = [bpfman program load file --path testdata/bpf/multi_prog_xdp_chain_stops_at_drop.bpf.o --programs xdp:mxdp_chain_a,xdp:mxdp_chain_b,xdp:mxdp_chain_c -g "weight_a=0x${u64le $weight_a}" -g "weight_b=0x${u64le $weight_b}" -g "weight_c=0x${u64le $weight_c}"]
  DispatchBind t11 = t10 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t11 argv=t10 primary=loaded rc=_ guard=true fail=bb3
  Eval t12 = [$loaded.programs[0] $loaded.programs[0].record.program_id]
  BindDestructure [prog_a pid_a] = t12
  Eval t13 = [$loaded.programs[1] $loaded.programs[1].record.program_id]
  BindDestructure [prog_b pid_b] = t13
  Eval t14 = [$loaded.programs[2] $loaded.programs[2].record.program_id]
  BindDestructure [prog_c pid_c] = t14
  BuildArgs t15 = [bpfman program unload $pid_a]
  RegisterDefer argv=t15 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t16 = [bpfman program unload $pid_b]
  RegisterDefer argv=t16 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t17 = [bpfman program unload $pid_c]
  RegisterDefer argv=t17 policy=def-then-exec-bind lane=builtin(bpfman)
  Eval t18 = $prog_a |> jq "[.status.maps[] | select(.name == \"mxda_count\") | .id][0]"
  BindName mapID_a = t18
  Eval t19 = $prog_b |> jq "[.status.maps[] | select(.name == \"mxdb_count\") | .id][0]"
  BindName mapID_b = t19
  Eval t20 = $prog_c |> jq "[.status.maps[] | select(.name == \"mxdc_count\") | .id][0]"
  BindName mapID_c = t20
  BuildArgs t21 = [bpfman link attach xdp -i $pair.host_link -p 50 $pid_a]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t22 argv=t21 primary=link_a rc=_ guard=true fail=bb4
  BuildArgs t23 = [bpfman link attach xdp -i $pair.host_link -p 60 $pid_b]
  DispatchBind t24 = t23 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t24 argv=t23 primary=link_b rc=_ guard=true fail=bb5
  BuildArgs t25 = [bpfman link attach xdp -i $pair.host_link -p 70 $pid_c]
  DispatchBind t26 = t25 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t26 argv=t25 primary=link_c rc=_ guard=true fail=bb6
  Eval t27 = "fromjson | .[0].formatted.value | tonumber"
  BindName counter_filter = t27
  BuildArgs t28 = [net exec $pair ping -c $n -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t29 argv=t28 primary=_ rc=_ guard=false
  BuildArgs t30 = [bpftool map dump id $mapID_a -j]
  DispatchBind t31 = t30 policy=def-then-exec-bind lane=exec
  ApplyBind src=t31 argv=t30 primary=dump_a rc=_ guard=true fail=bb7
  BuildArgs t32 = [bpftool map dump id $mapID_b -j]
  DispatchBind t33 = t32 policy=def-then-exec-bind lane=exec
  ApplyBind src=t33 argv=t32 primary=dump_b rc=_ guard=true fail=bb8
  BuildArgs t34 = [bpftool map dump id $mapID_c -j]
  DispatchBind t35 = t34 policy=def-then-exec-bind lane=exec
  ApplyBind src=t35 argv=t34 primary=dump_c rc=_ guard=true fail=bb9
  Eval t36 = $dump_a.stdout |> jq $counter_filter
  BindName count_a = t36
  Eval t37 = $dump_b.stdout |> jq $counter_filter
  BindName count_b = t37
  Eval t38 = $dump_c.stdout |> jq $counter_filter
  BindName count_c = t38
  Eval t39 = $n * $weight_a
  BindName want_a = t39
  Eval t40 = $n * $weight_b
  BindName want_b = t40
  Eval t41 = 0
  BindName want_c = t41
  BuildArgs t42 = [print "a: got=${count_a} want=${want_a}  (ran, returned PASS)"]
  DispatchCommand argv=t42 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t43 = [print "b: got=${count_b} want=${want_b}  (ran, returned DROP)"]
  DispatchCommand argv=t43 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t44 = [print "c: got=${count_c} want=${want_c}    (never ran)"]
  DispatchCommand argv=t44 policy=def-then-exec-command lane=builtin(print)
  Assert $count_a == $want_a
  Assert $count_b == $want_b
  Assert $count_c == $want_c
  BuildArgs t45 = [bpfman link detach $link_a]
  DispatchCommand argv=t45 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t46 = [bpfman link detach $link_b]
  DispatchCommand argv=t46 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t47 = [bpfman link detach $link_c]
  DispatchCommand argv=t47 policy=def-then-exec-command lane=builtin(bpfman)
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError
