body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  Eval t3 = [100 200 300 400 500]
  BindName priorities = t3
  Eval t4 = ["ok,pipe,dispatcher_return" "ok,pipe,dispatcher_return" "shot" "ok,pipe,dispatcher_return" "ok,pipe,dispatcher_return"]
  BindName proceed_ons = t4
  Eval t5 = zip $priorities $proceed_ons
  ForEachCollect list=t5 names=[prio po] primary=links rc=_ guard=true body=bb2 exit=bb3

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  BuildArgs t6 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t7 = t6 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t7 argv=t6 primary=loaded rc=_ guard=true fail=bb4
  Eval t8 = $loaded.programs[0]
  BindName prog = t8
  BuildArgs t9 = [bpfman program unload $prog]
  RegisterDefer argv=t9 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t10 = [bpfman link attach tc -i $pair.host_link -d ingress -p $prio --proceed-on $po $prog]
  DispatchBind t11 = t10 policy=def-then-exec-bind lane=builtin(bpfman)
  CollectProduce t11

bb3:
  Eval t12 = $links
  ForEach list=t12 names=[l] body=bb5 exit=bb6

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  BuildArgs t13 = [bpfman link detach $l]
  RegisterDefer argv=t13 policy=def-then-exec-bind lane=builtin(bpfman)
  ForEachContinue

bb6:
  Eval t14 = $links
  ForEachCollect list=t14 names=[l] primary=progs rc=_ guard=true body=bb7 exit=bb8

bb7:
  BuildArgs t15 = [bpfman program get $l.record.program_id]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  CollectProduce t16

bb8:
  Eval t17 = "[.status.maps[] | select(.name == \"tc_stats_map\") | .id][0]"
  BindName mapFilter = t17
  Eval t18 = $progs
  ForEachCollect list=t18 names=[p] primary=mapIDs rc=_ guard=false body=bb9 exit=bb10

bb9:
  BuildArgs t19 = [jq $mapFilter $p]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=builtin(jq)
  CollectProduce t20

bb10:
  BuildArgs t21 = [net exec $pair ping -c 20 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t22 argv=t21 primary=_ rc=_ guard=true fail=bb11
  Eval t23 = "fromjson | [.[].formatted.values[].value.rx_packets | tonumber] | add"
  BindName sumFilter = t23
  Eval t24 = $mapIDs
  ForEachCollect list=t24 names=[m] primary=dumps rc=_ guard=true body=bb12 exit=bb13

bb11:
  RunDefers policy=program
  PropagateError

bb12:
  BuildArgs t25 = [bpftool map dump id $m -j]
  DispatchBind t26 = t25 policy=def-then-exec-bind lane=exec
  CollectProduce t26

bb13:
  Eval t27 = $dumps
  ForEachCollect list=t27 names=[d] primary=counts rc=_ guard=false body=bb14 exit=bb15

bb14:
  BuildArgs t28 = [jq $sumFilter $d.stdout]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=builtin(jq)
  CollectProduce t29

bb15:
  Assert $counts.[0] > 0
  Assert $counts.[1] > 0
  Assert $counts.[2] > 0
  Assert $counts.[3] == 0
  Assert $counts.[4] == 0
  RunDefers policy=program
  Stop
