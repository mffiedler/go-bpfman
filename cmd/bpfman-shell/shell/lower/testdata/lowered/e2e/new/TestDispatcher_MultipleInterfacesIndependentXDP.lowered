body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair_a rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair_a]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [net veth-pair]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t4 argv=t3 primary=pair_b rc=_ guard=true fail=bb2
  BuildArgs t5 = [net release $pair_b]
  RegisterDefer argv=t5 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t6 = [bpfman program load file --path testdata/bpf/xdp_counter.bpf.o --programs xdp:xdp_stats]
  DispatchBind t7 = t6 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t7 argv=t6 primary=loaded rc=_ guard=true fail=bb3
  Eval t8 = $loaded.programs[0]
  BindName prog = t8
  Eval t9 = $prog.record.program_id
  BindName pid = t9
  BuildArgs t10 = [bpfman program unload $pid]
  RegisterDefer argv=t10 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t11 = [bpfman link attach xdp -i $pair_a.host_link -p 100 $pid]
  DispatchBind t12 = t11 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t12 argv=t11 primary=a_100 rc=_ guard=true fail=bb4
  BuildArgs t13 = [bpfman link attach xdp -i $pair_a.host_link -p 200 $pid]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t14 argv=t13 primary=a_200 rc=_ guard=true fail=bb5
  BuildArgs t15 = [bpfman link attach xdp -i $pair_a.host_link -p 300 $pid]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=a_300 rc=_ guard=true fail=bb6
  BuildArgs t17 = [bpfman link detach $a_100]
  RegisterDefer argv=t17 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t18 = [bpfman link detach $a_200]
  RegisterDefer argv=t18 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t19 = [bpfman link detach $a_300]
  RegisterDefer argv=t19 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t20 = [bpfman link attach xdp -i $pair_b.host_link -p 100 $pid]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t21 argv=t20 primary=b_100 rc=_ guard=true fail=bb7
  BuildArgs t22 = [bpfman link attach xdp -i $pair_b.host_link -p 200 $pid]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t23 argv=t22 primary=b_200 rc=_ guard=true fail=bb8
  BuildArgs t24 = [bpfman dispatcher get xdp $pair_a.host_nsid $pair_a.host_ifindex]
  DispatchBind t25 = t24 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t25 argv=t24 primary=snap_a rc=_ guard=true fail=bb9
  Eval t26 = $snap_a |> jq ".members | length"
  BindName count_a = t26
  Assert $count_a == 3
  BuildArgs t27 = [bpfman dispatcher get xdp $pair_b.host_nsid $pair_b.host_ifindex]
  DispatchBind t28 = t27 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t28 argv=t27 primary=snap_b rc=_ guard=true fail=bb10
  Eval t29 = $snap_b |> jq ".members | length"
  BindName count_b = t29
  Assert $count_b == 2
  BuildArgs t30 = [bpfman link detach $b_100]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t31 = [bpfman link detach $b_200]
  DispatchCommand argv=t31 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman dispatcher get xdp $pair_b.host_nsid $pair_b.host_ifindex
  BuildArgs t32 = [bpfman dispatcher get xdp $pair_a.host_nsid $pair_a.host_ifindex]
  DispatchBind t33 = t32 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t33 argv=t32 primary=snap_a_after rc=_ guard=true fail=bb11
  Eval t34 = $snap_a_after |> jq ".members | length"
  BindName count_a_after = t34
  Assert $count_a_after == 3
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError
