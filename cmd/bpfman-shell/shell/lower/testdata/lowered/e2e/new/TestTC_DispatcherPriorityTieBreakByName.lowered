body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [bpfman program load file --path testdata/bpf/tc_pass.bpf.o --programs tc:beta]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded_beta rc=_ guard=true fail=bb2
  BuildArgs t5 = [bpfman program load file --path testdata/bpf/tc_pass.bpf.o --programs tc:alpha]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t6 argv=t5 primary=loaded_alpha rc=_ guard=true fail=bb3
  Eval t7 = $loaded_beta.programs[0]
  BindName prog_beta = t7
  Eval t8 = $loaded_alpha.programs[0]
  BindName prog_alpha = t8
  BuildArgs t9 = [bpfman program unload $prog_beta]
  RegisterDefer argv=t9 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t10 = [bpfman program unload $prog_alpha]
  RegisterDefer argv=t10 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t11 = [bpfman link attach tc -i $pair.host_link -d ingress -p 100 $prog_beta]
  DispatchBind t12 = t11 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t12 argv=t11 primary=l_beta rc=_ guard=true fail=bb4
  BuildArgs t13 = [bpfman link attach tc -i $pair.host_link -d ingress -p 100 $prog_alpha]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t14 argv=t13 primary=l_alpha rc=_ guard=true fail=bb5
  BuildArgs t15 = [bpfman link detach $l_beta]
  RegisterDefer argv=t15 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t16 = [bpfman link detach $l_alpha]
  RegisterDefer argv=t16 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t17 = [bpfman link get $l_alpha]
  DispatchBind t18 = t17 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t18 argv=t17 primary=g_alpha rc=_ guard=true fail=bb6
  BuildArgs t19 = [bpfman link get $l_beta]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t20 argv=t19 primary=g_beta rc=_ guard=true fail=bb7
  Assert $g_alpha.record.details.priority == 100
  Assert $g_beta.record.details.priority == 100
  Assert $g_alpha.record.details.position < $g_beta.record.details.position
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError
