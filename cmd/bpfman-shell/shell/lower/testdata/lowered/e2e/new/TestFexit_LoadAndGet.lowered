body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [import ../lib.bpfman]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(import)
  BuildArgs t1 = [bpfman program load file --path testdata/bpf/fentry_counter.bpf.o --programs fexit:test_fexit:do_unlinkat -m owner=e2e -m purpose=load-and-get]
  DispatchBind t2 = t1 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t2 argv=t1 primary=loaded rc=_ guard=true fail=bb1
  Eval t3 = $loaded.programs[0]
  BindName prog = t3
  Eval t4 = $prog.record.program_id
  BindName pid = t4
  Eval t5 = $prog.record.handles.pin_path |> jq "split(\"/fs/\")[0]"
  BindName runtime_base = t5
  Eval t6 = "${runtime_base}/fs/prog_${pid}"
  BindName expect_prog_pin = t6
  Eval t7 = "${runtime_base}/fs/maps/${pid}"
  BindName expect_map_dir = t7
  Eval t8 = "${runtime_base}/fs/links/${pid}"
  BindName expect_link_dir = t8
  Eval t9 = "${runtime_base}/programs/${pid}/bytecode.o"
  BindName expect_bytecode = t9
  Eval t10 = $prog.status.maps |> jq "[.[].id]"
  BindName expect_map_ids = t10
  Eval t11 = $prog.status.kernel.map_ids[0]
  BindName expect_map_id = t11
  BuildArgs t12 = [expect_program_load $prog fexit tracing test_fexit]
  DispatchCommand argv=t12 policy=def-then-exec-command lane=exec
  Assert $prog matches exhaustive { record: matches exhaustive { program_id: $pid, license: "Dual BSD/GPL", gpl_compatible: true, created_at: not-empty, updated_at: null, load: matches exhaustive { object_path: $expect_bytecode, program_name: test_fexit, program_type: fexit, attach_func: do_unlinkat, map_owner_id: null, global_data: empty, image_source: null }, handles: matches exhaustive { pin_path: $expect_prog_pin, map_pin_path: $expect_map_dir, map_owner_id: null }, meta: matches exhaustive { name: test_fexit, owner: "", description: "", metadata: matches exhaustive { owner: e2e, purpose: load-and-get } } }, status: matches exhaustive { kernel: matches exhaustive { id: $pid, name: test_fexit, program_type: tracing, tag: not-empty, loaded_at: not-empty, uid: 0, has_uid: true, btf_id: not-empty, has_btf_id: true, map_ids: $expect_map_ids, has_map_ids: true, jited_size: not-empty, xlated_size: not-empty, verified_insns: not-empty, memlock: not-empty, has_memlock: true, restricted: false }, stats: null, prog_pin: $expect_prog_pin, map_dir: $expect_map_dir, link_dir: $expect_link_dir, bytecode: $expect_bytecode, links: empty, maps: not-empty } }
  Assert $pid > 0
  Assert $prog.status.kernel.jited_size > 0
  Assert $prog.status.kernel.xlated_size > 0
  Assert $prog.status.kernel.verified_insns > 0
  Assert $prog.status.kernel.btf_id > 0
  Assert $prog.status.kernel.memlock > 0
  Eval t13 = $prog.status.maps[0]
  BindName m = t13
  Assert $m matches exhaustive { id: $expect_map_id, name: fentry_stats_ma, map_type: percpuarray, key_size: 4, value_size: 8, max_entries: 2, flags: 0, btf_id: not-empty, has_btf_id: true, map_extra: 0, has_map_extra: false, memlock: not-empty, has_memlock: true, frozen: false, pin_path: "", present: false }
  Assert $m.id > 0
  Assert $m.btf_id > 0
  Assert $m.memlock > 0
  BuildArgs t14 = [bpfman program get $pid]
  DispatchBind t15 = t14 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t15 argv=t14 primary=got rc=_ guard=true fail=bb2
  Assert $got matches exhaustive { record: matches exhaustive { program_id: $prog.record.program_id, license: $prog.record.license, gpl_compatible: $prog.record.gpl_compatible, created_at: $prog.record.created_at, updated_at: null, load: matches exhaustive { object_path: $prog.record.load.object_path, program_name: $prog.record.load.program_name, program_type: $prog.record.load.program_type, attach_func: do_unlinkat, map_owner_id: $prog.record.load.map_owner_id, global_data: empty, image_source: null }, handles: matches exhaustive { pin_path: $prog.record.handles.pin_path, map_pin_path: $prog.record.handles.map_pin_path, map_owner_id: null }, meta: matches exhaustive { name: $prog.record.meta.name, owner: $prog.record.meta.owner, description: $prog.record.meta.description, metadata: matches exhaustive { owner: $prog.record.meta.metadata.owner, purpose: $prog.record.meta.metadata.purpose } } }, status: matches exhaustive { kernel: matches exhaustive { id: $prog.status.kernel.id, name: test_fexit, program_type: tracing, tag: $prog.status.kernel.tag, loaded_at: $prog.status.kernel.loaded_at, uid: 0, has_uid: true, btf_id: $prog.status.kernel.btf_id, has_btf_id: true, map_ids: $expect_map_ids, has_map_ids: true, jited_size: $prog.status.kernel.jited_size, xlated_size: $prog.status.kernel.xlated_size, verified_insns: $prog.status.kernel.verified_insns, memlock: $prog.status.kernel.memlock, has_memlock: true, restricted: false }, stats: matches exhaustive { runtime: 0, run_count: 0, recursion_misses: 0 }, prog_pin: $expect_prog_pin, map_dir: $expect_map_dir, link_dir: $expect_link_dir, bytecode: $expect_bytecode, links: empty, maps: not-empty } }
  Eval t16 = $got.status.maps[0]
  BindName gm = t16
  Eval t17 = "${runtime_base}/fs/maps/${pid}/fentry_stats_map"
  BindName expect_map_pin = t17
  Assert $gm matches exhaustive { id: $m.id, name: $m.name, map_type: $m.map_type, key_size: $m.key_size, value_size: $m.value_size, max_entries: $m.max_entries, flags: $m.flags, btf_id: $m.btf_id, has_btf_id: $m.has_btf_id, map_extra: $m.map_extra, has_map_extra: $m.has_map_extra, memlock: $m.memlock, has_memlock: $m.has_memlock, frozen: $m.frozen, pin_path: $expect_map_pin, present: true }
  BuildArgs t18 = [bpfman program list -o json]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t19 argv=t18 primary=listed rc=_ guard=true fail=bb3
  Eval t20 = $listed |> jq ".programs[] | select(.record.program_id == ${pid})"
  BindName ours = t20
  Assert present $ours
  Assert $ours.record.meta.name == $prog.record.meta.name
  Assert $ours.status.kernel.id == $prog.status.kernel.id
  BuildArgs t21 = [bpfman program unload $pid]
  DispatchCommand argv=t21 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $pid
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError
