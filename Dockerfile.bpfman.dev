# syntax=docker/dockerfile:1.7
# Runtime image for go-bpfman, assembled from a host-built binary.
# The caller is responsible for producing bin/bpfman before invoking
# docker build; this file does no compilation.

FROM registry.access.redhat.com/ubi9/ubi-minimal:latest

COPY --link --chmod=0755 bin/bpfman /bpfman

ENV BPFMAN_MODE=bpfman-rpc
ENV BPFMAN_PPROF_ADDRESS=localhost:6060
ENTRYPOINT ["/bpfman"]
