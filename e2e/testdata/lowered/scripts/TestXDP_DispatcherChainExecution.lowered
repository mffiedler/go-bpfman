body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  Eval t3 = range 10
  ForEachCollect list=t3 names=[_] primary=links rc=_ guard=true body=bb2 exit=bb3

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  BuildArgs t4 = [bpfman program load file --path testdata/bpf/xdp_counter.bpf.o --programs xdp:xdp_stats]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t5 argv=t4 primary=loaded rc=_ guard=true fail=bb4
  Eval t6 = $loaded.programs[0]
  BindName prog = t6
  BuildArgs t7 = [bpfman program unload $prog]
  RegisterDefer argv=t7 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t8 = [bpfman link attach xdp -i $pair.host_link $prog]
  DispatchBind t9 = t8 policy=def-then-exec-bind lane=builtin(bpfman)
  CollectProduce t9

bb3:
  Eval t10 = $links
  ForEach list=t10 names=[l] body=bb5 exit=bb6

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  BuildArgs t11 = [bpfman link detach $l]
  RegisterDefer argv=t11 policy=def-then-exec-bind lane=builtin(bpfman)
  ForEachContinue

bb6:
  Eval t12 = $links
  ForEachCollect list=t12 names=[l] primary=progs rc=_ guard=true body=bb7 exit=bb8

bb7:
  BuildArgs t13 = [bpfman program get $l.record.program_id]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=builtin(bpfman)
  CollectProduce t14

bb8:
  Eval t15 = "[.status.maps[] | select(.name == \"xdp_stats_map\") | .id][0]"
  BindName mapFilter = t15
  Eval t16 = $progs
  ForEachCollect list=t16 names=[p] primary=mapIDs rc=_ guard=false body=bb9 exit=bb10

bb9:
  BuildArgs t17 = [jq $mapFilter $p]
  DispatchBind t18 = t17 policy=def-then-exec-bind lane=builtin(jq)
  CollectProduce t18

bb10:
  BuildArgs t19 = [net exec $pair ping -c 20 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t20 argv=t19 primary=_ rc=_ guard=true fail=bb11
  Eval t21 = "fromjson | [.[].formatted.values[].value.rx_packets | tonumber] | add"
  BindName sumFilter = t21
  Eval t22 = $mapIDs
  ForEachCollect list=t22 names=[m] primary=dumps rc=_ guard=true body=bb12 exit=bb13

bb11:
  RunDefers policy=program
  PropagateError

bb12:
  BuildArgs t23 = [bpftool map dump id $m -j]
  DispatchBind t24 = t23 policy=def-then-exec-bind lane=exec
  CollectProduce t24

bb13:
  Eval t25 = $dumps
  ForEachCollect list=t25 names=[d] primary=counts rc=_ guard=false body=bb14 exit=bb15

bb14:
  BuildArgs t26 = [jq $sumFilter $d.stdout]
  DispatchBind t27 = t26 policy=def-then-exec-bind lane=builtin(jq)
  CollectProduce t27

bb15:
  Eval t28 = $counts
  ForEach list=t28 names=[c] body=bb16 exit=bb17

bb16:
  Assert $c > 0
  ForEachContinue

bb17:
  RunDefers policy=program
  Stop
