body entry=bb0

bb0:
  EnterDeferScope kind=program
  Eval t0 = 5
  BindName n = t0
  Eval t1 = 41
  BindName weight_a = t1
  Eval t2 = 42
  BindName weight_b = t2
  Eval t3 = 43
  BindName weight_c = t3
  BuildArgs t4 = [net veth-pair]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t5 argv=t4 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t6 = [net release $pair]
  RegisterDefer argv=t6 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t7 = [bpfman program load file --path testdata/bpf/multi_prog_tcx_counter.bpf.o --programs tcx:mtcx_a,tcx:mtcx_b,tcx:mtcx_c -g "weight_a=0x${u64le $weight_a}" -g "weight_b=0x${u64le $weight_b}" -g "weight_c=0x${u64le $weight_c}"]
  DispatchBind t8 = t7 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t8 argv=t7 primary=loaded rc=_ guard=true fail=bb2
  Eval t9 = $loaded.programs[0]
  BindName a = t9
  Eval t10 = $loaded.programs[1]
  BindName b = t10
  Eval t11 = $loaded.programs[2]
  BindName c = t11
  BuildArgs t12 = [bpfman program unload $a]
  RegisterDefer argv=t12 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t13 = [bpfman program unload $b]
  RegisterDefer argv=t13 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t14 = [bpfman program unload $c]
  RegisterDefer argv=t14 policy=def-then-exec-bind lane=builtin(bpfman)
  Eval t15 = $a |> jq "[.status.maps[] | select(.name == \"mtcx_a_count\") | .id][0]"
  BindName mapID_a = t15
  Eval t16 = $b |> jq "[.status.maps[] | select(.name == \"mtcx_b_count\") | .id][0]"
  BindName mapID_b = t16
  Eval t17 = $c |> jq "[.status.maps[] | select(.name == \"mtcx_c_count\") | .id][0]"
  BindName mapID_c = t17
  BuildArgs t18 = [bpfman link attach tcx -i $pair.host_link -d ingress -p 50 $a]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t19 argv=t18 primary=link_a rc=_ guard=true fail=bb3
  BuildArgs t20 = [bpfman link attach tcx -i $pair.host_link -d ingress -p 60 $b]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t21 argv=t20 primary=link_b rc=_ guard=true fail=bb4
  BuildArgs t22 = [bpfman link attach tcx -i $pair.host_link -d ingress -p 70 $c]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t23 argv=t22 primary=link_c rc=_ guard=true fail=bb5
  Eval t24 = "fromjson | .[0].formatted.value | tonumber"
  BindName counter_filter = t24
  BuildArgs t25 = [net exec $pair ping -c $n -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t26 = t25 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t26 argv=t25 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t27 = [bpfman link detach $link_c]
  DispatchCommand argv=t27 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t28 = [net exec $pair ping -c $n -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t29 argv=t28 primary=_ rc=_ guard=true fail=bb7
  BuildArgs t30 = [bpfman link detach $link_b]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t31 = [net exec $pair ping -c $n -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t32 = t31 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t32 argv=t31 primary=_ rc=_ guard=true fail=bb8
  BuildArgs t33 = [bpftool map dump id $mapID_a -j]
  DispatchBind t34 = t33 policy=def-then-exec-bind lane=exec
  ApplyBind src=t34 argv=t33 primary=dump_a rc=_ guard=true fail=bb9
  BuildArgs t35 = [bpftool map dump id $mapID_b -j]
  DispatchBind t36 = t35 policy=def-then-exec-bind lane=exec
  ApplyBind src=t36 argv=t35 primary=dump_b rc=_ guard=true fail=bb10
  BuildArgs t37 = [bpftool map dump id $mapID_c -j]
  DispatchBind t38 = t37 policy=def-then-exec-bind lane=exec
  ApplyBind src=t38 argv=t37 primary=dump_c rc=_ guard=true fail=bb11
  Eval t39 = $dump_a.stdout |> jq $counter_filter
  BindName count_a = t39
  Eval t40 = $dump_b.stdout |> jq $counter_filter
  BindName count_b = t40
  Eval t41 = $dump_c.stdout |> jq $counter_filter
  BindName count_c = t41
  Eval t42 = (3 * $n) * $weight_a
  BindName want_a = t42
  Eval t43 = (2 * $n) * $weight_b
  BindName want_b = t43
  Eval t44 = (1 * $n) * $weight_c
  BindName want_c = t44
  BuildArgs t45 = [print "a: got=${count_a} want=${want_a}"]
  DispatchCommand argv=t45 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t46 = [print "b: got=${count_b} want=${want_b}"]
  DispatchCommand argv=t46 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t47 = [print "c: got=${count_c} want=${want_c}"]
  DispatchCommand argv=t47 policy=def-then-exec-command lane=builtin(print)
  Assert $count_a == $want_a
  Assert $count_b == $want_b
  Assert $count_c == $want_c
  BuildArgs t48 = [bpfman link detach $link_a]
  DispatchCommand argv=t48 policy=def-then-exec-command lane=builtin(bpfman)
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError
