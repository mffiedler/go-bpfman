def expect_program_load(prog load_tp kernel_tp name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName load_tp = t1
  BindName kernel_tp = t2
  BindName name = t3
  Assert $prog matches { record.load.program_type: $load_tp, status.kernel.program_type: $kernel_tp, record.meta.name: $name, status.kernel.id: $prog.record.program_id, status.kernel.name: not-empty, status.kernel.tag: not-empty, status.kernel.loaded_at: not-empty, record.handles.pin_path: not-empty }
  Eval t4 = not null $prog.record.load.image_source
  Branch cond=t4 true=bb1 false=bb2

bb1:
  EnterFrame kind=if-branch
  Assert $prog.record.load.image_source.url != ""
  Assert $prog.record.load.image_source.digest != ""
  Assert $prog.record.load.image_source.pull_policy == Always
  ExitFrame
  Jump bb3

bb2:
  Jump bb3

bb3:
  Jump bb4

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_program_round_trip(got prog) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName got = t0
  BindName prog = t1
  Assert $got matches { status.kernel.id: $prog.status.kernel.id, status.kernel.program_type: $prog.status.kernel.program_type, status.kernel.name: $prog.status.kernel.name, status.kernel.tag: $prog.status.kernel.tag, record.meta.name: $prog.record.meta.name, record.handles.pin_path: $prog.record.handles.pin_path }
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def inspect_published_image(image program_name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName image = t0
  BindName program_name = t1
  BuildArgs t2 = [bpfman image inspect $image]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t3 argv=t2 primary=inspected rc=_ guard=true fail=bb1
  Assert $inspected matches { reference: not-empty, digest: not-empty }
  Eval t4 = "if ((.manifests // []) | length) > 0 then [.manifests[] | select(.programs.${program_name} != null)][0] else . end"
  BindName program_filter = t4
  Eval t5 = $inspected |> jq "{inspected: ., manifest: (${program_filter})}"
  BindName bundle = t5
  Assert not null $bundle.manifest
  Assert ($bundle.manifest.layers |> jq "length") >= 1
  Eval t6 = $bundle
  ReturnValue t6 to=bb3

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  Jump bb3

bb3:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_loaded_image_source(prog image inspected) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName image = t1
  BindName inspected = t2
  Assert $prog.record.load.image_source.url == $image
  Eval t3 = $prog.record.load.image_source.digest
  BindName digest = t3
  Eval t4 = $inspected |> jq "if ((.manifests // []) | length) > 0 then [.manifests[].digest | select(. == "${digest}")] | length else if .digest == "${digest}" then 1 else 0 end end"
  BindName matches = t4
  Assert $matches == 1
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def await_wave_completion(ack n) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName ack = t0
  BindName n = t1
  Eval t2 = path-exists "${ack}.${n}"
  Branch cond=t2 true=bb1 false=bb2

bb1:
  Jump bb4

bb2:
  Eval t3 = "waiting for ack.${n}"
  RunDefers policy=attempt-fatal
  ExitFrame
  RetryPoll message=t3

bb3:

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def assert_link_absent(listed linkID) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName listed = t0
  BindName linkID = t1
  Eval t2 = $listed |> jq "[.links[] | select(.id == ${linkID})] | length"
  BindName count = t2
  Assert $count == 0
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

body entry=bb0

bb0:
  EnterDeferScope kind=program
  Eval t0 = "quay.io/bpfman-bytecode/go-tracepoint-counter"
  BindName image = t0
  BuildArgs t1 = [inspect_published_image $image tracepoint_kill_recorder]
  DispatchBind t2 = t1 policy=def-then-exec-bind lane=def(inspect_published_image)
  ApplyBind src=t2 argv=t1 primary=published rc=_ guard=true fail=bb1
  Assert $published.manifest.programs.tracepoint_kill_recorder == tracepoint
  Assert $published.manifest.maps.tracepoint_stats_map == per_cpu_array
  BuildArgs t3 = [bpfman program load image --image-url $image --pull-policy Always --programs tracepoint:tracepoint_kill_recorder]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded rc=_ guard=true fail=bb2
  Eval t5 = $loaded.programs[0]
  BindName prog = t5
  Eval t6 = $prog.record.program_id
  BindName pid = t6
  BuildArgs t7 = [bpfman program unload $pid]
  RegisterDefer argv=t7 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t8 = [expect_program_load $prog tracepoint tracepoint tracepoint_kill_recorder]
  DispatchCommand argv=t8 policy=def-then-exec-command lane=def(expect_program_load)
  BuildArgs t9 = [expect_loaded_image_source $prog $image $published.inspected]
  DispatchCommand argv=t9 policy=def-then-exec-command lane=def(expect_loaded_image_source)
  BuildArgs t10 = [bpfman link attach tracepoint $prog syscalls/sys_enter_kill]
  DispatchBind t11 = t10 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t11 argv=t10 primary=link rc=_ guard=true fail=bb3
  Eval t12 = $link.record.id
  BindName linkID = t12
  Assert $link.record.kind == tracepoint
  Assert $link.record.program_id == $pid
  Assert $link.record.details.group == syscalls
  Assert $link.record.details.name == sys_enter_kill
  Assert $link.status.kernel_seen
  Eval t13 = 5
  BindName events = t13
  Eval t14 = $prog.status.maps[0].id
  BindName mapID = t14
  Eval t15 = "fromjson | [.[].formatted.values[].value.calls | tonumber] | add"
  BindName sumFilter = t15
  BuildArgs t16 = [bpftool map dump id $mapID -j]
  DispatchBind t17 = t16 policy=def-then-exec-bind lane=exec
  ApplyBind src=t17 argv=t16 primary=dumpBefore rc=_ guard=true fail=bb4
  Eval t18 = $dumpBefore.stdout |> jq $sumFilter
  BindName before = t18
  BuildArgs t19 = [exec sh -c "i=0; trap \"\" USR1; while [ $i -lt \"$1\" ]; do kill -USR1 $$; i=$((i + 1)); done" sh $events]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t20 argv=t19 primary=_ rc=_ guard=true fail=bb5
  BuildArgs t21 = [bpftool map dump id $mapID -j]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=exec
  ApplyBind src=t22 argv=t21 primary=dumpAfter rc=_ guard=true fail=bb6
  Eval t23 = $dumpAfter.stdout |> jq $sumFilter
  BindName after = t23
  Eval t24 = $after - $before
  BindName delta = t24
  BuildArgs t25 = [print "published tracepoint image: events=${delta}"]
  DispatchCommand argv=t25 policy=def-then-exec-command lane=builtin(print)
  Assert $delta >= $events
  BuildArgs t26 = [bpfman link detach $link]
  DispatchCommand argv=t26 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t27 = [sleep 0.1]
  DispatchCommand argv=t27 policy=def-then-exec-command lane=exec
  BuildArgs t28 = [bpftool map dump id $mapID -j]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=exec
  ApplyBind src=t29 argv=t28 primary=dumpDetached rc=_ guard=true fail=bb7
  Eval t30 = $dumpDetached.stdout |> jq $sumFilter
  BindName detached = t30
  BuildArgs t31 = [exec sh -c "i=0; trap \"\" USR1; while [ $i -lt \"$1\" ]; do kill -USR1 $$; i=$((i + 1)); done" sh $events]
  DispatchBind t32 = t31 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t32 argv=t31 primary=_ rc=_ guard=true fail=bb8
  BuildArgs t33 = [bpftool map dump id $mapID -j]
  DispatchBind t34 = t33 policy=def-then-exec-bind lane=exec
  ApplyBind src=t34 argv=t33 primary=dumpAfterDetach rc=_ guard=true fail=bb9
  Eval t35 = $dumpAfterDetach.stdout |> jq $sumFilter
  BindName afterDetach = t35
  BuildArgs t36 = [print "published tracepoint image after-detach=${afterDetach} want=${detached}"]
  DispatchCommand argv=t36 policy=def-then-exec-command lane=builtin(print)
  Assert $afterDetach == $detached
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError
