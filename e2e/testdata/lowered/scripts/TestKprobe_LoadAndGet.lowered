def expect_program_load(prog load_tp kernel_tp name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName load_tp = t1
  BindName kernel_tp = t2
  BindName name = t3
  Assert $prog matches { record.load.program_type: $load_tp, status.kernel.program_type: $kernel_tp, record.meta.name: $name, status.kernel.id: $prog.record.program_id, status.kernel.name: not-empty, status.kernel.tag: not-empty, status.kernel.loaded_at: not-empty, record.handles.pin_path: not-empty }
  Eval t4 = not null $prog.record.load.image_source
  Branch cond=t4 true=bb1 false=bb2

bb1:
  EnterFrame kind=if-branch
  Assert $prog.record.load.image_source.url != ""
  Assert $prog.record.load.image_source.digest != ""
  Assert $prog.record.load.image_source.pull_policy == Always
  ExitFrame
  Jump bb3

bb2:
  EnterFrame kind=if-branch
  Assert null $prog.record.load.image_source
  ExitFrame
  Jump bb3

bb3:
  Jump bb4

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_program_round_trip(got prog) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName got = t0
  BindName prog = t1
  Assert $got matches { status.kernel.id: $prog.status.kernel.id, status.kernel.program_type: $prog.status.kernel.program_type, status.kernel.name: $prog.status.kernel.name, status.kernel.tag: $prog.status.kernel.tag, record.meta.name: $prog.record.meta.name, record.handles.pin_path: $prog.record.handles.pin_path }
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def inspect_published_image(image program_name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName image = t0
  BindName program_name = t1
  BuildArgs t2 = [bpfman image inspect $image]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t3 argv=t2 primary=inspected rc=_ guard=true fail=bb1
  Assert $inspected matches { reference: not-empty, digest: not-empty }
  Eval t4 = "if ((.manifests // []) | length) > 0 then [.manifests[] | select(.programs.${program_name} != null)][0] else . end"
  BindName program_filter = t4
  Eval t5 = $inspected |> jq "{inspected: ., manifest: (${program_filter})}"
  BindName bundle = t5
  Assert not null $bundle.manifest
  Assert ($bundle.manifest.layers |> jq "length") >= 1
  Eval t6 = $bundle
  ReturnValue t6 to=bb3

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  Jump bb3

bb3:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_loaded_image_source(prog image inspected) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName image = t1
  BindName inspected = t2
  Assert $prog.record.load.image_source.url == $image
  Eval t3 = $prog.record.load.image_source.digest
  BindName digest = t3
  Eval t4 = $inspected |> jq "if ((.manifests // []) | length) > 0 then [.manifests[].digest | select(. == "${digest}")] | length else if .digest == "${digest}" then 1 else 0 end end"
  BindName matches = t4
  Assert $matches == 1
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def await_wave_completion(ack n) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName ack = t0
  BindName n = t1
  Eval t2 = path-exists "${ack}.${n}"
  Branch cond=t2 true=bb1 false=bb2

bb1:
  Jump bb4

bb2:
  Eval t3 = "waiting for ack.${n}"
  RunDefers policy=attempt-fatal
  ExitFrame
  RetryPoll message=t3

bb3:

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def assert_link_absent(listed linkID) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName listed = t0
  BindName linkID = t1
  Eval t2 = $listed |> jq "[.links[] | select(.id == ${linkID})] | length"
  BindName count = t2
  Assert $count == 0
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [bpfman program load file --path testdata/bpf/kprobe_counter.bpf.o --programs kprobe:kprobe_counter -m owner=e2e -m purpose=load-and-get]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t1 argv=t0 primary=loaded rc=_ guard=true fail=bb1
  Eval t2 = $loaded.programs[0]
  BindName prog = t2
  Eval t3 = $prog.record.program_id
  BindName pid = t3
  Eval t4 = $prog.record.handles.pin_path |> jq "split(\"/fs/\")[0]"
  BindName runtime_base = t4
  Eval t5 = "${runtime_base}/fs/prog_${pid}"
  BindName expect_prog_pin = t5
  Eval t6 = "${runtime_base}/fs/maps/${pid}"
  BindName expect_map_dir = t6
  Eval t7 = "${runtime_base}/fs/links/${pid}"
  BindName expect_link_dir = t7
  Eval t8 = "${runtime_base}/programs/${pid}/bytecode.o"
  BindName expect_bytecode = t8
  Eval t9 = $prog.status.maps |> jq "[.[].id]"
  BindName expect_map_ids = t9
  Eval t10 = $prog.status.kernel.map_ids[0]
  BindName expect_map_id = t10
  BuildArgs t11 = [expect_program_load $prog kprobe kprobe kprobe_counter]
  DispatchCommand argv=t11 policy=def-then-exec-command lane=def(expect_program_load)
  Assert $prog matches exhaustive { record: matches exhaustive { program_id: $pid, license: "Dual BSD/GPL", gpl_compatible: true, created_at: not-empty, updated_at: null, load: matches exhaustive { object_path: $expect_bytecode, program_name: kprobe_counter, program_type: kprobe, attach_func: null, map_owner_id: null, global_data: empty, image_source: $prog.record.load.image_source }, handles: matches exhaustive { pin_path: $expect_prog_pin, map_pin_path: $expect_map_dir, map_owner_id: null }, meta: matches exhaustive { name: kprobe_counter, owner: "", description: "", metadata: matches exhaustive { owner: e2e, purpose: load-and-get } } }, status: matches exhaustive { kernel: matches exhaustive { id: $pid, name: kprobe_counter, program_type: kprobe, tag: not-empty, loaded_at: not-empty, uid: 0, has_uid: true, btf_id: not-empty, has_btf_id: true, map_ids: $expect_map_ids, has_map_ids: true, jited_size: not-empty, xlated_size: not-empty, verified_insns: not-empty, memlock: not-empty, has_memlock: true, restricted: false }, stats: null, prog_pin: $expect_prog_pin, map_dir: $expect_map_dir, link_dir: $expect_link_dir, bytecode: $expect_bytecode, links: empty, maps: not-empty } }
  Assert $pid > 0
  Assert $prog.status.kernel.jited_size > 0
  Assert $prog.status.kernel.xlated_size > 0
  Assert $prog.status.kernel.verified_insns > 0
  Assert $prog.status.kernel.btf_id > 0
  Assert $prog.status.kernel.memlock > 0
  Eval t12 = $prog.status.maps[0]
  BindName m = t12
  Assert $m matches exhaustive { id: $expect_map_id, name: kprobe_stats_ma, map_type: percpuarray, key_size: 4, value_size: 8, max_entries: 1, flags: 0, btf_id: not-empty, has_btf_id: true, map_extra: 0, has_map_extra: false, memlock: not-empty, has_memlock: true, frozen: false, pin_path: "", present: false }
  Assert $m.id > 0
  Assert $m.btf_id > 0
  Assert $m.memlock > 0
  BuildArgs t13 = [bpfman program get $pid]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t14 argv=t13 primary=got rc=_ guard=true fail=bb2
  Assert $got matches exhaustive { record: matches exhaustive { program_id: $prog.record.program_id, license: $prog.record.license, gpl_compatible: $prog.record.gpl_compatible, created_at: $prog.record.created_at, updated_at: null, load: matches exhaustive { object_path: $prog.record.load.object_path, program_name: $prog.record.load.program_name, program_type: $prog.record.load.program_type, attach_func: $prog.record.load.attach_func, map_owner_id: $prog.record.load.map_owner_id, global_data: empty, image_source: $prog.record.load.image_source }, handles: matches exhaustive { pin_path: $prog.record.handles.pin_path, map_pin_path: $prog.record.handles.map_pin_path, map_owner_id: null }, meta: matches exhaustive { name: $prog.record.meta.name, owner: $prog.record.meta.owner, description: $prog.record.meta.description, metadata: matches exhaustive { owner: $prog.record.meta.metadata.owner, purpose: $prog.record.meta.metadata.purpose } } }, status: matches exhaustive { kernel: matches exhaustive { id: $prog.status.kernel.id, name: kprobe_counter, program_type: kprobe, tag: $prog.status.kernel.tag, loaded_at: $prog.status.kernel.loaded_at, uid: 0, has_uid: true, btf_id: $prog.status.kernel.btf_id, has_btf_id: true, map_ids: $expect_map_ids, has_map_ids: true, jited_size: $prog.status.kernel.jited_size, xlated_size: $prog.status.kernel.xlated_size, verified_insns: $prog.status.kernel.verified_insns, memlock: $prog.status.kernel.memlock, has_memlock: true, restricted: false }, stats: matches exhaustive { runtime: 0, run_count: 0, recursion_misses: 0 }, prog_pin: $expect_prog_pin, map_dir: $expect_map_dir, link_dir: $expect_link_dir, bytecode: $expect_bytecode, links: empty, maps: not-empty } }
  Eval t15 = $got.status.maps[0]
  BindName gm = t15
  Eval t16 = "${runtime_base}/fs/maps/${pid}/kprobe_stats_map"
  BindName expect_map_pin = t16
  Assert $gm matches exhaustive { id: $m.id, name: $m.name, map_type: $m.map_type, key_size: $m.key_size, value_size: $m.value_size, max_entries: $m.max_entries, flags: $m.flags, btf_id: $m.btf_id, has_btf_id: $m.has_btf_id, map_extra: $m.map_extra, has_map_extra: $m.has_map_extra, memlock: $m.memlock, has_memlock: $m.has_memlock, frozen: $m.frozen, pin_path: $expect_map_pin, present: true }
  BuildArgs t17 = [bpfman program list -o json]
  DispatchBind t18 = t17 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t18 argv=t17 primary=listed rc=_ guard=true fail=bb3
  Eval t19 = $listed |> jq ".programs[] | select(.record.program_id == ${pid})"
  BindName ours = t19
  Assert present $ours
  Assert $ours.record.meta.name == $prog.record.meta.name
  Assert $ours.status.kernel.id == $prog.status.kernel.id
  BuildArgs t20 = [bpfman program unload $pid]
  DispatchCommand argv=t20 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $pid
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError
