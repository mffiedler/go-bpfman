def expect_program_load(prog load_tp kernel_tp name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName load_tp = t1
  BindName kernel_tp = t2
  BindName name = t3
  Assert $prog matches { record.load.program_type: $load_tp, status.kernel.program_type: $kernel_tp, record.meta.name: $name, status.kernel.id: $prog.record.program_id, status.kernel.name: not-empty, status.kernel.tag: not-empty, status.kernel.loaded_at: not-empty, record.handles.pin_path: not-empty }
  Eval t4 = not null $prog.record.load.image_source
  Branch cond=t4 true=bb1 false=bb2

bb1:
  EnterFrame kind=if-branch
  Assert $prog.record.load.image_source.url != ""
  Assert $prog.record.load.image_source.digest != ""
  Assert $prog.record.load.image_source.pull_policy == Always
  ExitFrame
  Jump bb3

bb2:
  EnterFrame kind=if-branch
  Assert null $prog.record.load.image_source
  ExitFrame
  Jump bb3

bb3:
  Jump bb4

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_program_round_trip(got prog) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName got = t0
  BindName prog = t1
  Assert $got matches { status.kernel.id: $prog.status.kernel.id, status.kernel.program_type: $prog.status.kernel.program_type, status.kernel.name: $prog.status.kernel.name, status.kernel.tag: $prog.status.kernel.tag, record.meta.name: $prog.record.meta.name, record.handles.pin_path: $prog.record.handles.pin_path }
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def inspect_published_image(image program_name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName image = t0
  BindName program_name = t1
  BuildArgs t2 = [bpfman image inspect $image]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t3 argv=t2 primary=inspected rc=_ guard=true fail=bb1
  Assert $inspected matches { reference: not-empty, digest: not-empty }
  Eval t4 = "if ((.manifests // []) | length) > 0 then [.manifests[] | select(.programs.${program_name} != null)][0] else . end"
  BindName program_filter = t4
  Eval t5 = $inspected |> jq "{inspected: ., manifest: (${program_filter})}"
  BindName bundle = t5
  Assert not null $bundle.manifest
  Assert ($bundle.manifest.layers |> jq "length") >= 1
  Eval t6 = $bundle
  ReturnValue t6 to=bb3

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  Jump bb3

bb3:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_loaded_image_source(prog image inspected) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName image = t1
  BindName inspected = t2
  Assert $prog.record.load.image_source.url == $image
  Eval t3 = $prog.record.load.image_source.digest
  BindName digest = t3
  Eval t4 = $inspected |> jq "if ((.manifests // []) | length) > 0 then [.manifests[].digest | select(. == "${digest}")] | length else if .digest == "${digest}" then 1 else 0 end end"
  BindName matches = t4
  Assert $matches == 1
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def await_wave_completion(ack n) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName ack = t0
  BindName n = t1
  Eval t2 = path-exists "${ack}.${n}"
  Branch cond=t2 true=bb1 false=bb2

bb1:
  Jump bb4

bb2:
  Eval t3 = "waiting for ack.${n}"
  RunDefers policy=attempt-fatal
  ExitFrame
  RetryPoll message=t3

bb3:

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def assert_link_absent(listed linkID) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName listed = t0
  BindName linkID = t1
  Eval t2 = $listed |> jq "[.links[] | select(.id == ${linkID})] | length"
  BindName count = t2
  Assert $count == 0
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

body entry=bb0

bb0:
  EnterDeferScope kind=program
  Eval t0 = 5
  BindName n = t0
  Eval t1 = 11
  BindName weight = t1
  BuildArgs t2 = [uprobe target]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(uprobe)
  ApplyBind src=t3 argv=t2 primary=target rc=_ guard=true fail=bb1
  BuildArgs t4 = [bpfman program load file --path testdata/bpf/uprobe_exact.bpf.o --programs uprobe:uprobe_counter -g "expected_pid=0x${u32le $target.pid}" -g "weight=0x${u64le $weight}"]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t5 argv=t4 primary=loaded rc=_ guard=true fail=bb2
  Eval t6 = $loaded.programs[0]
  BindName prog = t6
  Eval t7 = $prog.record.program_id
  BindName pid = t7
  BuildArgs t8 = [bpfman program unload $pid]
  RegisterDefer argv=t8 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t9 = [bpfman link attach uprobe --target $target.path --fn-name $target.symbol $prog]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t10 argv=t9 primary=link rc=_ guard=true fail=bb3
  Eval t11 = $link.record.id
  BindName linkID = t11
  Assert $link.record.kind == uprobe
  Assert $link.record.program_id == $pid
  Assert $link.record.details.target == $target.path
  Assert $link.record.details.fn_name == $target.symbol
  Assert $link.record.details.offset == 0
  Assert not $link.record.details.retprobe
  Assert $link.status.kernel_seen
  BuildArgs t12 = [bpfman link get $linkID]
  DispatchBind t13 = t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t13 argv=t12 primary=gotLink rc=_ guard=true fail=bb4
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == uprobe
  Assert $gotLink.record.program_id == $pid
  Assert $gotLink.record.details.target == $target.path
  Assert $gotLink.record.details.fn_name == $target.symbol
  Assert $gotLink.record.details.offset == 0
  Assert not $gotLink.record.details.retprobe
  BuildArgs t14 = [bpfman link list -o json]
  DispatchBind t15 = t14 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t15 argv=t14 primary=listed rc=_ guard=true fail=bb5
  Eval t16 = $listed |> jq ".links[] | select(.id == ${linkID})"
  BindName ourLink = t16
  Require not null ourLink
  Assert $ourLink.id == $linkID
  Assert $ourLink.kind == uprobe
  Eval t17 = $prog |> jq "[.status.maps[] | select(.name == \"up_count\") | .id][0]"
  BindName mapID = t17
  Eval t18 = "fromjson | .[0].formatted.value | tonumber"
  BindName counter_filter = t18
  BuildArgs t19 = [uprobe fire $n]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=builtin(uprobe)
  ApplyBind src=t20 argv=t19 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t21 = [bpftool map dump id $mapID -j]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=exec
  ApplyBind src=t22 argv=t21 primary=dump rc=_ guard=true fail=bb7
  Eval t23 = $dump.stdout |> jq $counter_filter
  BindName count = t23
  Eval t24 = $n * $weight
  BindName want = t24
  BuildArgs t25 = [print "uprobe count: got=${count} want=${want}"]
  DispatchCommand argv=t25 policy=def-then-exec-command lane=builtin(print)
  Assert $count == $want
  BuildArgs t26 = [bpfman link detach $link]
  DispatchCommand argv=t26 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t27 = [bpfman link list -o json]
  DispatchBind t28 = t27 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t28 argv=t27 primary=listedAfter rc=_ guard=true fail=bb8
  BuildArgs t29 = [assert_link_absent $listedAfter $linkID]
  DispatchCommand argv=t29 policy=def-then-exec-command lane=def(assert_link_absent)
  BuildArgs t30 = [sleep 0.1]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=exec
  BuildArgs t31 = [bpftool map dump id $mapID -j]
  DispatchBind t32 = t31 policy=def-then-exec-bind lane=exec
  ApplyBind src=t32 argv=t31 primary=dumpDetached rc=_ guard=true fail=bb9
  Eval t33 = $dumpDetached.stdout |> jq $counter_filter
  BindName detached = t33
  BuildArgs t34 = [uprobe fire $n]
  DispatchBind t35 = t34 policy=def-then-exec-bind lane=builtin(uprobe)
  ApplyBind src=t35 argv=t34 primary=_ rc=_ guard=true fail=bb10
  BuildArgs t36 = [bpftool map dump id $mapID -j]
  DispatchBind t37 = t36 policy=def-then-exec-bind lane=exec
  ApplyBind src=t37 argv=t36 primary=dumpAfterDetach rc=_ guard=true fail=bb11
  Eval t38 = $dumpAfterDetach.stdout |> jq $counter_filter
  BindName afterDetach = t38
  BuildArgs t39 = [print "uprobe after-detach=${afterDetach} want=${detached}"]
  DispatchCommand argv=t39 policy=def-then-exec-command lane=builtin(print)
  Assert $afterDetach == $detached
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

