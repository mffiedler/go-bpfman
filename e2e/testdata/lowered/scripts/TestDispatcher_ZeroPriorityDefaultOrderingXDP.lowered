body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [bpfman program load file --path testdata/bpf/xdp_counter.bpf.o --programs xdp:xdp_stats]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded rc=_ guard=true fail=bb2
  Eval t5 = $loaded.programs[0]
  BindName prog = t5
  BuildArgs t6 = [bpfman program unload $prog]
  RegisterDefer argv=t6 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t7 = [bpfman link attach xdp -i $pair.host_link -p 25 $prog]
  DispatchBind t8 = t7 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t8 argv=t7 primary=l_25 rc=_ guard=true fail=bb3
  BuildArgs t9 = [bpfman link attach xdp -i $pair.host_link -p 0 $prog]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t10 argv=t9 primary=l_0 rc=_ guard=true fail=bb4
  BuildArgs t11 = [bpfman link attach xdp -i $pair.host_link -p 75 $prog]
  DispatchBind t12 = t11 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t12 argv=t11 primary=l_75 rc=_ guard=true fail=bb5
  BuildArgs t13 = [bpfman link detach $l_25]
  RegisterDefer argv=t13 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t14 = [bpfman link detach $l_0]
  RegisterDefer argv=t14 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t15 = [bpfman link detach $l_75]
  RegisterDefer argv=t15 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t16 = [bpfman link get $l_25]
  DispatchBind t17 = t16 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t17 argv=t16 primary=g_25 rc=_ guard=true fail=bb6
  BuildArgs t18 = [bpfman link get $l_0]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t19 argv=t18 primary=g_0 rc=_ guard=true fail=bb7
  BuildArgs t20 = [bpfman link get $l_75]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t21 argv=t20 primary=g_75 rc=_ guard=true fail=bb8
  Assert $g_25.record.details.priority == 25
  Assert $g_0.record.details.priority == 0
  Assert $g_75.record.details.priority == 75
  Assert $g_25.record.details.position == 0
  Assert $g_0.record.details.position == 1
  Assert $g_75.record.details.position == 2
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError
