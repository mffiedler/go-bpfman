body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded rc=_ guard=true fail=bb2
  Eval t5 = $loaded.programs[0]
  BindName prog = t5
  BuildArgs t6 = [bpfman program unload $prog]
  RegisterDefer argv=t6 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t7 = [bpfman link attach tc -i $pair.host_link -d ingress -p 0 $prog]
  DispatchBind t8 = t7 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t8 argv=t7 primary=in_0 rc=_ guard=true fail=bb3
  BuildArgs t9 = [bpfman link attach tc -i $pair.host_link -d ingress -p 100 $prog]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t10 argv=t9 primary=in_100 rc=_ guard=true fail=bb4
  BuildArgs t11 = [bpfman link attach tc -i $pair.host_link -d ingress -p 200 $prog]
  DispatchBind t12 = t11 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t12 argv=t11 primary=in_200 rc=_ guard=true fail=bb5
  BuildArgs t13 = [bpfman link detach $in_0]
  RegisterDefer argv=t13 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t14 = [bpfman link detach $in_100]
  RegisterDefer argv=t14 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t15 = [bpfman link detach $in_200]
  RegisterDefer argv=t15 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t16 = [bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex]
  DispatchBind t17 = t16 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t17 argv=t16 primary=snap_in_before rc=_ guard=true fail=bb6
  Assert ($snap_in_before |> jq ".members | length") == 3
  BuildArgs t18 = [bpfman link attach tc -i $pair.host_link -d egress -p 0 $prog]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t19 argv=t18 primary=eg_0 rc=_ guard=true fail=bb7
  BuildArgs t20 = [bpfman link attach tc -i $pair.host_link -d egress -p 100 $prog]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t21 argv=t20 primary=eg_100 rc=_ guard=true fail=bb8
  BuildArgs t22 = [bpfman dispatcher get tc-egress $pair.host_nsid $pair.host_ifindex]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t23 argv=t22 primary=snap_eg rc=_ guard=true fail=bb9
  Assert ($snap_eg |> jq ".members | length") == 2
  BuildArgs t24 = [bpfman link detach $eg_0]
  DispatchCommand argv=t24 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t25 = [bpfman link detach $eg_100]
  DispatchCommand argv=t25 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman dispatcher get tc-egress $pair.host_nsid $pair.host_ifindex
  BuildArgs t26 = [bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex]
  DispatchBind t27 = t26 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t27 argv=t26 primary=snap_in_after rc=_ guard=true fail=bb10
  Assert ($snap_in_after |> jq ".members | length") == 3
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError
