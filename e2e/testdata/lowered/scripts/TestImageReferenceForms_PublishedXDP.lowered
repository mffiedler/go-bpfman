def expect_program_load(prog load_tp kernel_tp name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName load_tp = t1
  BindName kernel_tp = t2
  BindName name = t3
  Assert $prog matches { record.load.program_type: $load_tp, status.kernel.program_type: $kernel_tp, record.meta.name: $name, status.kernel.id: $prog.record.program_id, status.kernel.name: not-empty, status.kernel.tag: not-empty, status.kernel.loaded_at: not-empty, record.handles.pin_path: not-empty }
  Eval t4 = not null $prog.record.load.image_source
  Branch cond=t4 true=bb1 false=bb2

bb1:
  EnterFrame kind=if-branch
  Assert $prog.record.load.image_source.url != ""
  Assert $prog.record.load.image_source.digest != ""
  Assert $prog.record.load.image_source.pull_policy == Always
  ExitFrame
  Jump bb3

bb2:
  EnterFrame kind=if-branch
  Assert null $prog.record.load.image_source
  ExitFrame
  Jump bb3

bb3:
  Jump bb4

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_program_round_trip(got prog) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName got = t0
  BindName prog = t1
  Assert $got matches { status.kernel.id: $prog.status.kernel.id, status.kernel.program_type: $prog.status.kernel.program_type, status.kernel.name: $prog.status.kernel.name, status.kernel.tag: $prog.status.kernel.tag, record.meta.name: $prog.record.meta.name, record.handles.pin_path: $prog.record.handles.pin_path }
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def inspect_published_image(image program_name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName image = t0
  BindName program_name = t1
  BuildArgs t2 = [bpfman image inspect $image]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t3 argv=t2 primary=inspected rc=_ guard=true fail=bb1
  Assert $inspected matches { reference: not-empty, digest: not-empty }
  Eval t4 = "if ((.manifests // []) | length) > 0 then [.manifests[] | select(.programs.${program_name} != null)][0] else . end"
  BindName program_filter = t4
  Eval t5 = $inspected |> jq "{inspected: ., manifest: (${program_filter})}"
  BindName bundle = t5
  Assert not null $bundle.manifest
  Assert ($bundle.manifest.layers |> jq "length") >= 1
  Eval t6 = $bundle
  ReturnValue t6 to=bb3

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  Jump bb3

bb3:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_loaded_image_source(prog image inspected) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName image = t1
  BindName inspected = t2
  Assert $prog.record.load.image_source.url == $image
  Eval t3 = $prog.record.load.image_source.digest
  BindName digest = t3
  Eval t4 = $inspected |> jq "if ((.manifests // []) | length) > 0 then [.manifests[].digest | select(. == "${digest}")] | length else if .digest == "${digest}" then 1 else 0 end end"
  BindName matches = t4
  Assert $matches == 1
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def await_wave_completion(ack n) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName ack = t0
  BindName n = t1
  Eval t2 = path-exists "${ack}.${n}"
  Branch cond=t2 true=bb1 false=bb2

bb1:
  Jump bb4

bb2:
  Eval t3 = "waiting for ack.${n}"
  RunDefers policy=attempt-fatal
  ExitFrame
  RetryPoll message=t3

bb3:

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def assert_link_absent(listed linkID) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName listed = t0
  BindName linkID = t1
  Eval t2 = $listed |> jq "[.links[] | select(.id == ${linkID})] | length"
  BindName count = t2
  Assert $count == 0
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_xdp_ref(image) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName image = t0
  BuildArgs t1 = [print "image-ref: inspecting ${image}"]
  DispatchCommand argv=t1 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t2 = [inspect_published_image $image xdp_stats]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=def(inspect_published_image)
  ApplyBind src=t3 argv=t2 primary=published rc=_ guard=true fail=bb1
  Assert $published.manifest.programs.xdp_stats == xdp
  Assert $published.manifest.maps.xdp_stats_map == per_cpu_array
  BuildArgs t4 = [print "image-ref: loading ${image}"]
  DispatchCommand argv=t4 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t5 = [bpfman program load image --image-url $image --pull-policy Always --programs xdp:xdp_stats]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t6 argv=t5 primary=loaded rc=_ guard=true fail=bb2
  Eval t7 = $loaded.programs[0]
  BindName prog = t7
  Eval t8 = $prog.record.program_id
  BindName pid = t8
  BuildArgs t9 = [print "image-ref: unloaded ${image} pid=${pid}"]
  RegisterDefer argv=t9 policy=def-then-exec-bind lane=builtin(print)
  BuildArgs t10 = [bpfman program unload $pid]
  RegisterDefer argv=t10 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t11 = [expect_program_load $prog xdp extension xdp_stats]
  DispatchCommand argv=t11 policy=def-then-exec-command lane=def(expect_program_load)
  BuildArgs t12 = [expect_loaded_image_source $prog $image $published.inspected]
  DispatchCommand argv=t12 policy=def-then-exec-command lane=def(expect_loaded_image_source)
  BuildArgs t13 = [print "image-ref: loaded ${image} digest=${prog.record.load.image_source.digest}"]
  DispatchCommand argv=t13 policy=def-then-exec-command lane=builtin(print)
  Eval t14 = $published.inspected
  ReturnValue t14 to=bb4

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb3:
  Jump bb4

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

body entry=bb0

bb0:
  EnterDeferScope kind=program
  Eval t0 = "quay.io/bpfman-bytecode/go-xdp-counter"
  BindName bare = t0
  Eval t1 = "${bare}:latest"
  BindName tagged = t1
  BuildArgs t2 = [expect_xdp_ref $tagged]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=def(expect_xdp_ref)
  ApplyBind src=t3 argv=t2 primary=tagged_inspected rc=_ guard=true fail=bb1
  Assert $tagged_inspected.reference == $tagged
  BuildArgs t4 = [expect_xdp_ref $bare]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=def(expect_xdp_ref)
  ApplyBind src=t5 argv=t4 primary=bare_inspected rc=_ guard=true fail=bb2
  Assert $bare_inspected.reference == $tagged
  Assert $bare_inspected.digest == $tagged_inspected.digest
  Eval t6 = "${bare}@${tagged_inspected.digest}"
  BindName digest_ref = t6
  BuildArgs t7 = [expect_xdp_ref $digest_ref]
  DispatchBind t8 = t7 policy=def-then-exec-bind lane=def(expect_xdp_ref)
  ApplyBind src=t8 argv=t7 primary=digest_inspected rc=_ guard=true fail=bb3
  Assert $digest_inspected.reference == $digest_ref
  Assert $digest_inspected.digest == $tagged_inspected.digest
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError
