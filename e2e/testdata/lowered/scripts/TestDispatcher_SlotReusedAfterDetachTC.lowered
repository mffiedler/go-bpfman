body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded rc=_ guard=true fail=bb2
  Eval t5 = $loaded.programs[0]
  BindName prog = t5
  BuildArgs t6 = [bpfman program unload $prog]
  RegisterDefer argv=t6 policy=def-then-exec-bind lane=builtin(bpfman)
  Eval t7 = [100 200 300 500 600 700 800 900 1000]
  BindName keep_priorities = t7
  Eval t8 = $keep_priorities
  ForEachCollect list=t8 names=[prio] primary=kept rc=_ guard=true body=bb3 exit=bb4

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  BuildArgs t9 = [bpfman link attach tc -i $pair.host_link -d ingress -p $prio $prog]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  CollectProduce t10

bb4:
  Eval t11 = $kept
  ForEach list=t11 names=[l] body=bb5 exit=bb6

bb5:
  BuildArgs t12 = [bpfman link detach $l]
  RegisterDefer argv=t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ForEachContinue

bb6:
  BuildArgs t13 = [bpfman link attach tc -i $pair.host_link -d ingress -p 400 $prog]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t14 argv=t13 primary=l_400 rc=_ guard=true fail=bb7
  BuildArgs t15 = [bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=snap_full rc=_ guard=true fail=bb8
  Eval t17 = $snap_full |> jq ".members | length"
  BindName count_full = t17
  Assert $count_full == 10
  BuildArgs t18 = [bpfman link detach $l_400]
  DispatchCommand argv=t18 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t19 = [bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t20 argv=t19 primary=snap_partial rc=_ guard=true fail=bb9
  Eval t21 = $snap_partial |> jq ".members | length"
  BindName count_partial = t21
  Assert $count_partial == 9
  BuildArgs t22 = [bpfman link attach tc -i $pair.host_link -d ingress -p 350 $prog]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t23 argv=t22 primary=l_350 rc=_ guard=true fail=bb10
  BuildArgs t24 = [bpfman link detach $l_350]
  RegisterDefer argv=t24 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t25 = [bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex]
  DispatchBind t26 = t25 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t26 argv=t25 primary=snap_refilled rc=_ guard=true fail=bb11
  Eval t27 = $snap_refilled |> jq ".members | length"
  BindName count_refilled = t27
  Assert $count_refilled == 10
  Assert $l_350.record.details.position == 3
  RunDefers policy=program
  Stop

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError
