def expect_program_load(prog load_tp kernel_tp name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName load_tp = t1
  BindName kernel_tp = t2
  BindName name = t3
  Assert $prog matches { record.load.program_type: $load_tp, status.kernel.program_type: $kernel_tp, record.meta.name: $name, status.kernel.id: $prog.record.program_id, status.kernel.name: not-empty, status.kernel.tag: not-empty, status.kernel.loaded_at: not-empty, record.handles.pin_path: not-empty }
  Eval t4 = not null $prog.record.load.image_source
  Branch cond=t4 true=bb1 false=bb2

bb1:
  EnterFrame kind=if-branch
  Assert $prog.record.load.image_source.url != ""
  Assert $prog.record.load.image_source.digest != ""
  Assert $prog.record.load.image_source.pull_policy == Always
  ExitFrame
  Jump bb3

bb2:
  Jump bb3

bb3:
  Jump bb4

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_program_round_trip(got prog) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName got = t0
  BindName prog = t1
  Assert $got matches { status.kernel.id: $prog.status.kernel.id, status.kernel.program_type: $prog.status.kernel.program_type, status.kernel.name: $prog.status.kernel.name, status.kernel.tag: $prog.status.kernel.tag, record.meta.name: $prog.record.meta.name, record.handles.pin_path: $prog.record.handles.pin_path }
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def inspect_published_image(image program_name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName image = t0
  BindName program_name = t1
  BuildArgs t2 = [bpfman image inspect $image]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t3 argv=t2 primary=inspected rc=_ guard=true fail=bb1
  Assert $inspected matches { reference: not-empty, digest: not-empty }
  Eval t4 = "if ((.manifests // []) | length) > 0 then [.manifests[] | select(.programs.${program_name} != null)][0] else . end"
  BindName program_filter = t4
  Eval t5 = $inspected |> jq "{inspected: ., manifest: (${program_filter})}"
  BindName bundle = t5
  Assert not null $bundle.manifest
  Assert ($bundle.manifest.layers |> jq "length") >= 1
  Eval t6 = $bundle
  ReturnValue t6 to=bb3

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  Jump bb3

bb3:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_loaded_image_source(prog image inspected) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName image = t1
  BindName inspected = t2
  Assert $prog.record.load.image_source.url == $image
  Eval t3 = $prog.record.load.image_source.digest
  BindName digest = t3
  Eval t4 = $inspected |> jq "if ((.manifests // []) | length) > 0 then [.manifests[].digest | select(. == "${digest}")] | length else if .digest == "${digest}" then 1 else 0 end end"
  BindName matches = t4
  Assert $matches == 1
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def await_wave_completion(ack n) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName ack = t0
  BindName n = t1
  Eval t2 = path-exists "${ack}.${n}"
  Branch cond=t2 true=bb1 false=bb2

bb1:
  Jump bb4

bb2:
  Eval t3 = "waiting for ack.${n}"
  RunDefers policy=attempt-fatal
  ExitFrame
  RetryPoll message=t3

bb3:

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def assert_link_absent(listed linkID) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName listed = t0
  BindName linkID = t1
  Eval t2 = $listed |> jq "[.links[] | select(.id == ${linkID})] | length"
  BindName count = t2
  Assert $count == 0
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [print "PROOF: shared-map program delete ordering (owner-first / dependant-first / recursive / --all)"]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t1 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats -m role=owner]
  DispatchBind t2 = t1 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t2 argv=t1 primary=ownerA rc=_ guard=true fail=bb1
  Eval t3 = $ownerA.programs[0]
  BindName progOwnerA = t3
  Eval t4 = $progOwnerA.record.program_id
  BindName oA = t4
  BuildArgs t5 = [expect_program_load $progOwnerA tcx schedcls tcx_stats]
  DispatchCommand argv=t5 policy=def-then-exec-command lane=def(expect_program_load)
  BuildArgs t6 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oA -m role=dependent]
  DispatchBind t7 = t6 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t7 argv=t6 primary=depA rc=_ guard=true fail=bb2
  Eval t8 = $depA.programs[0].record.program_id
  BindName dA = t8
  Assert $depA.programs[0].record.handles.map_owner_id == $oA
  BuildArgs t9 = [print "A: loaded owner=${oA}, dependant=${dA} sharing its maps"]
  DispatchCommand argv=t9 policy=def-then-exec-command lane=builtin(print)
  Assert fail bpfman program delete $oA
  BuildArgs t10 = [bpfman program get $oA]
  DispatchBind t11 = t10 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t11 argv=t10 primary=survivedOwnerA rc=_ guard=true fail=bb3
  BuildArgs t12 = [bpfman program get $dA]
  DispatchBind t13 = t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t13 argv=t12 primary=survivedDepA rc=_ guard=true fail=bb4
  BuildArgs t14 = [print "A: non-recursive delete of owner ${oA} alone refused; both survive"]
  DispatchCommand argv=t14 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t15 = [bpfman program delete $oA $dA]
  DispatchCommand argv=t15 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $oA
  Assert fail bpfman program get $dA
  BuildArgs t16 = [print "A: owner-first batch deleted ${oA} and ${dA}"]
  DispatchCommand argv=t16 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t17 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats]
  DispatchBind t18 = t17 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t18 argv=t17 primary=ownerB rc=_ guard=true fail=bb5
  Eval t19 = $ownerB.programs[0].record.program_id
  BindName oB = t19
  BuildArgs t20 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oB]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t21 argv=t20 primary=depB rc=_ guard=true fail=bb6
  Eval t22 = $depB.programs[0].record.program_id
  BindName dB = t22
  Assert $depB.programs[0].record.handles.map_owner_id == $oB
  BuildArgs t23 = [bpfman program delete $dB $oB]
  DispatchCommand argv=t23 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $oB
  Assert fail bpfman program get $dB
  BuildArgs t24 = [print "B: dependant-first batch deleted ${oB} and ${dB}"]
  DispatchCommand argv=t24 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t25 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats]
  DispatchBind t26 = t25 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t26 argv=t25 primary=ownerC rc=_ guard=true fail=bb7
  Eval t27 = $ownerC.programs[0].record.program_id
  BindName oC = t27
  BuildArgs t28 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oC]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t29 argv=t28 primary=depC rc=_ guard=true fail=bb8
  Eval t30 = $depC.programs[0].record.program_id
  BindName dC = t30
  Assert $depC.programs[0].record.handles.map_owner_id == $oC
  BuildArgs t31 = [bpfman program delete $oC -r]
  DispatchCommand argv=t31 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $oC
  Assert fail bpfman program get $dC
  BuildArgs t32 = [print "C: recursive delete of ${oC} removed unnamed dependant ${dC}"]
  DispatchCommand argv=t32 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t33 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats]
  DispatchBind t34 = t33 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t34 argv=t33 primary=ownerD rc=_ guard=true fail=bb9
  Eval t35 = $ownerD.programs[0].record.program_id
  BindName oD = t35
  BuildArgs t36 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oD]
  DispatchBind t37 = t36 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t37 argv=t36 primary=depD rc=_ guard=true fail=bb10
  Eval t38 = $depD.programs[0].record.program_id
  BindName dD = t38
  Assert $depD.programs[0].record.handles.map_owner_id == $oD
  BuildArgs t39 = [bpfman program delete --all]
  DispatchCommand argv=t39 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t40 = [bpfman program list -o json]
  DispatchBind t41 = t40 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t41 argv=t40 primary=listedD rc=_ guard=true fail=bb11
  Eval t42 = $listedD |> jq "[.programs[]] | length"
  BindName remaining = t42
  Assert $remaining == 0
  BuildArgs t43 = [print "D: --all cleared the store; remaining=${remaining}"]
  DispatchCommand argv=t43 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t44 = [print "PROOF complete: ordering holds for owner-first, dependant-first, recursive, and --all"]
  DispatchCommand argv=t44 policy=def-then-exec-command lane=builtin(print)
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

