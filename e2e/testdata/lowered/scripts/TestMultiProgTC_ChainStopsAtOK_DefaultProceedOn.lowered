def expect_program_load(prog load_tp kernel_tp name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName load_tp = t1
  BindName kernel_tp = t2
  BindName name = t3
  Assert $prog matches { record.load.program_type: $load_tp, status.kernel.program_type: $kernel_tp, record.meta.name: $name, status.kernel.id: $prog.record.program_id, status.kernel.name: not-empty, status.kernel.tag: not-empty, status.kernel.loaded_at: not-empty, record.handles.pin_path: not-empty }
  Eval t4 = not null $prog.record.load.image_source
  Branch cond=t4 true=bb1 false=bb2

bb1:
  EnterFrame kind=if-branch
  Assert $prog.record.load.image_source.url != ""
  Assert $prog.record.load.image_source.digest != ""
  Assert $prog.record.load.image_source.pull_policy == Always
  ExitFrame
  Jump bb3

bb2:
  EnterFrame kind=if-branch
  Assert null $prog.record.load.image_source
  ExitFrame
  Jump bb3

bb3:
  Jump bb4

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_program_round_trip(got prog) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName got = t0
  BindName prog = t1
  Assert $got matches { status.kernel.id: $prog.status.kernel.id, status.kernel.program_type: $prog.status.kernel.program_type, status.kernel.name: $prog.status.kernel.name, status.kernel.tag: $prog.status.kernel.tag, record.meta.name: $prog.record.meta.name, record.handles.pin_path: $prog.record.handles.pin_path }
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def inspect_published_image(image program_name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName image = t0
  BindName program_name = t1
  BuildArgs t2 = [bpfman image inspect $image]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t3 argv=t2 primary=inspected rc=_ guard=true fail=bb1
  Assert $inspected matches { reference: not-empty, digest: not-empty }
  Eval t4 = "if ((.manifests // []) | length) > 0 then [.manifests[] | select(.programs.${program_name} != null)][0] else . end"
  BindName program_filter = t4
  Eval t5 = $inspected |> jq "{inspected: ., manifest: (${program_filter})}"
  BindName bundle = t5
  Assert not null $bundle.manifest
  Assert ($bundle.manifest.layers |> jq "length") >= 1
  Eval t6 = $bundle
  ReturnValue t6 to=bb3

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  Jump bb3

bb3:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_loaded_image_source(prog image inspected) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName image = t1
  BindName inspected = t2
  Assert $prog.record.load.image_source.url == $image
  Eval t3 = $prog.record.load.image_source.digest
  BindName digest = t3
  Eval t4 = $inspected |> jq "if ((.manifests // []) | length) > 0 then [.manifests[].digest | select(. == "${digest}")] | length else if .digest == "${digest}" then 1 else 0 end end"
  BindName matches = t4
  Assert $matches == 1
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def await_wave_completion(ack n) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName ack = t0
  BindName n = t1
  Eval t2 = path-exists "${ack}.${n}"
  Branch cond=t2 true=bb1 false=bb2

bb1:
  Jump bb4

bb2:
  Eval t3 = "waiting for ack.${n}"
  RunDefers policy=attempt-fatal
  ExitFrame
  RetryPoll message=t3

bb3:

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def assert_link_absent(listed linkID) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName listed = t0
  BindName linkID = t1
  Eval t2 = $listed |> jq "[.links[] | select(.id == ${linkID})] | length"
  BindName count = t2
  Assert $count == 0
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

body entry=bb0

bb0:
  EnterDeferScope kind=program
  Eval t0 = 5
  BindName n = t0
  Eval t1 = 41
  BindName weight_a = t1
  Eval t2 = 42
  BindName weight_b = t2
  Eval t3 = 43
  BindName weight_c = t3
  BuildArgs t4 = [net veth-pair]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t5 argv=t4 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t6 = [net release $pair]
  RegisterDefer argv=t6 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t7 = [bpfman program load file --path testdata/bpf/multi_prog_tc_chain_stops_at_ok.bpf.o --programs tc:mtc_chain_a,tc:mtc_chain_b,tc:mtc_chain_c -g "weight_a=0x${u64le $weight_a}" -g "weight_b=0x${u64le $weight_b}" -g "weight_c=0x${u64le $weight_c}"]
  DispatchBind t8 = t7 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t8 argv=t7 primary=loaded rc=_ guard=true fail=bb2
  Eval t9 = $loaded.programs[0]
  BindName a = t9
  Eval t10 = $loaded.programs[1]
  BindName b = t10
  Eval t11 = $loaded.programs[2]
  BindName c = t11
  BuildArgs t12 = [bpfman program unload $a]
  RegisterDefer argv=t12 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t13 = [bpfman program unload $b]
  RegisterDefer argv=t13 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t14 = [bpfman program unload $c]
  RegisterDefer argv=t14 policy=def-then-exec-bind lane=builtin(bpfman)
  Eval t15 = $a |> jq "[.status.maps[] | select(.name == \"mca_count\") | .id][0]"
  BindName mapID_a = t15
  Eval t16 = $b |> jq "[.status.maps[] | select(.name == \"mcb_count\") | .id][0]"
  BindName mapID_b = t16
  Eval t17 = $c |> jq "[.status.maps[] | select(.name == \"mcc_count\") | .id][0]"
  BindName mapID_c = t17
  BuildArgs t18 = [bpfman link attach tc -i $pair.host_link -d ingress -p 50 $a]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t19 argv=t18 primary=link_a rc=_ guard=true fail=bb3
  BuildArgs t20 = [bpfman link attach tc -i $pair.host_link -d ingress -p 60 $b]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t21 argv=t20 primary=link_b rc=_ guard=true fail=bb4
  BuildArgs t22 = [bpfman link attach tc -i $pair.host_link -d ingress -p 70 $c]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t23 argv=t22 primary=link_c rc=_ guard=true fail=bb5
  Eval t24 = "fromjson | .[0].formatted.value | tonumber"
  BindName counter_filter = t24
  BuildArgs t25 = [net exec $pair ping -c $n -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t26 = t25 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t26 argv=t25 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t27 = [bpftool map dump id $mapID_a -j]
  DispatchBind t28 = t27 policy=def-then-exec-bind lane=exec
  ApplyBind src=t28 argv=t27 primary=dump_a rc=_ guard=true fail=bb7
  BuildArgs t29 = [bpftool map dump id $mapID_b -j]
  DispatchBind t30 = t29 policy=def-then-exec-bind lane=exec
  ApplyBind src=t30 argv=t29 primary=dump_b rc=_ guard=true fail=bb8
  BuildArgs t31 = [bpftool map dump id $mapID_c -j]
  DispatchBind t32 = t31 policy=def-then-exec-bind lane=exec
  ApplyBind src=t32 argv=t31 primary=dump_c rc=_ guard=true fail=bb9
  Eval t33 = $dump_a.stdout |> jq $counter_filter
  BindName count_a = t33
  Eval t34 = $dump_b.stdout |> jq $counter_filter
  BindName count_b = t34
  Eval t35 = $dump_c.stdout |> jq $counter_filter
  BindName count_c = t35
  Eval t36 = $n * $weight_a
  BindName want_a = t36
  Eval t37 = $n * $weight_b
  BindName want_b = t37
  Eval t38 = 0
  BindName want_c = t38
  BuildArgs t39 = [print "a: got=${count_a} want=${want_a}  (ran, returned PIPE)"]
  DispatchCommand argv=t39 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t40 = [print "b: got=${count_b} want=${want_b}  (ran, returned OK)"]
  DispatchCommand argv=t40 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t41 = [print "c: got=${count_c} want=${want_c}    (never ran)"]
  DispatchCommand argv=t41 policy=def-then-exec-command lane=builtin(print)
  Assert $count_a == $want_a
  Assert $count_b == $want_b
  Assert $count_c == $want_c
  BuildArgs t42 = [bpfman link detach $link_a]
  DispatchCommand argv=t42 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t43 = [bpfman link detach $link_b]
  DispatchCommand argv=t43 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t44 = [bpfman link detach $link_c]
  DispatchCommand argv=t44 policy=def-then-exec-command lane=builtin(bpfman)
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

