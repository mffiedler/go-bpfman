def expect_program_load(prog load_tp kernel_tp name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName load_tp = t1
  BindName kernel_tp = t2
  BindName name = t3
  Assert $prog matches { record.load.program_type: $load_tp, status.kernel.program_type: $kernel_tp, record.meta.name: $name, status.kernel.id: $prog.record.program_id, status.kernel.name: not-empty, status.kernel.tag: not-empty, status.kernel.loaded_at: not-empty, record.handles.pin_path: not-empty }
  Eval t4 = not null $prog.record.load.image_source
  Branch cond=t4 true=bb1 false=bb2

bb1:
  EnterFrame kind=if-branch
  Assert $prog.record.load.image_source.url != ""
  Assert $prog.record.load.image_source.digest != ""
  Assert $prog.record.load.image_source.pull_policy == Always
  ExitFrame
  Jump bb3

bb2:
  Jump bb3

bb3:
  Jump bb4

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_program_round_trip(got prog) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName got = t0
  BindName prog = t1
  Assert $got matches { status.kernel.id: $prog.status.kernel.id, status.kernel.program_type: $prog.status.kernel.program_type, status.kernel.name: $prog.status.kernel.name, status.kernel.tag: $prog.status.kernel.tag, record.meta.name: $prog.record.meta.name, record.handles.pin_path: $prog.record.handles.pin_path }
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def inspect_published_image(image program_name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName image = t0
  BindName program_name = t1
  BuildArgs t2 = [bpfman image inspect $image]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t3 argv=t2 primary=inspected rc=_ guard=true fail=bb1
  Assert $inspected matches { reference: not-empty, digest: not-empty }
  Eval t4 = "if ((.manifests // []) | length) > 0 then [.manifests[] | select(.programs.${program_name} != null)][0] else . end"
  BindName program_filter = t4
  Eval t5 = $inspected |> jq "{inspected: ., manifest: (${program_filter})}"
  BindName bundle = t5
  Assert not null $bundle.manifest
  Assert ($bundle.manifest.layers |> jq "length") >= 1
  Eval t6 = $bundle
  ReturnValue t6 to=bb3

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  Jump bb3

bb3:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_loaded_image_source(prog image inspected) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName image = t1
  BindName inspected = t2
  Assert $prog.record.load.image_source.url == $image
  Eval t3 = $prog.record.load.image_source.digest
  BindName digest = t3
  Eval t4 = $inspected |> jq "if ((.manifests // []) | length) > 0 then [.manifests[].digest | select(. == "${digest}")] | length else if .digest == "${digest}" then 1 else 0 end end"
  BindName matches = t4
  Assert $matches == 1
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def await_wave_completion(ack n) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName ack = t0
  BindName n = t1
  Eval t2 = path-exists "${ack}.${n}"
  Branch cond=t2 true=bb1 false=bb2

bb1:
  Jump bb4

bb2:
  Eval t3 = "waiting for ack.${n}"
  RunDefers policy=attempt-fatal
  ExitFrame
  RetryPoll message=t3

bb3:

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def assert_link_absent(listed linkID) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName listed = t0
  BindName linkID = t1
  Eval t2 = $listed |> jq "[.links[] | select(.id == ${linkID})] | length"
  BindName count = t2
  Assert $count == 0
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

body entry=bb0

bb0:
  EnterDeferScope kind=program
  Eval t0 = 5
  BindName n = t0
  Eval t1 = 41
  BindName weight_tp = t1
  Eval t2 = 42
  BindName weight_kp = t2
  Eval t3 = 43
  BindName weight_krp = t3
  BuildArgs t4 = [kfunc acquire]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t5 argv=t4 primary=fn rc=_ guard=true fail=bb1
  BuildArgs t6 = [kfunc release $fn]
  RegisterDefer argv=t6 policy=def-then-exec-bind lane=builtin(kfunc)
  BuildArgs t7 = [bpfman program load file --path testdata/bpf/multi_prog_mixed_counter_script.bpf.o --programs tracepoint:mixed_tp,kprobe:mixed_kp,kretprobe:mixed_krp -g "expected_slot=0x${u32le $fn.index}" -g "weight_tp=0x${u64le $weight_tp}" -g "weight_kp=0x${u64le $weight_kp}" -g "weight_krp=0x${u64le $weight_krp}"]
  DispatchBind t8 = t7 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t8 argv=t7 primary=loaded rc=_ guard=true fail=bb2
  Eval t9 = $loaded.programs[0]
  BindName tp = t9
  Eval t10 = $loaded.programs[1]
  BindName kp = t10
  Eval t11 = $loaded.programs[2]
  BindName krp = t11
  BuildArgs t12 = [bpfman program unload $tp]
  RegisterDefer argv=t12 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t13 = [bpfman program unload $kp]
  RegisterDefer argv=t13 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t14 = [bpfman program unload $krp]
  RegisterDefer argv=t14 policy=def-then-exec-bind lane=builtin(bpfman)
  Eval t15 = $tp |> jq "[.status.maps[] | select(.name == \"mtp_count\")  | .id][0]"
  BindName mapID_tp = t15
  Eval t16 = $kp |> jq "[.status.maps[] | select(.name == \"mkp_count\")  | .id][0]"
  BindName mapID_kp = t16
  Eval t17 = $krp |> jq "[.status.maps[] | select(.name == \"mkrp_count\") | .id][0]"
  BindName mapID_krp = t17
  BuildArgs t18 = [bpfman link attach tracepoint $tp bpfman_e2e/bpfman_e2e_ping]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t19 argv=t18 primary=link_tp rc=_ guard=true fail=bb3
  BuildArgs t20 = [bpfman link attach kprobe --fn-name $fn.name $kp]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t21 argv=t20 primary=link_kp rc=_ guard=true fail=bb4
  BuildArgs t22 = [bpfman link attach kprobe --fn-name $fn.name $krp]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t23 argv=t22 primary=link_krp rc=_ guard=true fail=bb5
  Eval t24 = "fromjson | .[0].formatted.value | tonumber"
  BindName counter_filter = t24
  BuildArgs t25 = [kfunc fire $fn $n]
  DispatchBind t26 = t25 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t26 argv=t25 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t27 = [bpfman link detach $link_krp]
  DispatchCommand argv=t27 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t28 = [sleep 0.1]
  DispatchCommand argv=t28 policy=def-then-exec-command lane=exec
  BuildArgs t29 = [kfunc fire $fn $n]
  DispatchBind t30 = t29 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t30 argv=t29 primary=_ rc=_ guard=true fail=bb7
  BuildArgs t31 = [bpfman link detach $link_kp]
  DispatchCommand argv=t31 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t32 = [sleep 0.1]
  DispatchCommand argv=t32 policy=def-then-exec-command lane=exec
  BuildArgs t33 = [kfunc fire $fn $n]
  DispatchBind t34 = t33 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t34 argv=t33 primary=_ rc=_ guard=true fail=bb8
  BuildArgs t35 = [bpftool map dump id $mapID_tp -j]
  DispatchBind t36 = t35 policy=def-then-exec-bind lane=exec
  ApplyBind src=t36 argv=t35 primary=dump_tp rc=_ guard=true fail=bb9
  BuildArgs t37 = [bpftool map dump id $mapID_kp -j]
  DispatchBind t38 = t37 policy=def-then-exec-bind lane=exec
  ApplyBind src=t38 argv=t37 primary=dump_kp rc=_ guard=true fail=bb10
  BuildArgs t39 = [bpftool map dump id $mapID_krp -j]
  DispatchBind t40 = t39 policy=def-then-exec-bind lane=exec
  ApplyBind src=t40 argv=t39 primary=dump_krp rc=_ guard=true fail=bb11
  Eval t41 = $dump_tp.stdout |> jq $counter_filter
  BindName count_tp = t41
  Eval t42 = $dump_kp.stdout |> jq $counter_filter
  BindName count_kp = t42
  Eval t43 = $dump_krp.stdout |> jq $counter_filter
  BindName count_krp = t43
  Eval t44 = (3 * $n) * $weight_tp
  BindName want_tp = t44
  Eval t45 = (2 * $n) * $weight_kp
  BindName want_kp = t45
  Eval t46 = (1 * $n) * $weight_krp
  BindName want_krp = t46
  BuildArgs t47 = [print "tp:  got=${count_tp}  want=${want_tp}"]
  DispatchCommand argv=t47 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t48 = [print "kp:  got=${count_kp}  want=${want_kp}"]
  DispatchCommand argv=t48 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t49 = [print "krp: got=${count_krp} want=${want_krp}"]
  DispatchCommand argv=t49 policy=def-then-exec-command lane=builtin(print)
  Assert $count_tp == $want_tp
  Assert $count_kp == $want_kp
  Assert $count_krp == $want_krp
  BuildArgs t50 = [bpfman link detach $link_tp]
  DispatchCommand argv=t50 policy=def-then-exec-command lane=builtin(bpfman)
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

