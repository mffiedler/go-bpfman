def expect_program_load(prog load_tp kernel_tp name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName load_tp = t1
  BindName kernel_tp = t2
  BindName name = t3
  Assert $prog matches { record.load.program_type: $load_tp, status.kernel.program_type: $kernel_tp, record.meta.name: $name, status.kernel.id: $prog.record.program_id, status.kernel.name: not-empty, status.kernel.tag: not-empty, status.kernel.loaded_at: not-empty, record.handles.pin_path: not-empty }
  Eval t4 = not null $prog.record.load.image_source
  Branch cond=t4 true=bb1 false=bb2

bb1:
  EnterFrame kind=if-branch
  Assert $prog.record.load.image_source.url != ""
  Assert $prog.record.load.image_source.digest != ""
  Assert $prog.record.load.image_source.pull_policy == Always
  ExitFrame
  Jump bb3

bb2:
  EnterFrame kind=if-branch
  Assert null $prog.record.load.image_source
  ExitFrame
  Jump bb3

bb3:
  Jump bb4

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_program_round_trip(got prog) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName got = t0
  BindName prog = t1
  Assert $got matches { status.kernel.id: $prog.status.kernel.id, status.kernel.program_type: $prog.status.kernel.program_type, status.kernel.name: $prog.status.kernel.name, status.kernel.tag: $prog.status.kernel.tag, record.meta.name: $prog.record.meta.name, record.handles.pin_path: $prog.record.handles.pin_path }
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def inspect_published_image(image program_name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName image = t0
  BindName program_name = t1
  BuildArgs t2 = [bpfman image inspect $image]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t3 argv=t2 primary=inspected rc=_ guard=true fail=bb1
  Assert $inspected matches { reference: not-empty, digest: not-empty }
  Eval t4 = "if ((.manifests // []) | length) > 0 then [.manifests[] | select(.programs.${program_name} != null)][0] else . end"
  BindName program_filter = t4
  Eval t5 = $inspected |> jq "{inspected: ., manifest: (${program_filter})}"
  BindName bundle = t5
  Assert not null $bundle.manifest
  Assert ($bundle.manifest.layers |> jq "length") >= 1
  Eval t6 = $bundle
  ReturnValue t6 to=bb3

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  Jump bb3

bb3:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_loaded_image_source(prog image inspected) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName image = t1
  BindName inspected = t2
  Assert $prog.record.load.image_source.url == $image
  Eval t3 = $prog.record.load.image_source.digest
  BindName digest = t3
  Eval t4 = $inspected |> jq "if ((.manifests // []) | length) > 0 then [.manifests[].digest | select(. == "${digest}")] | length else if .digest == "${digest}" then 1 else 0 end end"
  BindName matches = t4
  Assert $matches == 1
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def await_wave_completion(ack n) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName ack = t0
  BindName n = t1
  Eval t2 = path-exists "${ack}.${n}"
  Branch cond=t2 true=bb1 false=bb2

bb1:
  Jump bb4

bb2:
  Eval t3 = "waiting for ack.${n}"
  RunDefers policy=attempt-fatal
  ExitFrame
  RetryPoll message=t3

bb3:

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def assert_link_absent(listed linkID) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName listed = t0
  BindName linkID = t1
  Eval t2 = $listed |> jq "[.links[] | select(.id == ${linkID})] | length"
  BindName count = t2
  Assert $count == 0
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [print "PROOF: shared-map delete fan-out (one owner, three dependants)"]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t1 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats -m role=owner]
  DispatchBind t2 = t1 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t2 argv=t1 primary=ownerA rc=_ guard=true fail=bb1
  Eval t3 = $ownerA.programs[0]
  BindName progOwnerA = t3
  Eval t4 = $progOwnerA.record.program_id
  BindName oA = t4
  BuildArgs t5 = [expect_program_load $progOwnerA tcx schedcls tcx_stats]
  DispatchCommand argv=t5 policy=def-then-exec-command lane=def(expect_program_load)
  BuildArgs t6 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oA]
  DispatchBind t7 = t6 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t7 argv=t6 primary=depA1 rc=_ guard=true fail=bb2
  Eval t8 = $depA1.programs[0].record.program_id
  BindName dA1 = t8
  Assert $depA1.programs[0].record.handles.map_owner_id == $oA
  BuildArgs t9 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oA]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t10 argv=t9 primary=depA2 rc=_ guard=true fail=bb3
  Eval t11 = $depA2.programs[0].record.program_id
  BindName dA2 = t11
  Assert $depA2.programs[0].record.handles.map_owner_id == $oA
  BuildArgs t12 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oA]
  DispatchBind t13 = t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t13 argv=t12 primary=depA3 rc=_ guard=true fail=bb4
  Eval t14 = $depA3.programs[0].record.program_id
  BindName dA3 = t14
  Assert $depA3.programs[0].record.handles.map_owner_id == $oA
  BuildArgs t15 = [print "A: owner=${oA} with dependants ${dA1}, ${dA2}, ${dA3} sharing its maps"]
  DispatchCommand argv=t15 policy=def-then-exec-command lane=builtin(print)
  Assert fail bpfman program delete $oA
  BuildArgs t16 = [bpfman program list -o json]
  DispatchBind t17 = t16 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t17 argv=t16 primary=afterFailA rc=_ guard=true fail=bb5
  Eval t18 = $afterFailA |> jq "[.programs[]] | length"
  BindName survivorsA = t18
  Assert $survivorsA == 4
  BuildArgs t19 = [print "A: non-recursive delete of owner ${oA} alone refused; all 4 survive"]
  DispatchCommand argv=t19 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t20 = [bpfman program delete $dA2 $oA $dA3 $dA1]
  DispatchCommand argv=t20 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $oA
  Assert fail bpfman program get $dA1
  Assert fail bpfman program get $dA2
  Assert fail bpfman program get $dA3
  BuildArgs t21 = [print "A: scrambled batch (${dA2} ${oA} ${dA3} ${dA1}) deleted all four"]
  DispatchCommand argv=t21 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t22 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats]
  DispatchBind t23 = t22 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t23 argv=t22 primary=ownerB rc=_ guard=true fail=bb6
  Eval t24 = $ownerB.programs[0].record.program_id
  BindName oB = t24
  BuildArgs t25 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oB]
  DispatchBind t26 = t25 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t26 argv=t25 primary=depB1 rc=_ guard=true fail=bb7
  Eval t27 = $depB1.programs[0].record.program_id
  BindName dB1 = t27
  BuildArgs t28 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oB]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t29 argv=t28 primary=depB2 rc=_ guard=true fail=bb8
  Eval t30 = $depB2.programs[0].record.program_id
  BindName dB2 = t30
  BuildArgs t31 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oB]
  DispatchBind t32 = t31 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t32 argv=t31 primary=depB3 rc=_ guard=true fail=bb9
  Eval t33 = $depB3.programs[0].record.program_id
  BindName dB3 = t33
  Assert $depB1.programs[0].record.handles.map_owner_id == $oB
  Assert $depB3.programs[0].record.handles.map_owner_id == $oB
  BuildArgs t34 = [bpfman program delete $oB -r]
  DispatchCommand argv=t34 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $oB
  Assert fail bpfman program get $dB1
  Assert fail bpfman program get $dB2
  Assert fail bpfman program get $dB3
  BuildArgs t35 = [print "B: recursive delete of ${oB} removed unnamed dependants ${dB1}, ${dB2}, ${dB3}"]
  DispatchCommand argv=t35 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t36 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats]
  DispatchBind t37 = t36 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t37 argv=t36 primary=ownerC rc=_ guard=true fail=bb10
  Eval t38 = $ownerC.programs[0].record.program_id
  BindName oC = t38
  BuildArgs t39 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oC]
  DispatchBind t40 = t39 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t40 argv=t39 primary=depC1 rc=_ guard=true fail=bb11
  Eval t41 = $depC1.programs[0].record.program_id
  BindName dC1 = t41
  BuildArgs t42 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oC]
  DispatchBind t43 = t42 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t43 argv=t42 primary=depC2 rc=_ guard=true fail=bb12
  Eval t44 = $depC2.programs[0].record.program_id
  BindName dC2 = t44
  BuildArgs t45 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oC]
  DispatchBind t46 = t45 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t46 argv=t45 primary=depC3 rc=_ guard=true fail=bb13
  Eval t47 = $depC3.programs[0].record.program_id
  BindName dC3 = t47
  Assert $depC1.programs[0].record.handles.map_owner_id == $oC
  Assert $depC2.programs[0].record.handles.map_owner_id == $oC
  Assert $depC3.programs[0].record.handles.map_owner_id == $oC
  BuildArgs t48 = [bpfman program delete $oC $dC2 $dC1 -r]
  DispatchCommand argv=t48 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $oC
  Assert fail bpfman program get $dC1
  Assert fail bpfman program get $dC2
  Assert fail bpfman program get $dC3
  BuildArgs t49 = [print "C: recursive owner-plus-named batch (${oC} ${dC2} ${dC1}) deduped all dependants"]
  DispatchCommand argv=t49 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t50 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats]
  DispatchBind t51 = t50 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t51 argv=t50 primary=ownerD rc=_ guard=true fail=bb14
  Eval t52 = $ownerD.programs[0].record.program_id
  BindName oD = t52
  BuildArgs t53 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oD]
  DispatchBind t54 = t53 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t54 argv=t53 primary=depD1 rc=_ guard=true fail=bb15
  BuildArgs t55 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oD]
  DispatchBind t56 = t55 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t56 argv=t55 primary=depD2 rc=_ guard=true fail=bb16
  BuildArgs t57 = [bpfman program load file --path testdata/bpf/tcx_counter.bpf.o --programs tcx:tcx_stats --map-owner-id $oD]
  DispatchBind t58 = t57 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t58 argv=t57 primary=depD3 rc=_ guard=true fail=bb17
  Assert $depD1.programs[0].record.handles.map_owner_id == $oD
  BuildArgs t59 = [bpfman program delete --all]
  DispatchCommand argv=t59 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t60 = [bpfman program list -o json]
  DispatchBind t61 = t60 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t61 argv=t60 primary=listedD rc=_ guard=true fail=bb18
  Eval t62 = $listedD |> jq "[.programs[]] | length"
  BindName remainingD = t62
  Assert $remainingD == 0
  BuildArgs t63 = [print "D: --all cleared the fan-out; remaining=${remainingD}"]
  DispatchCommand argv=t63 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t64 = [print "PROOF complete: fan-out ordering holds for scrambled batch, recursive, dedup, and --all"]
  DispatchCommand argv=t64 policy=def-then-exec-command lane=builtin(print)
  RunDefers policy=program
  Stop

