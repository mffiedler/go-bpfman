body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [bpfman program load file --path testdata/bpf/xdp_pass.bpf.o --programs xdp:pass]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded rc=_ guard=true fail=bb2
  Eval t5 = $loaded.programs[0]
  BindName prog = t5
  BuildArgs t6 = [bpfman program unload $prog]
  RegisterDefer argv=t6 policy=def-then-exec-bind lane=builtin(bpfman)
  Eval t7 = range 10
  ForEachCollect list=t7 names=[_] primary=links rc=_ guard=true body=bb3 exit=bb4

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  BuildArgs t8 = [bpfman link attach xdp -i $pair.host_link $prog]
  DispatchBind t9 = t8 policy=def-then-exec-bind lane=builtin(bpfman)
  CollectProduce t9

bb4:
  BuildArgs t10 = [bpfman link detach $links.[9]]
  RegisterDefer argv=t10 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t11 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t12 = t11 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t12 argv=t11 primary=snap_10 rc=_ guard=true fail=bb5
  Assert ($snap_10 |> jq ".members | length") == 10
  BuildArgs t13 = [bpfman link detach $links.[0]]
  DispatchCommand argv=t13 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t14 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t15 = t14 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t15 argv=t14 primary=snap_9 rc=_ guard=true fail=bb6
  Assert ($snap_9 |> jq ".members | length") == 9
  BuildArgs t16 = [bpfman link detach $links.[1]]
  DispatchCommand argv=t16 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t17 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t18 = t17 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t18 argv=t17 primary=snap_8 rc=_ guard=true fail=bb7
  Assert ($snap_8 |> jq ".members | length") == 8
  BuildArgs t19 = [bpfman link detach $links.[2]]
  DispatchCommand argv=t19 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t20 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t21 argv=t20 primary=snap_7 rc=_ guard=true fail=bb8
  Assert ($snap_7 |> jq ".members | length") == 7
  BuildArgs t22 = [bpfman link detach $links.[3]]
  DispatchCommand argv=t22 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t23 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t24 = t23 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t24 argv=t23 primary=snap_6 rc=_ guard=true fail=bb9
  Assert ($snap_6 |> jq ".members | length") == 6
  BuildArgs t25 = [bpfman link detach $links.[4]]
  DispatchCommand argv=t25 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t26 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t27 = t26 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t27 argv=t26 primary=snap_5 rc=_ guard=true fail=bb10
  Assert ($snap_5 |> jq ".members | length") == 5
  BuildArgs t28 = [bpfman link detach $links.[5]]
  DispatchCommand argv=t28 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t29 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t30 = t29 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t30 argv=t29 primary=snap_4 rc=_ guard=true fail=bb11
  Assert ($snap_4 |> jq ".members | length") == 4
  BuildArgs t31 = [bpfman link detach $links.[6]]
  DispatchCommand argv=t31 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t32 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t33 = t32 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t33 argv=t32 primary=snap_3 rc=_ guard=true fail=bb12
  Assert ($snap_3 |> jq ".members | length") == 3
  BuildArgs t34 = [bpfman link detach $links.[7]]
  DispatchCommand argv=t34 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t35 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t36 = t35 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t36 argv=t35 primary=snap_2 rc=_ guard=true fail=bb13
  Assert ($snap_2 |> jq ".members | length") == 2
  BuildArgs t37 = [bpfman link detach $links.[8]]
  DispatchCommand argv=t37 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t38 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t39 = t38 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t39 argv=t38 primary=snap_1 rc=_ guard=true fail=bb14
  Assert ($snap_1 |> jq ".members | length") == 1
  RunDefers policy=program
  Stop

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

