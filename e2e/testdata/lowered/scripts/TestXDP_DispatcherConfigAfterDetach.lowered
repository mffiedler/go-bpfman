body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [bpfman program load file --path testdata/bpf/xdp_pass.bpf.o --programs xdp:pass]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded rc=_ guard=true fail=bb2
  Eval t5 = $loaded.programs[0]
  BindName prog = t5
  Eval t6 = $prog.record.program_id
  BindName pid = t6
  BuildArgs t7 = [bpfman program unload $pid]
  RegisterDefer argv=t7 policy=def-then-exec-bind lane=builtin(bpfman)
  Eval t8 = range 10
  ForEachCollect list=t8 names=[_] primary=links rc=_ guard=true body=bb3 exit=bb4

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  BuildArgs t9 = [bpfman link attach xdp -i $pair.host_link $pid]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  CollectProduce t10

bb4:
  BuildArgs t11 = [bpfman link detach $links.[9]]
  RegisterDefer argv=t11 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t12 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t13 = t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t13 argv=t12 primary=snap_10 rc=_ guard=true fail=bb5
  Assert ($snap_10 |> jq ".members | length") == 10
  BuildArgs t14 = [bpfman link detach $links.[0]]
  DispatchCommand argv=t14 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t15 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=snap_9 rc=_ guard=true fail=bb6
  Assert ($snap_9 |> jq ".members | length") == 9
  BuildArgs t17 = [bpfman link detach $links.[1]]
  DispatchCommand argv=t17 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t18 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t19 argv=t18 primary=snap_8 rc=_ guard=true fail=bb7
  Assert ($snap_8 |> jq ".members | length") == 8
  BuildArgs t20 = [bpfman link detach $links.[2]]
  DispatchCommand argv=t20 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t21 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t22 argv=t21 primary=snap_7 rc=_ guard=true fail=bb8
  Assert ($snap_7 |> jq ".members | length") == 7
  BuildArgs t23 = [bpfman link detach $links.[3]]
  DispatchCommand argv=t23 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t24 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t25 = t24 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t25 argv=t24 primary=snap_6 rc=_ guard=true fail=bb9
  Assert ($snap_6 |> jq ".members | length") == 6
  BuildArgs t26 = [bpfman link detach $links.[4]]
  DispatchCommand argv=t26 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t27 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t28 = t27 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t28 argv=t27 primary=snap_5 rc=_ guard=true fail=bb10
  Assert ($snap_5 |> jq ".members | length") == 5
  BuildArgs t29 = [bpfman link detach $links.[5]]
  DispatchCommand argv=t29 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t30 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t31 = t30 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t31 argv=t30 primary=snap_4 rc=_ guard=true fail=bb11
  Assert ($snap_4 |> jq ".members | length") == 4
  BuildArgs t32 = [bpfman link detach $links.[6]]
  DispatchCommand argv=t32 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t33 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t34 = t33 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t34 argv=t33 primary=snap_3 rc=_ guard=true fail=bb12
  Assert ($snap_3 |> jq ".members | length") == 3
  BuildArgs t35 = [bpfman link detach $links.[7]]
  DispatchCommand argv=t35 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t36 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t37 = t36 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t37 argv=t36 primary=snap_2 rc=_ guard=true fail=bb13
  Assert ($snap_2 |> jq ".members | length") == 2
  BuildArgs t38 = [bpfman link detach $links.[8]]
  DispatchCommand argv=t38 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t39 = [bpfman dispatcher get xdp $pair.host_nsid $pair.host_ifindex]
  DispatchBind t40 = t39 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t40 argv=t39 primary=snap_1 rc=_ guard=true fail=bb14
  Assert ($snap_1 |> jq ".members | length") == 1
  RunDefers policy=program
  Stop

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError

bb12:
  RunDefers policy=program
  PropagateError

bb13:
  RunDefers policy=program
  PropagateError

bb14:
  RunDefers policy=program
  PropagateError
