def expect_program_load(prog load_tp kernel_tp name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName load_tp = t1
  BindName kernel_tp = t2
  BindName name = t3
  Assert $prog matches { record.load.program_type: $load_tp, status.kernel.program_type: $kernel_tp, record.meta.name: $name, status.kernel.id: $prog.record.program_id, status.kernel.name: not-empty, status.kernel.tag: not-empty, status.kernel.loaded_at: not-empty, record.handles.pin_path: not-empty }
  Eval t4 = not null $prog.record.load.image_source
  Branch cond=t4 true=bb1 false=bb2

bb1:
  EnterFrame kind=if-branch
  Assert $prog.record.load.image_source.url != ""
  Assert $prog.record.load.image_source.digest != ""
  Assert $prog.record.load.image_source.pull_policy == Always
  ExitFrame
  Jump bb3

bb2:
  EnterFrame kind=if-branch
  Assert null $prog.record.load.image_source
  ExitFrame
  Jump bb3

bb3:
  Jump bb4

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_program_round_trip(got prog) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName got = t0
  BindName prog = t1
  Assert $got matches { status.kernel.id: $prog.status.kernel.id, status.kernel.program_type: $prog.status.kernel.program_type, status.kernel.name: $prog.status.kernel.name, status.kernel.tag: $prog.status.kernel.tag, record.meta.name: $prog.record.meta.name, record.handles.pin_path: $prog.record.handles.pin_path }
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def inspect_published_image(image program_name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName image = t0
  BindName program_name = t1
  BuildArgs t2 = [bpfman image inspect $image]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t3 argv=t2 primary=inspected rc=_ guard=true fail=bb1
  Assert $inspected matches { reference: not-empty, digest: not-empty }
  Eval t4 = "if ((.manifests // []) | length) > 0 then [.manifests[] | select(.programs.${program_name} != null)][0] else . end"
  BindName program_filter = t4
  Eval t5 = $inspected |> jq "{inspected: ., manifest: (${program_filter})}"
  BindName bundle = t5
  Assert not null $bundle.manifest
  Assert ($bundle.manifest.layers |> jq "length") >= 1
  Eval t6 = $bundle
  ReturnValue t6 to=bb3

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  Jump bb3

bb3:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_loaded_image_source(prog image inspected) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName image = t1
  BindName inspected = t2
  Assert $prog.record.load.image_source.url == $image
  Eval t3 = $prog.record.load.image_source.digest
  BindName digest = t3
  Eval t4 = $inspected |> jq "if ((.manifests // []) | length) > 0 then [.manifests[].digest | select(. == "${digest}")] | length else if .digest == "${digest}" then 1 else 0 end end"
  BindName matches = t4
  Assert $matches == 1
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def await_wave_completion(ack n) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName ack = t0
  BindName n = t1
  Eval t2 = path-exists "${ack}.${n}"
  Branch cond=t2 true=bb1 false=bb2

bb1:
  Jump bb4

bb2:
  Eval t3 = "waiting for ack.${n}"
  RunDefers policy=attempt-fatal
  ExitFrame
  RetryPoll message=t3

bb3:

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def assert_link_absent(listed linkID) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName listed = t0
  BindName linkID = t1
  Eval t2 = $listed |> jq "[.links[] | select(.id == ${linkID})] | length"
  BindName count = t2
  Assert $count == 0
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

body entry=bb0

bb0:
  EnterDeferScope kind=program
  Eval t0 = "quay.io/bpfman-bytecode/go-tcx-counter"
  BindName image = t0
  BuildArgs t1 = [inspect_published_image $image tcx_stats]
  DispatchBind t2 = t1 policy=def-then-exec-bind lane=def(inspect_published_image)
  ApplyBind src=t2 argv=t1 primary=published rc=_ guard=true fail=bb1
  Assert $published.manifest.programs.tcx_stats == tc
  Assert $published.manifest.maps.tcx_stats_map == per_cpu_array
  BuildArgs t3 = [net veth-pair]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t4 argv=t3 primary=pair rc=_ guard=true fail=bb2
  BuildArgs t5 = [net release $pair]
  RegisterDefer argv=t5 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t6 = [bpfman program load image --image-url $image --pull-policy Always --programs tcx:tcx_stats]
  DispatchBind t7 = t6 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t7 argv=t6 primary=loaded rc=_ guard=true fail=bb3
  Eval t8 = $loaded.programs[0]
  BindName prog = t8
  Eval t9 = $prog.record.program_id
  BindName pid = t9
  BuildArgs t10 = [bpfman program unload $pid]
  RegisterDefer argv=t10 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t11 = [expect_program_load $prog tcx schedcls tcx_stats]
  DispatchCommand argv=t11 policy=def-then-exec-command lane=def(expect_program_load)
  BuildArgs t12 = [expect_loaded_image_source $prog $image $published.inspected]
  DispatchCommand argv=t12 policy=def-then-exec-command lane=def(expect_loaded_image_source)
  BuildArgs t13 = [bpfman link attach tcx --iface $pair.host_link --direction ingress --priority 50 $prog]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t14 argv=t13 primary=link rc=_ guard=true fail=bb4
  Eval t15 = $link.record.id
  BindName linkID = t15
  Assert $link.record.kind == tcx
  Assert $link.record.program_id == $pid
  Assert $link.record.details.interface == $pair.host_link
  Assert $link.record.details.direction == ingress
  Assert $link.record.details.priority == 50
  Assert $link.status.kernel_seen
  Eval t16 = $prog.status.maps[0].id
  BindName mapID = t16
  Eval t17 = "fromjson | [.[].formatted.values[].value.rx_packets | tonumber] | add"
  BindName sumFilter = t17
  BuildArgs t18 = [bpftool map dump id $mapID -j]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=exec
  ApplyBind src=t19 argv=t18 primary=dumpBefore rc=_ guard=true fail=bb5
  Eval t20 = $dumpBefore.stdout |> jq $sumFilter
  BindName before = t20
  BuildArgs t21 = [net exec $pair ping -c 5 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t22 argv=t21 primary=_ rc=_ guard=true fail=bb6
  BuildArgs t23 = [bpftool map dump id $mapID -j]
  DispatchBind t24 = t23 policy=def-then-exec-bind lane=exec
  ApplyBind src=t24 argv=t23 primary=dumpAfter rc=_ guard=true fail=bb7
  Eval t25 = $dumpAfter.stdout |> jq $sumFilter
  BindName after = t25
  Eval t26 = $after - $before
  BindName delta = t26
  BuildArgs t27 = [print "published tcx image: packets=${delta}"]
  DispatchCommand argv=t27 policy=def-then-exec-command lane=builtin(print)
  Assert $delta >= 5
  BuildArgs t28 = [bpfman link detach $link]
  DispatchCommand argv=t28 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t29 = [sleep 0.1]
  DispatchCommand argv=t29 policy=def-then-exec-command lane=exec
  BuildArgs t30 = [bpftool map dump id $mapID -j]
  DispatchBind t31 = t30 policy=def-then-exec-bind lane=exec
  ApplyBind src=t31 argv=t30 primary=dumpDetached rc=_ guard=true fail=bb8
  Eval t32 = $dumpDetached.stdout |> jq $sumFilter
  BindName detached = t32
  BuildArgs t33 = [net exec $pair ping -c 5 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t34 = t33 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t34 argv=t33 primary=_ rc=_ guard=true fail=bb9
  BuildArgs t35 = [bpftool map dump id $mapID -j]
  DispatchBind t36 = t35 policy=def-then-exec-bind lane=exec
  ApplyBind src=t36 argv=t35 primary=dumpAfterDetach rc=_ guard=true fail=bb10
  Eval t37 = $dumpAfterDetach.stdout |> jq $sumFilter
  BindName afterDetach = t37
  BuildArgs t38 = [print "published tcx image after-detach=${afterDetach} want=${detached}"]
  DispatchCommand argv=t38 policy=def-then-exec-command lane=builtin(print)
  Assert $afterDetach == $detached
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError
