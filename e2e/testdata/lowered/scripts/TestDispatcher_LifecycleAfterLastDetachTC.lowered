body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded rc=_ guard=true fail=bb2
  Eval t5 = $loaded.programs[0]
  BindName prog = t5
  BuildArgs t6 = [bpfman program unload $prog]
  RegisterDefer argv=t6 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t7 = [bpfman link attach tc -i $pair.host_link -d ingress -p 100 $prog]
  DispatchBind t8 = t7 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t8 argv=t7 primary=l1 rc=_ guard=true fail=bb3
  BuildArgs t9 = [bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t10 argv=t9 primary=snap1 rc=_ guard=true fail=bb4
  Eval t11 = $snap1 |> jq ".members | length"
  BindName members1 = t11
  Assert $members1 == 1
  Eval t12 = $snap1.runtime.program_id
  BindName dispatcher_pid_1 = t12
  BuildArgs t13 = [bpfman link detach $l1]
  DispatchCommand argv=t13 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex
  BuildArgs t14 = [bpfman link attach tc -i $pair.host_link -d ingress -p 200 $prog]
  DispatchBind t15 = t14 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t15 argv=t14 primary=l2 rc=_ guard=true fail=bb5
  BuildArgs t16 = [bpfman link detach $l2]
  RegisterDefer argv=t16 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t17 = [bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex]
  DispatchBind t18 = t17 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t18 argv=t17 primary=snap2 rc=_ guard=true fail=bb6
  Eval t19 = $snap2 |> jq ".members | length"
  BindName members2 = t19
  Assert $members2 == 1
  Assert $snap2.runtime.program_id != $dispatcher_pid_1
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError
