body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded rc=_ guard=true fail=bb2
  Eval t5 = $loaded.programs[0]
  BindName prog = t5
  Eval t6 = $prog.record.program_id
  BindName pid = t6
  BuildArgs t7 = [bpfman program unload $pid]
  RegisterDefer argv=t7 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t8 = [bpfman link attach tc -i $pair.host_link -d ingress -p 100 $pid]
  DispatchBind t9 = t8 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t9 argv=t8 primary=l1 rc=_ guard=true fail=bb3
  BuildArgs t10 = [bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex]
  DispatchBind t11 = t10 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t11 argv=t10 primary=snap1 rc=_ guard=true fail=bb4
  Eval t12 = $snap1 |> jq ".members | length"
  BindName members1 = t12
  Assert $members1 == 1
  Eval t13 = $snap1.runtime.program_id
  BindName dispatcher_pid_1 = t13
  BuildArgs t14 = [bpfman link detach $l1]
  DispatchCommand argv=t14 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex
  BuildArgs t15 = [bpfman link attach tc -i $pair.host_link -d ingress -p 200 $pid]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=l2 rc=_ guard=true fail=bb5
  BuildArgs t17 = [bpfman link detach $l2]
  RegisterDefer argv=t17 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t18 = [bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex]
  DispatchBind t19 = t18 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t19 argv=t18 primary=snap2 rc=_ guard=true fail=bb6
  Eval t20 = $snap2 |> jq ".members | length"
  BindName members2 = t20
  Assert $members2 == 1
  Assert $snap2.runtime.program_id != $dispatcher_pid_1
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError
