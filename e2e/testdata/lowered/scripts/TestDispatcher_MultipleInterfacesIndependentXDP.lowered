body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair_a rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair_a]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [net veth-pair]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t4 argv=t3 primary=pair_b rc=_ guard=true fail=bb2
  BuildArgs t5 = [net release $pair_b]
  RegisterDefer argv=t5 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t6 = [bpfman program load file --path testdata/bpf/xdp_counter.bpf.o --programs xdp:xdp_stats]
  DispatchBind t7 = t6 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t7 argv=t6 primary=loaded rc=_ guard=true fail=bb3
  Eval t8 = $loaded.programs[0]
  BindName prog = t8
  BuildArgs t9 = [bpfman program unload $prog]
  RegisterDefer argv=t9 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t10 = [bpfman link attach xdp -i $pair_a.host_link -p 100 $prog]
  DispatchBind t11 = t10 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t11 argv=t10 primary=a_100 rc=_ guard=true fail=bb4
  BuildArgs t12 = [bpfman link attach xdp -i $pair_a.host_link -p 200 $prog]
  DispatchBind t13 = t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t13 argv=t12 primary=a_200 rc=_ guard=true fail=bb5
  BuildArgs t14 = [bpfman link attach xdp -i $pair_a.host_link -p 300 $prog]
  DispatchBind t15 = t14 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t15 argv=t14 primary=a_300 rc=_ guard=true fail=bb6
  BuildArgs t16 = [bpfman link detach $a_100]
  RegisterDefer argv=t16 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t17 = [bpfman link detach $a_200]
  RegisterDefer argv=t17 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t18 = [bpfman link detach $a_300]
  RegisterDefer argv=t18 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t19 = [bpfman link attach xdp -i $pair_b.host_link -p 100 $prog]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t20 argv=t19 primary=b_100 rc=_ guard=true fail=bb7
  BuildArgs t21 = [bpfman link attach xdp -i $pair_b.host_link -p 200 $prog]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t22 argv=t21 primary=b_200 rc=_ guard=true fail=bb8
  BuildArgs t23 = [bpfman dispatcher get xdp $pair_a.host_nsid $pair_a.host_ifindex]
  DispatchBind t24 = t23 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t24 argv=t23 primary=snap_a rc=_ guard=true fail=bb9
  Eval t25 = $snap_a |> jq ".members | length"
  BindName count_a = t25
  Assert $count_a == 3
  BuildArgs t26 = [bpfman dispatcher get xdp $pair_b.host_nsid $pair_b.host_ifindex]
  DispatchBind t27 = t26 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t27 argv=t26 primary=snap_b rc=_ guard=true fail=bb10
  Eval t28 = $snap_b |> jq ".members | length"
  BindName count_b = t28
  Assert $count_b == 2
  BuildArgs t29 = [bpfman link detach $b_100]
  DispatchCommand argv=t29 policy=def-then-exec-command lane=builtin(bpfman)
  BuildArgs t30 = [bpfman link detach $b_200]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman dispatcher get xdp $pair_b.host_nsid $pair_b.host_ifindex
  BuildArgs t31 = [bpfman dispatcher get xdp $pair_a.host_nsid $pair_a.host_ifindex]
  DispatchBind t32 = t31 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t32 argv=t31 primary=snap_a_after rc=_ guard=true fail=bb11
  Eval t33 = $snap_a_after |> jq ".members | length"
  BindName count_a_after = t33
  Assert $count_a_after == 3
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError
