def expect_program_load(prog load_tp kernel_tp name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName load_tp = t1
  BindName kernel_tp = t2
  BindName name = t3
  Assert $prog matches { record.load.program_type: $load_tp, status.kernel.program_type: $kernel_tp, record.meta.name: $name, status.kernel.id: $prog.record.program_id, status.kernel.name: not-empty, status.kernel.tag: not-empty, status.kernel.loaded_at: not-empty, record.handles.pin_path: not-empty }
  Eval t4 = not null $prog.record.load.image_source
  Branch cond=t4 true=bb1 false=bb2

bb1:
  EnterFrame kind=if-branch
  Assert $prog.record.load.image_source.url != ""
  Assert $prog.record.load.image_source.digest != ""
  Assert $prog.record.load.image_source.pull_policy == Always
  ExitFrame
  Jump bb3

bb2:
  EnterFrame kind=if-branch
  Assert null $prog.record.load.image_source
  ExitFrame
  Jump bb3

bb3:
  Jump bb4

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_program_round_trip(got prog) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName got = t0
  BindName prog = t1
  Assert $got matches { status.kernel.id: $prog.status.kernel.id, status.kernel.program_type: $prog.status.kernel.program_type, status.kernel.name: $prog.status.kernel.name, status.kernel.tag: $prog.status.kernel.tag, record.meta.name: $prog.record.meta.name, record.handles.pin_path: $prog.record.handles.pin_path }
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def inspect_published_image(image program_name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName image = t0
  BindName program_name = t1
  BuildArgs t2 = [bpfman image inspect $image]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t3 argv=t2 primary=inspected rc=_ guard=true fail=bb1
  Assert $inspected matches { reference: not-empty, digest: not-empty }
  Eval t4 = "if ((.manifests // []) | length) > 0 then [.manifests[] | select(.programs.${program_name} != null)][0] else . end"
  BindName program_filter = t4
  Eval t5 = $inspected |> jq "{inspected: ., manifest: (${program_filter})}"
  BindName bundle = t5
  Assert not null $bundle.manifest
  Assert ($bundle.manifest.layers |> jq "length") >= 1
  Eval t6 = $bundle
  ReturnValue t6 to=bb3

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  Jump bb3

bb3:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_loaded_image_source(prog image inspected) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName image = t1
  BindName inspected = t2
  Assert $prog.record.load.image_source.url == $image
  Eval t3 = $prog.record.load.image_source.digest
  BindName digest = t3
  Eval t4 = $inspected |> jq "if ((.manifests // []) | length) > 0 then [.manifests[].digest | select(. == "${digest}")] | length else if .digest == "${digest}" then 1 else 0 end end"
  BindName matches = t4
  Assert $matches == 1
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def await_wave_completion(ack n) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName ack = t0
  BindName n = t1
  Eval t2 = path-exists "${ack}.${n}"
  Branch cond=t2 true=bb1 false=bb2

bb1:
  Jump bb4

bb2:
  Eval t3 = "waiting for ack.${n}"
  RunDefers policy=attempt-fatal
  ExitFrame
  RetryPoll message=t3

bb3:

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def assert_link_absent(listed linkID) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName listed = t0
  BindName linkID = t1
  Eval t2 = $listed |> jq "[.links[] | select(.id == ${linkID})] | length"
  BindName count = t2
  Assert $count == 0
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [net veth-pair]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t1 argv=t0 primary=pair rc=_ guard=true fail=bb1
  BuildArgs t2 = [net release $pair]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t3 = [bpfman program load file --path testdata/bpf/tc_counter.bpf.o --programs tc:stats]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t4 argv=t3 primary=loaded rc=_ guard=true fail=bb2
  Eval t5 = $loaded.programs[0]
  BindName prog = t5
  Eval t6 = $prog.record.program_id
  BindName pid = t6
  BuildArgs t7 = [bpfman program unload $pid]
  RegisterDefer argv=t7 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t8 = [bpfman link attach tc --iface $pair.host_link --direction ingress --priority 50 $prog]
  DispatchBind t9 = t8 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t9 argv=t8 primary=link rc=_ guard=true fail=bb3
  Eval t10 = $link.record.id
  BindName linkID = t10
  Assert $link.record.kind == tc
  Assert $link.record.program_id == $pid
  Assert $link.record.details.interface == $pair.host_link
  Assert $link.record.details.direction == ingress
  Assert $link.record.details.priority == 50
  Assert $link.record.details.dispatcher_id > 0
  Assert $link.record.details.revision > 0
  Assert $link.status.kernel_seen
  BuildArgs t11 = [bpfman link get $linkID]
  DispatchBind t12 = t11 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t12 argv=t11 primary=gotLink rc=_ guard=true fail=bb4
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == tc
  Assert $gotLink.record.program_id == $pid
  Assert $gotLink.record.details.interface == $pair.host_link
  Assert $gotLink.record.details.direction == ingress
  Assert $gotLink.record.details.priority == 50
  Assert $gotLink.record.details.dispatcher_id == $link.record.details.dispatcher_id
  BuildArgs t13 = [tc filter show dev $pair.host_link ingress]
  DispatchBind t14 = t13 policy=def-then-exec-bind lane=exec
  ApplyBind src=t14 argv=t13 primary=_ rc=_ guard=true fail=bb5
  BuildArgs t15 = [bpfman link list -o json]
  DispatchBind t16 = t15 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t16 argv=t15 primary=listed rc=_ guard=true fail=bb6
  Eval t17 = $listed |> jq ".links[] | select(.id == ${linkID})"
  BindName ourLink = t17
  Require not null ourLink
  Assert $ourLink.id == $linkID
  Assert $ourLink.kind == tc
  Eval t18 = $prog.status.maps[0].id
  BindName mapID = t18
  Eval t19 = "fromjson | [.[] | select(.formatted.key == 0) | .formatted.values[].value.rx_packets] | add"
  BindName sumFilter = t19
  BuildArgs t20 = [bpftool map dump id $mapID -j]
  DispatchBind t21 = t20 policy=def-then-exec-bind lane=exec
  ApplyBind src=t21 argv=t20 primary=dumpBefore rc=_ guard=true fail=bb7
  Eval t22 = $dumpBefore.stdout |> jq $sumFilter
  BindName before = t22
  BuildArgs t23 = [net exec $pair ping -c 5 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t24 = t23 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t24 argv=t23 primary=_ rc=_ guard=true fail=bb8
  BuildArgs t25 = [bpftool map dump id $mapID -j]
  DispatchBind t26 = t25 policy=def-then-exec-bind lane=exec
  ApplyBind src=t26 argv=t25 primary=dumpAfter rc=_ guard=true fail=bb9
  Eval t27 = $dumpAfter.stdout |> jq $sumFilter
  BindName after = t27
  Eval t28 = $after - $before
  BindName delta = t28
  BuildArgs t29 = [print "tc count: before=${before} after=${after} delta=${delta}"]
  DispatchCommand argv=t29 policy=def-then-exec-command lane=builtin(print)
  Assert $delta >= 5
  BuildArgs t30 = [bpfman link detach $link]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t31 = [bpfman link list -o json]
  DispatchBind t32 = t31 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t32 argv=t31 primary=listedAfter rc=_ guard=true fail=bb10
  BuildArgs t33 = [assert_link_absent $listedAfter $linkID]
  DispatchCommand argv=t33 policy=def-then-exec-command lane=def(assert_link_absent)
  BuildArgs t34 = [sleep 0.1]
  DispatchCommand argv=t34 policy=def-then-exec-command lane=exec
  BuildArgs t35 = [bpftool map dump id $mapID -j]
  DispatchBind t36 = t35 policy=def-then-exec-bind lane=exec
  ApplyBind src=t36 argv=t35 primary=dumpDetached rc=_ guard=true fail=bb11
  Eval t37 = $dumpDetached.stdout |> jq $sumFilter
  BindName detached = t37
  BuildArgs t38 = [net exec $pair ping -c 5 -i 0.05 -W 1 $pair.host_addr]
  DispatchBind t39 = t38 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t39 argv=t38 primary=_ rc=_ guard=true fail=bb12
  BuildArgs t40 = [bpftool map dump id $mapID -j]
  DispatchBind t41 = t40 policy=def-then-exec-bind lane=exec
  ApplyBind src=t41 argv=t40 primary=dumpAfterDetach rc=_ guard=true fail=bb13
  Eval t42 = $dumpAfterDetach.stdout |> jq $sumFilter
  BindName afterDetach = t42
  BuildArgs t43 = [print "tc after-detach=${afterDetach} want=${detached}"]
  DispatchCommand argv=t43 policy=def-then-exec-command lane=builtin(print)
  Assert $afterDetach == $detached
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

