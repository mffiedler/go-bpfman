def expect_program_load(prog load_tp kernel_tp name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName load_tp = t1
  BindName kernel_tp = t2
  BindName name = t3
  Assert $prog matches { record.load.program_type: $load_tp, status.kernel.program_type: $kernel_tp, record.meta.name: $name, status.kernel.id: $prog.record.program_id, status.kernel.name: not-empty, status.kernel.tag: not-empty, status.kernel.loaded_at: not-empty, record.handles.pin_path: not-empty }
  Eval t4 = not null $prog.record.load.image_source
  Branch cond=t4 true=bb1 false=bb2

bb1:
  EnterFrame kind=if-branch
  Assert $prog.record.load.image_source.url != ""
  Assert $prog.record.load.image_source.digest != ""
  Assert $prog.record.load.image_source.pull_policy == Always
  ExitFrame
  Jump bb3

bb2:
  EnterFrame kind=if-branch
  Assert null $prog.record.load.image_source
  ExitFrame
  Jump bb3

bb3:
  Jump bb4

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_program_round_trip(got prog) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName got = t0
  BindName prog = t1
  Assert $got matches { status.kernel.id: $prog.status.kernel.id, status.kernel.program_type: $prog.status.kernel.program_type, status.kernel.name: $prog.status.kernel.name, status.kernel.tag: $prog.status.kernel.tag, record.meta.name: $prog.record.meta.name, record.handles.pin_path: $prog.record.handles.pin_path }
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def inspect_published_image(image program_name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName image = t0
  BindName program_name = t1
  BuildArgs t2 = [bpfman image inspect $image]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t3 argv=t2 primary=inspected rc=_ guard=true fail=bb1
  Assert $inspected matches { reference: not-empty, digest: not-empty }
  Eval t4 = "if ((.manifests // []) | length) > 0 then [.manifests[] | select(.programs.${program_name} != null)][0] else . end"
  BindName program_filter = t4
  Eval t5 = $inspected |> jq "{inspected: ., manifest: (${program_filter})}"
  BindName bundle = t5
  Assert not null $bundle.manifest
  Assert ($bundle.manifest.layers |> jq "length") >= 1
  Eval t6 = $bundle
  ReturnValue t6 to=bb3

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  Jump bb3

bb3:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_loaded_image_source(prog image inspected) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName image = t1
  BindName inspected = t2
  Assert $prog.record.load.image_source.url == $image
  Eval t3 = $prog.record.load.image_source.digest
  BindName digest = t3
  Eval t4 = $inspected |> jq "if ((.manifests // []) | length) > 0 then [.manifests[].digest | select(. == "${digest}")] | length else if .digest == "${digest}" then 1 else 0 end end"
  BindName matches = t4
  Assert $matches == 1
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def await_wave_completion(ack n) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName ack = t0
  BindName n = t1
  Eval t2 = path-exists "${ack}.${n}"
  Branch cond=t2 true=bb1 false=bb2

bb1:
  Jump bb4

bb2:
  Eval t3 = "waiting for ack.${n}"
  RunDefers policy=attempt-fatal
  ExitFrame
  RetryPoll message=t3

bb3:

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def assert_link_absent(listed linkID) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName listed = t0
  BindName linkID = t1
  Eval t2 = $listed |> jq "[.links[] | select(.id == ${linkID})] | length"
  BindName count = t2
  Assert $count == 0
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

body entry=bb0

bb0:
  EnterDeferScope kind=program
  Eval t0 = 5
  BindName events = t0
  Eval t1 = 1
  BindName weight = t1
  Eval t2 = $events * $weight
  BindName want = t2
  BuildArgs t3 = [kfunc acquire]
  DispatchBind t4 = t3 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t4 argv=t3 primary=fn rc=_ guard=true fail=bb1
  BuildArgs t5 = [kfunc release $fn]
  RegisterDefer argv=t5 policy=def-then-exec-bind lane=builtin(kfunc)
  BuildArgs t6 = [bpfman program load file --path testdata/bpf/fexit_kmod_exact.bpf.o --programs "fexit:test_fexit:${fn.name}" -g "weight=0x${u64le $weight}"]
  DispatchBind t7 = t6 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t7 argv=t6 primary=loaded rc=_ guard=true fail=bb2
  Eval t8 = $loaded.programs[0]
  BindName prog = t8
  Eval t9 = $prog.record.program_id
  BindName pid = t9
  BuildArgs t10 = [expect_program_load $prog fexit tracing test_fexit]
  DispatchCommand argv=t10 policy=def-then-exec-command lane=def(expect_program_load)
  BuildArgs t11 = [bpfman link attach fexit $prog]
  DispatchBind t12 = t11 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t12 argv=t11 primary=link rc=_ guard=true fail=bb3
  Eval t13 = $link.record.id
  BindName linkID = t13
  Assert $link.record.kind == fexit
  Assert $link.record.program_id == $pid
  Assert $link.record.details.fn_name == $fn.name
  Assert $link.status.kernel_seen
  BuildArgs t14 = [bpfman link get $linkID]
  DispatchBind t15 = t14 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t15 argv=t14 primary=gotLink rc=_ guard=true fail=bb4
  Assert $gotLink.record.id == $linkID
  Assert $gotLink.record.kind == fexit
  Assert $gotLink.record.program_id == $pid
  Assert $gotLink.record.details.fn_name == $fn.name
  BuildArgs t16 = [bpfman link list -o json]
  DispatchBind t17 = t16 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t17 argv=t16 primary=listed rc=_ guard=true fail=bb5
  Eval t18 = $listed |> jq ".links[] | select(.id == ${linkID})"
  BindName ourLink = t18
  Require not null ourLink
  Assert $ourLink.id == $linkID
  Assert $ourLink.kind == fexit
  BuildArgs t19 = [kfunc fire $fn $events]
  DispatchBind t20 = t19 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t20 argv=t19 primary=fired rc=_ guard=true fail=bb6
  Assert $fired.ok
  Eval t21 = $prog.status.maps[0].id
  BindName mapID = t21
  Eval t22 = "fromjson | .[0].formatted.value | tonumber"
  BindName counterFilter = t22
  BuildArgs t23 = [bpftool map dump id $mapID -j]
  DispatchBind t24 = t23 policy=def-then-exec-bind lane=exec
  ApplyBind src=t24 argv=t23 primary=dump rc=_ guard=true fail=bb7
  Eval t25 = $dump.stdout |> jq $counterFilter
  BindName got = t25
  BuildArgs t26 = [print "kfunc=${fn.name} got=${got} want=${want}"]
  DispatchCommand argv=t26 policy=def-then-exec-command lane=builtin(print)
  Assert $got == $want
  BuildArgs t27 = [bpfman link detach $link]
  DispatchCommand argv=t27 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t28 = [bpfman link list -o json]
  DispatchBind t29 = t28 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t29 argv=t28 primary=listedAfter rc=_ guard=true fail=bb8
  BuildArgs t30 = [assert_link_absent $listedAfter $linkID]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=def(assert_link_absent)
  BuildArgs t31 = [sleep 0.1]
  DispatchCommand argv=t31 policy=def-then-exec-command lane=exec
  BuildArgs t32 = [bpftool map dump id $mapID -j]
  DispatchBind t33 = t32 policy=def-then-exec-bind lane=exec
  ApplyBind src=t33 argv=t32 primary=dumpDetached rc=_ guard=true fail=bb9
  Eval t34 = $dumpDetached.stdout |> jq $counterFilter
  BindName detached = t34
  BuildArgs t35 = [kfunc fire $fn $events]
  DispatchBind t36 = t35 policy=def-then-exec-bind lane=builtin(kfunc)
  ApplyBind src=t36 argv=t35 primary=_ rc=_ guard=true fail=bb10
  BuildArgs t37 = [bpftool map dump id $mapID -j]
  DispatchBind t38 = t37 policy=def-then-exec-bind lane=exec
  ApplyBind src=t38 argv=t37 primary=dumpAfterDetach rc=_ guard=true fail=bb11
  Eval t39 = $dumpAfterDetach.stdout |> jq $counterFilter
  BindName afterDetach = t39
  BuildArgs t40 = [print "kfunc=${fn.name} after-detach=${afterDetach} want=${detached}"]
  DispatchCommand argv=t40 policy=def-then-exec-command lane=builtin(print)
  Assert $afterDetach == $detached
  BuildArgs t41 = [bpfman program unload $pid]
  DispatchCommand argv=t41 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman program get $prog
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError

bb3:
  RunDefers policy=program
  PropagateError

bb4:
  RunDefers policy=program
  PropagateError

bb5:
  RunDefers policy=program
  PropagateError

bb6:
  RunDefers policy=program
  PropagateError

bb7:
  RunDefers policy=program
  PropagateError

bb8:
  RunDefers policy=program
  PropagateError

bb9:
  RunDefers policy=program
  PropagateError

bb10:
  RunDefers policy=program
  PropagateError

bb11:
  RunDefers policy=program
  PropagateError
