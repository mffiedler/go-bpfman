def expect_program_load(prog load_tp kernel_tp name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName load_tp = t1
  BindName kernel_tp = t2
  BindName name = t3
  Assert $prog matches { record.load.program_type: $load_tp, status.kernel.program_type: $kernel_tp, record.meta.name: $name, status.kernel.id: $prog.record.program_id, status.kernel.name: not-empty, status.kernel.tag: not-empty, status.kernel.loaded_at: not-empty, record.handles.pin_path: not-empty }
  Eval t4 = not null $prog.record.load.image_source
  Branch cond=t4 true=bb1 false=bb2

bb1:
  EnterFrame kind=if-branch
  Assert $prog.record.load.image_source.url != ""
  Assert $prog.record.load.image_source.digest != ""
  Assert $prog.record.load.image_source.pull_policy == Always
  ExitFrame
  Jump bb3

bb2:
  EnterFrame kind=if-branch
  Assert null $prog.record.load.image_source
  ExitFrame
  Jump bb3

bb3:
  Jump bb4

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_program_round_trip(got prog) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName got = t0
  BindName prog = t1
  Assert $got matches { status.kernel.id: $prog.status.kernel.id, status.kernel.program_type: $prog.status.kernel.program_type, status.kernel.name: $prog.status.kernel.name, status.kernel.tag: $prog.status.kernel.tag, record.meta.name: $prog.record.meta.name, record.handles.pin_path: $prog.record.handles.pin_path }
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def inspect_published_image(image program_name) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName image = t0
  BindName program_name = t1
  BuildArgs t2 = [bpfman image inspect $image]
  DispatchBind t3 = t2 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t3 argv=t2 primary=inspected rc=_ guard=true fail=bb1
  Assert $inspected matches { reference: not-empty, digest: not-empty }
  Eval t4 = "if ((.manifests // []) | length) > 0 then [.manifests[] | select(.programs.${program_name} != null)][0] else . end"
  BindName program_filter = t4
  Eval t5 = $inspected |> jq "{inspected: ., manifest: (${program_filter})}"
  BindName bundle = t5
  Assert not null $bundle.manifest
  Assert ($bundle.manifest.layers |> jq "length") >= 1
  Eval t6 = $bundle
  ReturnValue t6 to=bb3

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  Jump bb3

bb3:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def expect_loaded_image_source(prog image inspected) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName prog = t0
  BindName image = t1
  BindName inspected = t2
  Assert $prog.record.load.image_source.url == $image
  Eval t3 = $prog.record.load.image_source.digest
  BindName digest = t3
  Eval t4 = $inspected |> jq "if ((.manifests // []) | length) > 0 then [.manifests[].digest | select(. == "${digest}")] | length else if .digest == "${digest}" then 1 else 0 end end"
  BindName matches = t4
  Assert $matches == 1
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def await_wave_completion(ack n) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName ack = t0
  BindName n = t1
  Eval t2 = path-exists "${ack}.${n}"
  Branch cond=t2 true=bb1 false=bb2

bb1:
  Jump bb4

bb2:
  Eval t3 = "waiting for ack.${n}"
  RunDefers policy=attempt-fatal
  ExitFrame
  RetryPoll message=t3

bb3:

bb4:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def assert_link_absent(listed linkID) entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BindName listed = t0
  BindName linkID = t1
  Eval t2 = $listed |> jq "[.links[] | select(.id == ${linkID})] | length"
  BindName count = t2
  Assert $count == 0
  Jump bb1

bb1:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

def main() entry=bb0

bb0:
  EnterFrame kind=def
  EnterDeferScope kind=def
  BuildArgs t0 = [registry ref explicit-xdp-pass]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(registry)
  ApplyBind src=t1 argv=t0 primary=image rc=_ guard=false
  BuildArgs t2 = [print "image-build: minted image=${image}"]
  DispatchCommand argv=t2 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t3 = [print "image-build: publishing ${image}"]
  DispatchCommand argv=t3 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t4 = [bpfman image build $image testdata/bpf/xdp_pass.bpf.o]
  DispatchBind t5 = t4 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t5 argv=t4 primary=build rc=_ guard=true fail=bb1
  BuildArgs t6 = [print "image-build: published ${image}"]
  DispatchCommand argv=t6 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t7 = [print "image-build: inspecting ${image}"]
  DispatchCommand argv=t7 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t8 = [bpfman image inspect $image]
  DispatchBind t9 = t8 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t9 argv=t8 primary=inspected rc=_ guard=true fail=bb2
  BuildArgs t10 = [print "image-build: inspected reference=${inspected.reference} digest=${inspected.digest}"]
  DispatchCommand argv=t10 policy=def-then-exec-command lane=builtin(print)
  Assert $inspected.digest != ""
  BuildArgs t11 = [print "image-build: loading ${image}"]
  DispatchCommand argv=t11 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t12 = [bpfman program load image --image-url $image --pull-policy Always --programs xdp:pass]
  DispatchBind t13 = t12 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t13 argv=t12 primary=loaded rc=_ guard=true fail=bb3
  Eval t14 = $loaded.programs[0]
  BindName prog = t14
  Eval t15 = $prog.record.program_id
  BindName pid = t15
  BuildArgs t16 = [print "image-build: unloaded program pid=${pid}"]
  RegisterDefer argv=t16 policy=def-then-exec-bind lane=builtin(print)
  BuildArgs t17 = [bpfman program unload $pid]
  RegisterDefer argv=t17 policy=def-then-exec-bind lane=builtin(bpfman)
  BuildArgs t18 = [print "image-build: loaded program pid=${pid} source=${prog.record.load.image_source.url}"]
  DispatchCommand argv=t18 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t19 = [expect_program_load $prog xdp extension pass]
  DispatchCommand argv=t19 policy=def-then-exec-command lane=def(expect_program_load)
  Assert $prog.record.load.image_source.url == $inspected.reference
  Assert $prog.record.load.image_source.digest == $inspected.digest
  BuildArgs t20 = [print "image-build: creating veth pair"]
  DispatchCommand argv=t20 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t21 = [net veth-pair]
  DispatchBind t22 = t21 policy=def-then-exec-bind lane=builtin(net)
  ApplyBind src=t22 argv=t21 primary=pair rc=_ guard=true fail=bb4
  BuildArgs t23 = [print "image-build: released veth host=${pair.host_link}"]
  RegisterDefer argv=t23 policy=def-then-exec-bind lane=builtin(print)
  BuildArgs t24 = [net release $pair]
  RegisterDefer argv=t24 policy=def-then-exec-bind lane=builtin(net)
  BuildArgs t25 = [print "image-build: veth host=${pair.host_link} peer=${pair.peer_link}"]
  DispatchCommand argv=t25 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t26 = [print "image-build: attaching xdp pid=${pid} iface=${pair.host_link}"]
  DispatchCommand argv=t26 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t27 = [bpfman link attach xdp --iface $pair.host_link $prog]
  DispatchBind t28 = t27 policy=def-then-exec-bind lane=builtin(bpfman)
  ApplyBind src=t28 argv=t27 primary=link rc=_ guard=true fail=bb5
  Eval t29 = $link.record.id
  BindName linkID = t29
  BuildArgs t30 = [print "image-build: attached link=${linkID}"]
  DispatchCommand argv=t30 policy=def-then-exec-command lane=builtin(print)
  Assert $link.record.kind == xdp
  Assert $link.record.program_id == $pid
  Assert $link.status.kernel_seen
  BuildArgs t31 = [print "image-build: detaching link=${linkID}"]
  DispatchCommand argv=t31 policy=def-then-exec-command lane=builtin(print)
  BuildArgs t32 = [bpfman link detach $link]
  DispatchCommand argv=t32 policy=def-then-exec-command lane=builtin(bpfman)
  Assert fail bpfman link get $linkID
  BuildArgs t33 = [print "image-build: detached link=${linkID}"]
  DispatchCommand argv=t33 policy=def-then-exec-command lane=builtin(print)
  Jump bb6

bb1:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb2:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb3:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb4:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb5:
  RunDefers policy=def-local
  ExitFrame
  PropagateError

bb6:
  RunDefers policy=def-local
  ExitFrame
  EmitBindResult rc=synthetic primary=nil

body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [main]
  DispatchCommand argv=t0 policy=def-then-exec-command lane=def(main)
  RunDefers policy=program
