body entry=bb0

bb0:
  EnterDeferScope kind=program
  BuildArgs t0 = [tempdir image-build-cilium]
  DispatchBind t1 = t0 policy=def-then-exec-bind lane=builtin(tempdir)
  ApplyBind src=t1 argv=t0 primary=dir rc=_ guard=false
  BuildArgs t2 = [exec rm -rf $dir.path]
  RegisterDefer argv=t2 policy=def-then-exec-bind lane=builtin(exec)
  Eval t3 = "${dir.path}/bpf_x86_bpfel.o"
  BindName amd64 = t3
  Eval t4 = "${dir.path}/bpf_arm64_bpfel.o"
  BindName arm64 = t4
  BuildArgs t5 = [exec cp testdata/bpf/xdp_pass.bpf.o $amd64]
  DispatchBind t6 = t5 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t6 argv=t5 primary=_ rc=_ guard=true fail=bb1
  BuildArgs t7 = [exec cp testdata/bpf/xdp_pass.bpf.o $arm64]
  DispatchBind t8 = t7 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t8 argv=t7 primary=_ rc=_ guard=true fail=bb2
  BuildArgs t9 = [exec bpfman image generate-build-args --cilium-ebpf-project $dir.path -o json]
  DispatchBind t10 = t9 policy=def-then-exec-bind lane=builtin(exec)
  ApplyBind src=t10 argv=t9 primary=rc rc=_ guard=false
  Assert $rc.ok
  Eval t11 = $rc.stdout |> jq "fromjson | .platforms | join(\",\")"
  BindName platforms = t11
  Assert $platforms == "linux/amd64,linux/arm64"
  Eval t12 = $rc.stdout |> jq "fromjson | .build_args.BC_AMD64_EL"
  BindName got_amd64 = t12
  Assert $got_amd64 == $amd64
  Eval t13 = $rc.stdout |> jq "fromjson | .build_args.BC_ARM64_EL"
  BindName got_arm64 = t13
  Assert $got_arm64 == $arm64
  Eval t14 = $rc.stdout |> jq "fromjson | .programs.pass"
  BindName prog_type = t14
  Assert $prog_type == xdp
  Eval t15 = $rc.stdout |> jq "fromjson | .maps.xdp_pass_stats_map"
  BindName map_type = t15
  Assert $map_type == per_cpu_array
  RunDefers policy=program
  Stop

bb1:
  RunDefers policy=program
  PropagateError

bb2:
  RunDefers policy=program
  PropagateError
