# -*- mode: bpfman -*-
# Translation experiment: e2e/TestTC_IngressEgressIndependence.
#
# TC ingress and TC egress on the same interface are two
# separate dispatchers keyed by direction. Three members on
# ingress and two on egress must coexist without cross-talk;
# detaching every egress member must tear the egress dispatcher
# down without disturbing ingress.
#
# The script loads one TC program and reuses it for all five
# attaches (the dispatcher-side accounting is the test, not the
# program identity). Priorities are default, 100, 200 for ingress
# and default, 100 for egress; priority 0 requests the default 50.
#
# Run from e2e/:
#
#   cd e2e
#   sudo bpfman-shell new/TestTC_IngressEgressIndependence.bpfman
#
# Requires root.

guard pair <- net veth-pair
defer net release $pair

guard loaded <- bpfman program load file testdata/bpf/tc_counter.bpf.o --programs tc:stats
let prog = $loaded.programs[0]
defer bpfman program unload $prog

# Three members on ingress.
guard in_0 <- bpfman link attach tc $prog $pair.host_link ingress -p 0
guard in_100 <- bpfman link attach tc $prog $pair.host_link ingress -p 100
guard in_200 <- bpfman link attach tc $prog $pair.host_link ingress -p 200
defer bpfman link detach $in_0
defer bpfman link detach $in_100
defer bpfman link detach $in_200

guard snap_in_before <- bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex
assert ($snap_in_before |> jq ".members | length") == 3

# Two members on egress. No defers: the script detaches them
# mid-test as the operation under test.
guard eg_0 <- bpfman link attach tc $prog $pair.host_link egress -p 0
guard eg_100 <- bpfman link attach tc $prog $pair.host_link egress -p 100

guard snap_eg <- bpfman dispatcher get tc-egress $pair.host_nsid $pair.host_ifindex
assert ($snap_eg |> jq ".members | length") == 2

# Detach everything on egress; the egress dispatcher must vanish.
bpfman link detach $eg_0
bpfman link detach $eg_100
assert fail bpfman dispatcher get tc-egress $pair.host_nsid $pair.host_ifindex

# Ingress dispatcher must be untouched.
guard snap_in_after <- bpfman dispatcher get tc-ingress $pair.host_nsid $pair.host_ifindex
assert ($snap_in_after |> jq ".members | length") == 3
