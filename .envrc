use flake .
PATH_add $PWD/bin

# For a static build (`make STATIC=1`), enter the opt-in shell that
# adds glibc.static to the link path:
#
#     nix develop .#static -c make STATIC=1
#
# It is intentionally separate from the default shell: glibc.static
# ships only libc.a, and having it on the linker search path for an
# ordinary dynamic build makes ld resolve -lc to the static archive
# and emit glibc's NSS dlopen-at-runtime warnings.
