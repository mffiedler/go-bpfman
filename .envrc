# Enter the static-link devShell and default every `make` invocation
# to STATIC=1, so the daily local loop (make / make test / make
# build-image) produces a fully static binary against the same
# glibc.static the upstream container image is built with.
#
# The static shell is opt-in via this .envrc rather than via the
# flake's default shell because glibc.static's `-L` entry contains
# only libc.a; placing it ahead of the dynamic glibc on every
# shell's link path would make ld resolve -lc to the static archive
# for non-static builds and emit glibc's NSS dlopen-at-runtime
# warnings on every cgo link. Override with `STATIC=0 make` (or
# `nix develop -c make`) when a dynamic build is wanted.
use flake .#static
PATH_add $PWD/bin

# Toggle the mattn/go-sqlite3 (cgo) driver in place of the default
# pure-Go modernc.org/sqlite. Flip to 1 and `direnv reload` to make
# every `make` invocation in this shell pick up `cgo_sqlite`. The
# Makefile auto-appends `sqlite_omit_load_extension` whenever
# cgo_sqlite is set, so the static-link warning about runtime glibc
# dlopen does not appear. Leave at 0 (or unset) for the canonical
# modernc build.
: "${CGO_SQLITE:=0}"
if [ "$CGO_SQLITE" = "1" ]; then
    export EXTRA_TAGS="${EXTRA_TAGS:+$EXTRA_TAGS,}cgo_sqlite"
fi
