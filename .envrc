#use flake .#static
use flake
PATH_add $PWD/bin

# Toggle the mattn/go-sqlite3 (cgo) driver in place of the default
# pure-Go modernc.org/sqlite. Flip to 1 and `direnv reload` to make
# every `make` invocation in this shell pick up `cgo_sqlite`. The
# Makefile auto-appends `sqlite_omit_load_extension` whenever
# cgo_sqlite is set, so the static-link warning about runtime glibc
# dlopen does not appear. Leave at 0 (or unset) for the canonical
# modernc build.
: "${CGO_SQLITE:=0}"
if [ "$CGO_SQLITE" = "1" ]; then
    export EXTRA_TAGS="${EXTRA_TAGS:+$EXTRA_TAGS,}cgo_sqlite"
fi

# Default the bpfman image pullspec for the daily local loop.
# Local-only dev images (build-image-dev, build-image-amd64, etc.)
# never leave this host, so they live in the docker.io/library
# namespace under a plain `bpfman:latest` rather than the canonical
# quay.io/bpfman/bpfman:latest the Makefile defaults to. Push targets
# always set BPFMAN_IMG explicitly, so this default cannot
# accidentally redirect a publish.
export BPFMAN_IMG="${BPFMAN_IMG:-docker.io/library/bpfman:latest}"
