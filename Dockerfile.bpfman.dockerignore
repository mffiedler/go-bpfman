# In-container cross-build: needs the full source tree (COPY . .)
# but must not pull in host-built artefacts. A stale host
# bin/bpfman or dispatcher/*.bpf.o copied into the context would
# overlap with the in-container build outputs and could mask
# "didn't rebuild" bugs.
bin/
dispatcher/*.bpf.o
dispatcher/bpf/*.bpf.o
dispatcher/bpf/*.bpf.d

# Heavy/irrelevant trees that never need to be in the build context.
.git/
.gitignore
*.md
build/
scripts/
