# Multi-arch runtime image for go-bpfman.
#
# The bpfman binary is statically linked, so no base OS is needed.
# This Dockerfile expects a pre-built binary at bin/bpfman. The CI
# workflow builds these per-architecture and passes them via the
# build context.

FROM scratch

COPY bin/bpfman /bpfman

ENV BPFMAN_MODE=bpfman-rpc
ENV BPFMAN_PPROF_ADDRESS=localhost:6060
ENTRYPOINT ["/bpfman"]
